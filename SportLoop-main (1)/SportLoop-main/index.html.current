        nickname: row.nickname || "",
        realName: row.real_name || "",
        studentId: row.student_id || "",
        authStatus: row.auth_status || "未认证",
        college: row.college || "",
        campusRole: row.campus_role || "学生",
        campusCard: row.campus_card || "未绑定",
      };
