    function profileRateData(loans) {
      const returnedLoans = loans
        .filter((loan) => ["已归还", "异常已归还"].includes(loan.status) && typeof loan.returnedOnTime === "boolean")
        .slice()
        .reverse();
      let onTimeCount = 0;
      return returnedLoans.map((loan, index) => {
        if (loan.returnedOnTime) onTimeCount += 1;
        return Math.round((onTimeCount / (index + 1)) * 100);
      });
    }

    function profileRateChart(rates) {
      if (rates.length < 2) {
        const y = rates.length === 1 ? 58 - (rates[0] / 100) * 44 : 45;
        return `<svg class="profile-rate-chart" viewBox="0 0 130 74" fill="none" aria-hidden="true">
          <path d="M8 ${y}H122" stroke="rgba(159,18,57,.14)" stroke-width="11" stroke-linecap="round"/>
          <path d="M8 ${y}H122" stroke="#9f1239" stroke-width="4" stroke-linecap="round"/>
        </svg>`;
      }

      const points = rates.map((rate, index) => {
        const x = 8 + (index * 114) / (rates.length - 1);
        const y = 58 - (rate / 100) * 44;
        return `${Number(x.toFixed(1))},${Number(y.toFixed(1))}`;
      }).join(" ");
      const last = points.split(" ").pop().split(",");

      return `<svg class="profile-rate-chart" viewBox="0 0 130 74" fill="none" aria-hidden="true">
        <polyline points="${points}" stroke="rgba(159,18,57,.14)" stroke-width="11" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        <polyline points="${points}" stroke="#9f1239" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        <circle cx="${last[0]}" cy="${last[1]}" r="5" fill="#9f1239"/>
      </svg>`;
    }

    function clampScore(value) {
      return Math.max(0, Math.min(100, value));
    }

    function creditLevel(score) {
      if (score >= 90) return "优秀";
      if (score >= 80) return "良好";
      if (score >= 70) return "合格";
      if (score >= 60) return "待提升";
      return "暂停借用";
    }

    function creditSummary() {
      const active = confirmedBorrowLoans();
      const returned = store.loans.filter((loan) => ["已归还", "异常已归还"].includes(loan.status));
      const onTimeReturned = returned.filter((loan) => loan.returnedOnTime === true && loan.status === "已归还").length;
      const lateReturned = returned.filter((loan) => loan.returnedOnTime === false).length;
      const abnormalReturned = returned.filter((loan) => loan.status === "异常已归还" || detectionIsAbnormal(loan)).length;
      const abnormalActive = active.filter((loan) => loan.status === "异常待归还" || detectionIsAbnormal(loan)).length;
      const overdueActive = active.filter((loan) => Number.isFinite(Number(loan.dueAtMs)) && Date.now() > Number(loan.dueAtMs)).length;
      const onTimeBonus = Math.min(onTimeReturned * 2, 10);
      const latePenalty = lateReturned * 8;
      const abnormalPenalty = (abnormalReturned + abnormalActive) * 10;
      const overduePenalty = overdueActive * 12;
      const score = clampScore(90 + onTimeBonus - latePenalty - abnormalPenalty - overduePenalty);
      return {
        score,
        level: creditLevel(score),
        onTimeReturned,
        lateReturned,
        abnormalCount: abnormalReturned + abnormalActive,
        overdueActive,
        rows: [
          ["基础信用", "完成校园认证后的初始分", "+90"],
          ["准时归还", `准时 ${onTimeReturned} 次，每次 +2，上限 +10`, `+${onTimeBonus}`],
          ["超时归还", `超时 ${lateReturned} 次，每次 -8`, `-${latePenalty}`],
          ["异常归还", `异常 ${abnormalReturned + abnormalActive} 次，每次 -10`, `-${abnormalPenalty}`],
          ["当前逾期", `逾期未还 ${overdueActive} 件，每件 -12`, `-${overduePenalty}`],
        ],
      };
    }

    function profilePage() {
      const archiveActive = activeBorrowLoans();
      const active = confirmedBorrowLoans();
      const returned = store.loans.filter((loan) => ["已归还", "异常已归还"].includes(loan.status) && typeof loan.returnedOnTime === "boolean");
      const currentCount = archiveActive.length;
      const pendingPhotoCount = archiveActive.filter(loanNeedsBeforePhoto).length;
      const completedLoans = store.loans.filter((loan) => !loanNeedsBeforePhoto(loan));
      const weekCount = completedLoans.length;
      const ratePoints = profileRateData(completedLoans);
      const latestRate = ratePoints[ratePoints.length - 1];
      const rateText = ratePoints.length ? String(latestRate) : "--";
      const nearestDue = active
        .map((loan) => Number(loan.dueAtMs))
        .filter(Number.isFinite)
        .sort((a, b) => a - b)[0];
      const dueText = pendingPhotoCount === currentCount && currentCount
        ? "待补照片"
        : Number.isFinite(nearestDue)
          ? formatDueTime(nearestDue)
          : (currentCount ? "待归还" : "暂无");
      const rateChart = profileRateChart(ratePoints);
      const nickname = profileNickname();
      const credit = creditSummary();
      const body = `
        <main class="scroll profile-scroll">
          <section class="profile-identity">
            <div class="avatar profile-main-avatar"></div><!-- 保留原头像样式 -->
            <div>
              <button class="profile-name-line profile-name-edit-button" data-edit-profile-name type="button" aria-label="编辑昵称">
                <h2>${escapeHtml(nickname)}</h2>
                <span class="profile-edit" aria-hidden="true">${icon("edit")}</span>
              </button>
              <p class="profile-meta">${escapeHtml(profileMetaText())}</p>
            </div>
            <button class="profile-identity-more" data-route="profileInfo" type="button" aria-label="查看个人信息">${icon("chevron")}</button>
          </section>

          <section class="profile-file">
            <img class="profile-folder-img" src="${escapeAttr(assetUrl(PROFILE_FOLDER_SRC))}" alt="" aria-hidden="true" loading="eager" decoding="async" fetchpriority="high" />
            <div class="profile-file-card">
              <div class="profile-file-title">
                <h2>我的借用档案</h2>
                <button class="profile-round-link" data-route="borrow" aria-label="查看借用档案">${icon("chevron")}</button>
              </div>
              <div class="profile-file-panel">
                <div class="profile-file-metrics">
                  <div class="profile-file-metric">
                    <span>${icon("shield")} 校园信用</span>
                    <strong>${escapeHtml(credit.level)}</strong>
                  </div>
                  <div class="profile-file-metric">
                    <span>${icon("bag")} 当前借用</span>
                    <strong>${currentCount}<small> 件</small></strong>
                  </div>
                  <div class="profile-file-metric">
                    <span>${icon("clock")} 待归还</span>
                    <strong><em>${dueText}</em></strong>
                  </div>
                </div>
	                <div class="profile-file-actions">
	                  <button data-route="borrow">${icon("file")} 查看详情</button>
	                  <button data-route="renew">${icon("refresh")} 申请续借</button>
	                  <button data-route="report">${icon("wrench")} 报损</button>
	                  <button class="profile-return-button" data-route="borrow">去归还 ${icon("chevron")}</button>
	                </div>
              </div>
            </div>
          </section>

          <section class="profile-stats-card">
            <div>
              <p class="profile-stat-label">本周借用</p>
              <p class="profile-stat-value">${weekCount}<small> 次</small></p>
              <p class="profile-stat-note">较上周 <b>↑</b> ${weekCount ? "1次" : "0次"}</p>
            </div>
            <span class="profile-divider"></span>
            <div class="profile-rate">
              <div>
                <p class="profile-stat-label">准时归还率</p>
                <p class="profile-stat-value">${rateText}<small>${returned.length ? "%" : ""}</small></p>
                <p class="profile-stat-note">${ratePoints.length ? "按归还记录计算" : "暂无记录"}</p>
              </div>
              ${rateChart}
            </div>
          </section>

          <section class="profile-shortcuts">
            <button class="profile-shortcut" data-route="borrow"><i>${icon("bag")}</i><strong>我的借用</strong><span>查看当前借用</span></button>
            <button class="profile-shortcut" data-route="borrow"><i>${icon("clock")}</i><strong>历史记录</strong><span>借用与归还记录</span></button>
            <button class="profile-shortcut" data-route="report"><i>${icon("wrench")}</i><strong>报修/报损</strong><span>器材问题反馈</span></button>
            <button class="profile-shortcut" data-route="renew"><i>${icon("refresh")}</i><strong>续借申请</strong><span>选择器材续借</span></button>
          </section>

          <section class="profile-settings">
            <button class="profile-setting-row" data-route="borrow">${icon("bell")}<strong>归还提醒</strong><span>开启归还前提醒</span>${icon("chevron")}</button>
            <button class="profile-setting-row" data-route="messages">${icon("message")}<strong>消息通知</strong><span>系统通知与提醒</span>${icon("chevron")}</button>
            <button class="profile-setting-row" data-route="identity">${icon("idcard")}<strong>校园认证</strong><span>学号与身份管理</span>${icon("chevron")}</button>
            <button class="profile-setting-row" data-route="creditRules">${icon("shield")}<strong>信用规则</strong><span>了解信用评分规则</span>${icon("chevron")}</button>
            <button class="profile-setting-row" data-route="report">${icon("help")}<strong>帮助与反馈</strong><span>常见问题与反馈</span>${icon("chevron")}</button>
            <button class="profile-setting-row" data-route="nfcMachine">${icon("scan")}<strong>NFC 机器模式</strong><span>场馆验证机专用页面</span>${icon("chevron")}</button>
            <button class="profile-setting-row" data-route="contactAdmin">${icon("headset")}<strong>联系管理员</strong><span>意见建议与咨询</span>${icon("chevron")}</button>
            <button class="profile-setting-row logout-row" data-logout>${icon("logout")}<strong>退出登录</strong><span>回到登录页面</span>${icon("chevron")}</button>
          </section>
        </main>
      `;
      return `
        <section class="screen profile-screen">
          <header class="profile-topbar">
            <h1>我的</h1>
            <button class="profile-gear" data-route="profileInfo" aria-label="个人信息">${icon("gear")}</button>
          </header>
          ${notice()}
          ${body}
          ${tabbar()}
        </section>
      `;
    }

    function syncBorrowFromMachine(equipmentId, options = {}) {
      const item = byId(equipmentId);
      if (!item) {
        state.notice = "暂无这个器材，无法借用";
        if (!options.skipNavigate) render();
        return null;
      }
      const existing = store.loans.find((loan) => loan.equipmentId === equipmentId && ["等待NFC验证", "待补借出照片", "使用中", "待归还", "异常待归还"].includes(loan.status));
      if (existing) {
        if (existing.status === "等待NFC验证" && isVerificationCodeExpired(existing)) {
          const newCode = generateVerificationCode();
          existing.verificationCode = newCode;
          existing.verificationCodeExpiresAt = verificationCodeExpiresAt();
          existing.borrowedAtMs = Date.now();
          existing.borrowedAt = formatDateTime(existing.borrowedAtMs);
          saveStore();
          runRemote(() => supabaseRequest(`loans?id=eq.${existing.id}`, { method: "PATCH", body: { verification_code: newCode, verification_code_expires_at: existing.verificationCodeExpiresAt, borrowed_at: toIso(existing.borrowedAtMs) } }));
          if (options.skipNavigate) return existing;
          route("borrowConfirm", { loanId: existing.id });
          return existing;
        }
        state.notice = existing.status === "等待NFC验证" ? "该器材已有待验证的借用，请前往场馆 NFC 机器完成验证" : "该器材已有进行中的借用，无需重复借用";
        if (!options.skipNavigate) render();
        return existing;
      }
      if (item.available <= 0 || item.status === "维修中") {
        state.notice = "场馆暂无可用库存";
        if (!options.skipNavigate) render();
        return null;
      }
      const borrowedAtMs = Date.now();
      const durationPeriods = selectedBorrowPeriods();
      const durationMinutes = durationPeriods * CLASS_PERIOD_MINUTES;
      const dueAtMs = borrowedAtMs + durationMinutes * 60 * 1000;
      const verificationCode = generateVerificationCode();
      const profile = profileData();
      const loan = {
        id: makeUuid(),
        equipmentId,
        borrowedAt: formatDateTime(borrowedAtMs),
        borrowedAtMs,
        dueAt: formatDueTime(dueAtMs),
        dueAtMs,
        durationPeriods,
        durationMinutes,
        durationLabel: borrowDurationLabel(durationPeriods),
        status: "等待NFC验证",
        detectResult: "",
        beforePhotoDataUrl: "",
        returnPhotoDataUrl: "",
        returnMachineAllowed: false,
        nfcSerial: "",
        nfcVerifiedAt: "",
        verificationCode,
        verificationCodeExpiresAt: verificationCodeExpiresAt(),
        studentName: profile.realName || profileNickname(),
        studentId: profile.studentId || "",
      };
      store.loans.unshift(loan);
      pushMessage("借用申请已提交", `${item.name} ${item.assetId} 验证码：${verificationCode}，请前往场馆 NFC 机器完成验证。`);
      saveStore();
      createRemoteLoan(loan);
      if (options.skipNavigate) return loan;
      route("borrowConfirm", { loanId: loan.id });
      return loan;
    }

    async function finishBorrowWithBeforePhoto(loanId) {
      const loan = loanById(loanId);
      if (!loan) return;
      const item = byId(loan.equipmentId);
      if (!item) return;
      if (!loanNeedsBeforePhoto(loan)) {
        state.notice = "这条借用已经完成借出前照片";
        render();
        return;
      }
      const shouldReserveInventory = loan.status === "待补借出照片";
      if (shouldReserveInventory && (item.available <= 0 || item.status === "维修中")) {
        state.notice = "场馆暂无可用库存，请确认机器借出是否有效";
        render();
        return;
      }
      const previousLoan = { ...loan };
      const previousItem = { available: item.available, status: item.status };
      const request = loan.batchRequestId ? batchRequestById(loan.batchRequestId) : null;
      const previousRequest = request ? { status: request.status, adminNote: request.adminNote, borrowedAt: request.borrowedAt, borrowedAtMs: request.borrowedAtMs } : null;

      try {
        loan.beforePhotoDataUrl = await readImageDataUrl("borrowBeforePhotoInput", "借出前照片");
        loan.status = "使用中";
        loan.detectResult = "";
        loan.returnPhotoDataUrl = "";
        loan.returnMachineAllowed = false;
        if (shouldReserveInventory) {
          item.available -= 1;
          item.status = item.available > 0 ? "可借" : "补充中";
        }

        if (request) {
          const pending = store.loans.some((row) => row.batchRequestId === request.id && loanNeedsBeforePhoto(row));
          if (!pending) {
            request.status = "已借出";
            request.adminNote = "已补齐借出前照片";
            request.borrowedAt = loan.borrowedAt;
            request.borrowedAtMs = loan.borrowedAtMs;
          }
        }

        await Promise.all([
          shouldReserveInventory ? updateRemoteEquipment(item) : Promise.resolve(),
          updateRemoteLoan(loan),
          request ? saveRemoteBatchRequest(request) : Promise.resolve(),
        ]);
      } catch (error) {
        Object.assign(loan, previousLoan);
        item.available = previousItem.available;
        item.status = previousItem.status;
        if (request && previousRequest) Object.assign(request, previousRequest);
        state.notice = error.message || "借出前照片保存失败";
        render();
        return;
      }

      pushMessage("借用成功", `${item.name} ${item.assetId} 已保存借出前照片，归还截止 ${loan.dueAt}。`);
      saveStore();
      state.notice = "借用成功";
      route("borrowConfirm", { loanId: loan.id });
    }

    function loadImageFromFile(file, label) {
      const objectUrl = URL.createObjectURL(file);
      return new Promise((resolve, reject) => {
        const img = new Image();
        img.onload = () => {
          URL.revokeObjectURL(objectUrl);
          resolve(img);
        };
        img.onerror = () => {
          URL.revokeObjectURL(objectUrl);
          reject(new Error(`${label}读取失败`));
        };
        img.src = objectUrl;
      });
    }

    async function compressImageFile(file, label) {
      const img = await loadImageFromFile(file, label);
      const ratio = Math.min(1, PHOTO_MAX_SIDE / Math.max(img.naturalWidth, img.naturalHeight));
      const width = Math.max(1, Math.round(img.naturalWidth * ratio));
      const height = Math.max(1, Math.round(img.naturalHeight * ratio));
      const canvas = document.createElement("canvas");
      canvas.width = width;
      canvas.height = height;
      const ctx = canvas.getContext("2d");
      if (!ctx) throw new Error(`${label}压缩失败`);
      ctx.fillStyle = "#fff";
      ctx.fillRect(0, 0, width, height);
      ctx.drawImage(img, 0, 0, width, height);
      const dataUrl = canvas.toDataURL("image/jpeg", PHOTO_JPEG_QUALITY);
      if (!dataUrl || dataUrl.length > PHOTO_MAX_DATA_URL_LENGTH) throw new Error(`${label}太大，请重新拍摄近一点的照片`);
      return dataUrl;
    }

    async function readImageDataUrl(inputId, label) {
      const input = document.querySelector(`#${inputId}`);
      const file = input?.files?.[0];
      if (!file) throw new Error(`请先上传${label}`);
      if (!file.type.startsWith("image/")) throw new Error(`${label}必须是图片`);
      if (file.size > 10 * 1024 * 1024) throw new Error(`${label}不能超过 10MB`);
      return compressImageFile(file, label);
    }

    async function runAiDetection(loanId) {
      const loan = loanById(loanId);
      if (!loan) return;
      const item = byId(loan.equipmentId);
      if (!item) return;
      const button = document.querySelector(`[data-ai-detect="${loanId}"]`);
      const originalHtml = button?.innerHTML || "";
      try {
        if (button) {
          button.disabled = true;
          button.innerHTML = `<span class="loading-spinner" aria-hidden="true"></span>`;
        }
        if (!loan.beforePhotoDataUrl) throw new Error("请先完成借出前照片上传");
        const afterImageDataUrl = await readImageDataUrl("photoInput", "归还照片");
        const result = await supabaseFunctionRequest("analyze-equipment-damage", {
          equipmentName: item.name,
          assetId: item.assetId,
          beforeImageDataUrl: loan.beforePhotoDataUrl,
          afterImageDataUrl,
        });
        const normalizedResult = parseDetectionResult(serializeDetectionResult(result));
        loan.detectResult = serializeDetectionResult({
          status: normalizedResult.status,
          damage_level: normalizedResult.damageLevel,
          confidence: normalizedResult.confidence,
          risk_label: normalizedResult.riskLabel,
          issue_count: normalizedResult.issueCount,
          summary: normalizedResult.summary,
          issues: normalizedResult.issues,
          needs_admin_review: normalizedResult.needsAdminReview,
          target_matched: normalizedResult.targetMatched,
          comparable: normalizedResult.comparable,
        });
        loan.returnPhotoDataUrl = afterImageDataUrl;
        const passed = detectionCanPass(normalizedResult);
        loan.returnMachineAllowed = passed;
        loan.status = passed ? "待归还" : "异常待归还";
        if (!passed) {
          createOrder(item.id, "MiniMax 归还检测异常", normalizedResult.summary || "检测未通过", loan.id);
        }
        pushMessage("归还检测完成", passed
          ? `${item.name} 检测正常，机器端已允许扫码归还。`
          : `${item.name} 检测异常，暂不允许机器扫码归还，已生成复核记录。`);
        saveStore();
        saveRemoteLoan(loan);
        route("result", { loanId });
      } catch (error) {
        state.notice = error instanceof Error ? error.message : "检测失败";
        if (button) {
          button.disabled = false;
          button.innerHTML = originalHtml;
        }
        render();
      }
    }

    function syncReturnFromMachine(loanId, options = {}) {
      const loan = loanById(loanId);
      if (!loan) return null;
      const item = byId(loan.equipmentId);
      if (!item) return null;
      if (!loan.detectResult || !loan.returnMachineAllowed) {
        state.notice = "请先完成归还检测，检测正常后机器才允许扫码归还";
        if (!options.skipNavigate) render();
        return null;
      }
      if (!loanCanMachineReturn(loan)) {
        state.notice = "当前记录不可同步归还";
        if (!options.skipNavigate) render();
        return null;
      }
      loan.status = "已归还";
      const returnedAtMs = Date.now();
      loan.returnedAt = formatDateTime(returnedAtMs);
      loan.returnedAtMs = returnedAtMs;
      loan.returnedOnTime = Number.isFinite(Number(loan.dueAtMs)) ? returnedAtMs <= Number(loan.dueAtMs) : null;
      item.available = Math.min(item.total, item.available + 1);
      item.status = "可借";
      const punctualText = loan.returnedOnTime === true ? "准时归还" : (loan.returnedOnTime === false ? "超时归还" : "未计入准时率");
      pushMessage("归还记录已同步", `${item.name} 的归还状态已从场馆机器同步，检测结果：${detectionLabel(loan)}，${punctualText}。`);
      saveStore();
      saveRemoteEquipment(item);
      saveRemoteLoan(loan);
      if (options.skipNavigate) return loan;
      state.notice = "归还状态已同步";
      route("borrow");
      return loan;
    }

    function setBatchBorrowStatus(message) {
      const status = document.querySelector("#batchBorrowStatus");
      if (status) status.textContent = message;
    }

    function batchFormItems(form) {
      const qtyInputs = new Map(Array.from(form.querySelectorAll("[data-batch-qty]")).map((node) => [node.dataset.batchQty, node]));
      const selected = Array.from(form.querySelectorAll("[data-batch-select]:checked"));
      return selected.map((node) => {
        const item = byId(node.dataset.batchSelect);
        const qtyInput = qtyInputs.get(node.dataset.batchSelect);
        const qty = Number(qtyInput?.value || 0);
        return { item, qty };
      });
    }

    async function submitBatchBorrowRequest(event) {
      event.preventDefault();
      const form = event.currentTarget;
      const profile = profileData();
      if (profile.authStatus !== "已认证" || !profile.realName || !profile.studentId || !profile.college) {
        setBatchBorrowStatus("请先完成校园认证，再提交批量申请");
        return;
      }

      const rows = batchFormItems(form);
      if (!rows.length) {
        setBatchBorrowStatus("请至少选择一种器材");
        return;
      }
      const invalid = rows.find(({ item, qty }) => !item || !Number.isInteger(qty) || qty < 1 || qty > item.available);
      if (invalid) {
        setBatchBorrowStatus("数量必须是正整数，且不能超过剩余库存");
        return;
      }
      const totalCount = rows.reduce((sum, row) => sum + row.qty, 0);
      if (totalCount < 2) {
        setBatchBorrowStatus("批量申请至少 2 件器材");
        return;
      }

      const periods = selectedBorrowPeriods();
      const request = {
        id: makeUuid(),
        userId: authSession.userId,
        studentName: profile.realName,
        studentId: profile.studentId,
        items: rows.map(({ item, qty }) => ({
          equipmentId: item.id,
          assetId: item.assetId,
          name: item.name,
          venue: cleanVenue(item.venue),
          qty,
        })),
        durationPeriods: periods,
        durationMinutes: periods * CLASS_PERIOD_MINUTES,
        durationLabel: borrowDurationLabel(periods),
        status: "待审核",
        adminNote: "等待管理员审批",
        createdAt: nowText(),
        borrowedAt: "",
        returnedAt: "",
      };

      try {
        await createRemoteBatchRequest(request);
      } catch (error) {
        setBatchBorrowStatus(error.message || "申请提交失败");
        return;
      }

      batchRequestList().unshift(request);
      saveStore();
      state.notice = "";
      render();
    }

    async function notifyBatchRequestUser(request, title, body) {
      if (!request.userId) return;
      await supabaseRequest("student_messages", {
        method: "POST",
        body: { user_id: request.userId, title, body },
      });
    }

    async function approveBatchRequest(requestId, approved) {
      const request = batchRequestById(requestId);
      if (!request || request.status !== "待审核") return;
      const previous = { status: request.status, adminNote: request.adminNote };
      request.status = approved ? "已通过" : "已拒绝";
      request.adminNote = approved ? "管理员已通过" : "管理员已拒绝";
      try {
        await saveRemoteBatchRequest(request);
        await notifyBatchRequestUser(
          request,
          approved ? "批量申请已通过" : "批量申请未通过",
          approved ? "请到场馆机器完成批量借出后，在批量申请页同步记录。" : "这次批量借出申请未通过，请调整后重新提交。"
        );
      } catch (error) {
        request.status = previous.status;
        request.adminNote = previous.adminNote;
        state.notice = error.message || "审批失败";
        render();
        return;
      }
      saveStore();
      createAdminOperationLog(
        approved ? "通过批量申请" : "拒绝批量申请",
        "batch_borrow_requests",
        request.id,
        `${request.studentName || "学生"} 的批量申请已${approved ? "通过" : "拒绝"}`,
        { studentId: request.studentId, itemCount: (request.items || []).length }
      );
      state.notice = approved ? "批量申请已通过" : "批量申请已拒绝";
      render();
    }

    function validateBatchBorrowRequest(request) {
      if (!request) return "未找到这次批量申请";
      if (request.status !== "已通过") return "管理员通过后才能机器批量借出";
      const hasBorrowed = store.loans.some((loan) => loan.batchRequestId === request.id && ["等待NFC验证", "待补借出照片", "使用中", "待归还", "异常待归还"].includes(loan.status));
      if (hasBorrowed) return "这次申请已经同步过借出";
      for (const row of request.items || []) {
        const item = byId(row.equipmentId);
        const qty = Number(row.qty || 0);
        if (!item) return `未找到 ${row.name || "器材"}`;
        if (item.status !== "可借" || item.available < qty) return `${item.name} 当前库存不足`;
      }
      return "";
    }

    async function syncBatchBorrowFromMachine(requestId) {
      const request = batchRequestById(requestId);
      const errorMessage = validateBatchBorrowRequest(request);
      if (errorMessage) {
        state.notice = errorMessage;
        render();
        return;
      }
      const borrowedAtMs = Date.now();
      const dueAtMs = borrowedAtMs + request.durationMinutes * 60 * 1000;
      const loans = [];
      for (const row of request.items) {
        const item = byId(row.equipmentId);
        for (let index = 0; index < Number(row.qty); index += 1) {
          loans.push({
            id: makeUuid(),
            equipmentId: item.id,
            borrowedAt: formatDateTime(borrowedAtMs),
            borrowedAtMs,
            dueAt: formatDueTime(dueAtMs),
            dueAtMs,
            durationPeriods: request.durationPeriods,
            durationMinutes: request.durationMinutes,
            durationLabel: request.durationLabel,
            status: "待补借出照片",
            detectResult: "",
            beforePhotoDataUrl: "",
            returnPhotoDataUrl: "",
            returnMachineAllowed: false,
            batchRequestId: request.id,
          });
        }
      }
      const previous = { status: request.status, adminNote: request.adminNote, borrowedAt: request.borrowedAt, borrowedAtMs: request.borrowedAtMs };
      request.status = "待补照片";
      request.adminNote = "等待上传借出前照片";
      request.borrowedAt = formatDateTime(borrowedAtMs);
      request.borrowedAtMs = borrowedAtMs;
      store.loans.unshift(...loans);

      try {
        await Promise.all([
          ...loans.map((loan) => insertRemoteLoan(loan, request.userId)),
          saveRemoteBatchRequest(request),
        ]);
      } catch (error) {
        store.loans = store.loans.filter((loan) => !loans.some((created) => created.id === loan.id));
        Object.assign(request, previous);
        state.notice = error.message || "机器批量扫码同步失败";
        render();
        return;
      }

      pushMessage("批量扫码已同步", `已同步 ${loans.length} 件器材，请逐件上传借出前照片后完成借用。`);
      saveStore();
      state.notice = "请上传借出前照片";
      route("borrow");
    }

    async function syncBatchReturnFromMachine(requestId) {
      const request = batchRequestById(requestId);
      if (!request || request.status !== "已借出") {
        state.notice = "只有已借出的批量申请才能批量归还";
        render();
        return;
      }
      const loans = store.loans.filter((loan) => loan.batchRequestId === request.id && ["使用中", "待归还", "异常待归还"].includes(loan.status));
      if (!loans.length) {
        state.notice = "未找到可批量归还的借用记录";
        render();
        return;
      }
      const notReady = loans.filter((loan) => !loanCanMachineReturn(loan));
      if (notReady.length) {
        state.notice = "请先逐件完成归还检测，全部正常后才能机器批量归还";
        render();
        return;
      }
      const returnedAtMs = Date.now();
      const touchedItems = [];
      const previousLoans = loans.map((loan) => ({ loan, data: { ...loan } }));
      loans.forEach((loan) => {
        const item = byId(loan.equipmentId);
        if (!item) return;
        touchedItems.push({ item, available: item.available, status: item.status });
        loan.status = "已归还";
        loan.returnedAt = formatDateTime(returnedAtMs);
        loan.returnedAtMs = returnedAtMs;
        loan.returnedOnTime = Number.isFinite(Number(loan.dueAtMs)) ? returnedAtMs <= Number(loan.dueAtMs) : null;
        item.available = Math.min(item.total, item.available + 1);
        item.status = "可借";
      });
      const previous = { status: request.status, adminNote: request.adminNote, returnedAt: request.returnedAt, returnedAtMs: request.returnedAtMs };
      request.status = "已归还";
      request.adminNote = "已在机器批量归还";
      request.returnedAt = formatDateTime(returnedAtMs);
      request.returnedAtMs = returnedAtMs;

      try {
        await Promise.all([
          ...touchedItems.map(({ item }) => updateRemoteEquipment(item)),
          ...loans.map((loan) => updateRemoteLoan(loan)),
          saveRemoteBatchRequest(request),
        ]);
      } catch (error) {
        touchedItems.forEach(({ item, available, status }) => {
          item.available = available;
          item.status = status;
        });
        previousLoans.forEach(({ loan, data }) => Object.assign(loan, data));
        Object.assign(request, previous);
        state.notice = error.message || "机器批量归还同步失败";
        render();
        return;
      }

      pushMessage("批量归还已同步", `已批量归还 ${loans.length} 件器材。`);
      saveStore();
      state.notice = "批量归还已同步";
      route("borrow");
    }

    function submitRenewLoan(loanId) {
      const loan = loanById(loanId);
      if (!canRenewLoan(loan)) {
        state.notice = "这条记录当前不可续借";
        render();
        return;
      }
      const item = byId(loan.equipmentId);
      if (!item) {
        state.notice = "未找到对应器材";
        render();
        return;
      }
      const periods = selectedBorrowPeriods();
      const extensionMinutes = periods * CLASS_PERIOD_MINUTES;
      const newDueAtMs = renewedDueAtMs(loan, periods);
      loan.dueAtMs = newDueAtMs;
      loan.dueAt = formatDueTime(newDueAtMs);
      loan.durationPeriods = Number(loan.durationPeriods || 0) + periods;
      loan.durationMinutes = Number(loan.durationMinutes || 0) + extensionMinutes;
      loan.durationLabel = `${loan.durationPeriods} 节课 · ${Number.isInteger(loan.durationMinutes / 60) ? loan.durationMinutes / 60 : (loan.durationMinutes / 60).toFixed(1)} 小时`;
      loan.renewedTimes = Number(loan.renewedTimes || 0) + 1;
      loan.renewalRecords = Array.isArray(loan.renewalRecords) ? loan.renewalRecords : [];
      loan.renewalRecords.unshift({
        renewedAt: nowText(),
        extensionPeriods: periods,
        extensionLabel: borrowDurationLabel(periods),
        dueAt: loan.dueAt,
      });
      pushMessage("续借申请已通过", `${item.name} 已续借 ${borrowDurationLabel(periods)}，新的归还截止为 ${loan.dueAt}。`);
      saveStore();
      saveRemoteLoan(loan);
      state.notice = "续借申请已通过";
      route("borrow", { loanId });
    }

    function createOrder(equipmentId, source, title, loanId = "") {
      const exists = store.workOrders.some((order) => order.loanId === loanId && loanId);
      if (exists) return;
      const order = {
        id: makeUuid(),
        userId: state.currentUserId,
        equipmentId,
        loanId,
        title,
        source,
        status: "待处理",
        createdAt: nowText(),
        restored: false,
      };
      store.workOrders.unshift(order);
      saveStore();
      createRemoteWorkOrder(order);
    }

    function updateOrder(orderId, status) {
      const order = store.workOrders.find((item) => item.id === orderId);
      if (!order) return;
      const item = byId(order.equipmentId);
      if (!item) {
        state.notice = "未找到对应器材";
        render();
        return;
      }
      order.status = status;
      if (status === "暂停借出") item.status = "异常待确认";
      if (status === "维修中") item.status = "维修中";
      if (status === "已完成") {
        item.status = "可借";
        if (!order.restored) {
          item.available = Math.min(item.total, item.available + 1);
          order.restored = true;
        }
        pushMessage("报修已完成", `${item.name} 已维修完成，恢复可借。`);
      }
      saveStore();
      saveRemoteWorkOrder(order);
      saveRemoteEquipment(item);
      createAdminOperationLog("更新报修工单", "work_orders", order.id, `${item.name} 更新为 ${status}`, {
        equipmentId: item.id,
        assetId: item.assetId,
      });
      state.notice = `工单已更新为：${status}`;
      render();
    }

    function loginPage() {
      return `
        <section class="screen">
          <main class="scroll login-center">
            <div class="login-hero">
              <img class="login-icon" src="${escapeAttr(assetUrl(APP_ICON_SRC))}" alt="SportLoop" decoding="async" fetchpriority="high" />
              <h1>SportLoop</h1>
              <p>校园体育器材借用与维保</p>
            </div>
            <button class="primary-button login-btn" data-route="roleSelect">点击登录</button>
          </main>
        </section>
      `;
    }

    function profileInfoRow(iconName, label, value) {
      return `
        <div class="profile-info-row">
          ${icon(iconName)}
          <strong>${escapeHtml(label)}</strong>
          <span>${escapeHtml(value)}</span>
        </div>
      `;
    }

    function profileInfoPage() {
      const profile = profileData();
      const credit = creditSummary();
      const rows = [
        ["idcard", "学号", profile.studentId],
        ["user", "姓名", profile.realName],
        ["shield", "校园身份", profile.campusRole],
        ["check", "认证状态", profile.authStatus],
        ["file", "院系", profile.college],
        ["bag", "校园卡", profile.campusCard],
        ["clock", "借用信用", `${credit.level}（${credit.score}分）`],
      ];
      const body = `
        <main class="scroll profile-info-scroll">
          <section class="profile-info-hero">
            <div class="avatar profile-info-avatar"></div>
            <div>
              <p>当前昵称</p>
              <h2>${escapeHtml(profileNickname())}</h2>
              <button class="profile-info-edit" data-edit-profile-name type="button">${icon("edit")} 编辑昵称</button>
            </div>
          </section>
          <section class="profile-settings profile-info-card">
            ${rows.map(([iconName, label, value]) => profileInfoRow(iconName, label, value)).join("")}
          </section>
        </main>
      `;
      return shell("个人信息", body, { tabs: false });
    }

    function creditRuleRow(title, desc, value) {
      return `
        <div class="credit-rule-row">
          <span><strong>${escapeHtml(title)}</strong><span>${escapeHtml(desc)}</span></span>
          <b>${escapeHtml(value)}</b>
        </div>
      `;
    }

    function creditRulesPage() {
      const credit = creditSummary();
      const levels = [
        ["优秀", "90-100 分", "借用正常，信用表现稳定"],
        ["良好", "80-89 分", "可正常借用，注意按时归还"],
        ["合格", "70-79 分", "可借用，系统会加强提醒"],
        ["待提升", "60-69 分", "建议减少逾期和异常记录"],
        ["暂停借用", "0-59 分", "需联系管理员处理后恢复"],
      ];
      const body = `
        <main class="scroll profile-info-scroll">
          <section class="credit-summary-card">
            <div class="credit-score-ring" style="--score:${credit.score}">
              <div><span>信用分</span><strong>${credit.score}</strong></div>
            </div>
            <div>
              <p>当前校园信用</p>
              <h2>${escapeHtml(credit.level)}</h2>
              <small>按借用记录实时计算，当前 ${credit.score} 分。</small>
            </div>
            <p class="credit-formula">计算公式：90 基础分 + 准时加分 - 超时扣分 - 异常扣分 - 当前逾期扣分。</p>
          </section>
          <section class="profile-settings credit-rule-card">
            <h3>计分规则</h3>
            ${credit.rows.map(([title, desc, value]) => creditRuleRow(title, desc, value)).join("")}
          </section>
          <section class="profile-settings credit-rule-card">
            <h3>信用等级</h3>
            ${levels.map(([title, value, desc]) => creditRuleRow(title, desc, value)).join("")}
          </section>
        </main>
      `;
      return shell("信用规则", body, { tabs: false });
    }

    function identityPage() {
      const profile = profileData();
      const body = `
        <main class="scroll profile-info-scroll">
          <section class="profile-info-hero">
            <div class="avatar profile-info-avatar"></div>
            <div>
              <p>认证状态</p>
              <h2>${escapeHtml(profile.authStatus)}</h2>
            </div>
          </section>
          <form class="profile-settings identity-form" id="identityForm">
            <label class="field">
              <span>姓名</span>
              <input name="realName" value="${escapeAttr(profile.realName || "")}" maxlength="12" required placeholder="请输入真实姓名" />
            </label>
            <label class="field">
              <span>学号</span>
              <input name="studentId" value="${escapeAttr(profile.studentId || "")}" maxlength="18" required inputmode="numeric" placeholder="请输入学号" />
            </label>
            <label class="field">
              <span>院系</span>
              <input name="college" value="${escapeAttr(profile.college || "")}" maxlength="20" required placeholder="请输入院系" />
            </label>
            <p class="identity-status" id="identityStatus" aria-live="polite"></p>
            <button class="primary-button" type="submit">${icon("check")} 保存认证</button>
          </form>
        </main>
      `;
      return shell("校园认证", body, { tabs: false });
    }

    function roleSelectPage() {
      return `
        <section class="screen">
          <header class="topbar">
            <button class="icon-button" data-route="login" aria-label="返回">${icon("back")}</button>
            <div class="page-title">选择身份</div>
            <span></span>
          </header>
          <main class="scroll">
            <div class="role-grid">
              <button class="role-card" data-role="student">
                <div class="role-icon">${icon("user")}</div>
                <h2>学生端</h2>
                <p>查看器材状态、借用记录、拍照检测、报损反馈</p>
              </button>
              <button class="role-card" data-role="admin">
                <div class="role-icon">${icon("shield")}</div>
                <h2>管理员端</h2>
                <p>处理报修工单、器材维保、库存状态管理</p>
              </button>
              <button class="role-card" data-role="machine">
                <div class="role-icon">${icon("scan")}</div>
                <h2>NFC 机器端</h2>
                <p>场馆验证机专用，需管理员账号登录</p>
              </button>
            </div>
          </main>
        </section>
      `;
    }

    function credentialsPage() {
      const isAdmin = state.loginRole === "admin" || state.loginRole === "machine";
      const isMachine = state.loginRole === "machine";
      const roleLabel = isMachine ? "NFC 机器端" : (isAdmin ? "管理员" : "学生");
      return `
        <section class="screen">
          <header class="topbar">
            <button class="icon-button" data-route="roleSelect" aria-label="返回">${icon("back")}</button>
            <div class="page-title">${roleLabel}登录</div>
            <span></span>
          </header>
          <main class="scroll">
            <form class="login-form" id="loginForm">
              <div class="login-avatar">
                <div class="role-badge">${icon(isMachine ? "scan" : (isAdmin ? "shield" : "user"))}</div>
                <span>${roleLabel}</span>
              </div>
              <label class="field">
                <span>账号</span>
                <input id="loginAccount" type="text" placeholder="请输入账号" autocomplete="username" />
              </label>
              <label class="field">
                <span>密码</span>
                <input id="loginPassword" type="password" placeholder="请输入密码" autocomplete="current-password" />
              </label>
              <p class="login-hint">请先注册账号；未注册的账号不能登录。</p>
              <button class="primary-button" type="submit">${icon("check")} 登录</button>
              <div class="login-switch">
                <span>还没有账号？</span>
                <button class="text-button" type="button" data-route="register">去注册</button>
              </div>
              ${loginStatusHtml()}
            </form>
          </main>
        </section>
      `;
    }

    function registerPage() {
      const isAdmin = state.loginRole === "admin";
      return `
        <section class="screen">
          <header class="topbar">
            <button class="icon-button" data-route="credentials" aria-label="返回">${icon("back")}</button>
            <div class="page-title">${isAdmin ? "管理员注册" : "学生注册"}</div>
            <span></span>
          </header>
          <main class="scroll">
            <form class="login-form" id="registerForm">
              <div class="login-avatar">
                <div class="role-badge">${icon(isAdmin ? "shield" : "user")}</div>
                <span>${isAdmin ? "管理员" : "学生"}</span>
              </div>
              <label class="field">
                <span>用户名</span>
                <input id="registerAccount" type="text" placeholder="请输入用户名" autocomplete="username" />
              </label>
              <label class="field">
                <span>密码</span>
                <input id="registerPassword" type="password" placeholder="至少 6 位密码" autocomplete="new-password" />
              </label>
              <label class="field">
                <span>确认密码</span>
                <input id="registerConfirm" type="password" placeholder="再输入一次密码" autocomplete="new-password" />
              </label>
              <p class="login-hint">注册后会连接 Supabase 创建真实账号。</p>
              <button class="primary-button" type="submit">${icon("check")} 注册</button>
              <div class="login-switch">
                <span>已有账号？</span>
                <button class="text-button" type="button" data-route="credentials">去登录</button>
              </div>
              ${loginStatusHtml()}
            </form>
          </main>
        </section>
      `;
    }

    function render() {
      if (!state.loggedIn) {
        appEl.classList.remove("is-admin-view");
        const loginPages = { login: loginPage, roleSelect: roleSelectPage, credentials: credentialsPage, register: registerPage };
        appEl.innerHTML = (loginPages[state.route] || loginPage)();
        bindLogin();
        return;
      }
      state.route = normalizeRouteForRole(state.route);
      appEl.classList.toggle("is-admin-view", state.route.startsWith("admin"));

      const pages = {
        home: homePage,
        list: listPage,
        detail: detailPage,
        scanBorrow: scanBorrowPage,
        borrowConfirm: borrowConfirmPage,
        borrow: borrowPage,
        batchBorrow: batchBorrowPage,
        renew: renewPage,
        renewDetail: renewDetailPage,
        detect: detectPage,
        result: resultPage,
        report: reportPage,
        messages: messagesPage,
        contactAdmin: contactAdminPage,
        nfcMachine: nfcMachinePage,
        admin: adminPage,
        adminBatch: () => adminModulePage("batch"),
        adminMessages: () => adminModulePage("messages"),
        adminOrders: () => adminModulePage("orders"),
        adminEquipment: () => adminModulePage("equipment"),
        adminSyncLogs: () => adminModulePage("syncLogs"),
        adminLogs: () => adminModulePage("logs"),
        adminExport: () => adminModulePage("export"),
        adminVenues: () => adminModulePage("venues"),
        profile: profilePage,
        profileInfo: profileInfoPage,
        creditRules: creditRulesPage,
        identity: identityPage,
      };
      appEl.innerHTML = (pages[state.route] || homePage)();
      bind();
    }

    function bindLogin() {
      document.querySelectorAll("[data-route]").forEach((node) => node.addEventListener("click", () => route(node.dataset.route)));

      document.querySelectorAll("[data-role]").forEach((node) => {
        node.addEventListener("click", () => {
          state.loginRole = node.dataset.role;
          route("credentials");
        });
      });

      const loginForm = document.querySelector("#loginForm");
      if (loginForm) {
        loginForm.addEventListener("submit", async (event) => {
          event.preventDefault();
          const account = document.querySelector("#loginAccount").value.trim();
          const password = document.querySelector("#loginPassword").value.trim();
          if (!account || !password) {
            state.notice = "账号和密码不能为空";
            render();
            return;
          }
          try {
            state.notice = "";
            state.loading = true;
            render();
            await handleLogin(account, password);
          } catch (error) {
            state.loading = false;
            state.notice = error.message || "登录失败";
            render();
          }
        });
      }

      const registerForm = document.querySelector("#registerForm");
      if (registerForm) {
        registerForm.addEventListener("submit", async (event) => {
          event.preventDefault();
          const account = document.querySelector("#registerAccount").value.trim();
          const password = document.querySelector("#registerPassword").value.trim();
          const confirm = document.querySelector("#registerConfirm").value.trim();
          if (!account || !password || !confirm) {
            state.notice = "用户名和密码都要填写完整";
            render();
            return;
          }
          if (password.length < 6) {
            state.notice = "密码至少 6 位";
            render();
            return;
          }
          if (password !== confirm) {
            state.notice = "两次输入的密码不一致";
            render();
            return;
          }
          try {
            state.notice = "";
            state.loading = true;
            render();
            await handleRegister(account, password);
          } catch (error) {
            state.loading = false;
            state.notice = error.message || "注册失败";
            render();
          }
        });
      }
    }

    function showConfirm(message, onConfirm, confirmLabel) {
      const label = confirmLabel || "确认";
      const overlay = document.createElement("div");
      overlay.className = "confirm-overlay";
      overlay.innerHTML = `
        <div class="confirm-dialog">
          <p>${message}</p>
          <div class="confirm-actions">
            <button class="btn-cancel">取消</button>
            <button class="btn-danger">${label}</button>
          </div>
        </div>
      `;
      overlay.querySelector(".btn-cancel").addEventListener("click", () => overlay.remove());
      overlay.querySelector(".btn-danger").addEventListener("click", () => {
        overlay.remove();
        onConfirm();
      });
      overlay.addEventListener("click", (e) => {
        if (e.target === overlay) overlay.remove();
      });
      document.querySelector("#app").appendChild(overlay);
    }

    /* ==================== NFC 扫描功能 ==================== */
    function supportsNfc() {
      return typeof window !== "undefined" && "NDEFReader" in window;
    }

    function normalizeNfcSerial(serial) {
      if (!serial) return "";
      return String(serial).replace(/[\s:-]/g, "").toUpperCase();
    }

    function nfcTagMatchesEquipment(serial, item) {
      if (!serial || !item || !Array.isArray(item.nfcTags) || !item.nfcTags.length) return false;
      const normalized = normalizeNfcSerial(serial);
      return item.nfcTags.some((tag) => normalizeNfcSerial(tag) === normalized);
    }

    async function scanNfcTag(timeoutMs = 45000) {
      if (!supportsNfc()) {
        throw new Error("此设备不支持 NFC 功能，请使用支持 NFC 的安卓设备并开启 Chrome 浏览器。");
      }

      const ndef = new NDEFReader();

      return new Promise((resolve, reject) => {
        let settled = false;

        const timeout = setTimeout(() => {
          if (settled) return;
          settled = true;
          try { ndef.stop(); } catch (_) { /* ignore */ }
          reject(new Error("NFC 扫描超时，请将设备靠近 NFC 标签重试。"));
        }, timeoutMs);

        const onReading = ({ serialNumber, message }) => {
          if (settled) return;
          settled = true;
          clearTimeout(timeout);
          try { ndef.stop(); } catch (_) { /* ignore */ }
          resolve({ serialNumber, message });
        };

        const onError = (event) => {
          if (settled) return;
          settled = true;
          clearTimeout(timeout);
          try { ndef.stop(); } catch (_) { /* ignore */ }
          reject(new Error(event.message || "NFC 读取失败，请重试。"));
        };

        ndef.addEventListener("reading", onReading, { once: true });
        ndef.addEventListener("readingerror", onError, { once: true });

        ndef.scan().catch((err) => {
          if (settled) return;
          settled = true;
          clearTimeout(timeout);
          let msg = "无法启动 NFC 扫描";
          if (err.message) {
            if (err.message.includes("NotAllowed") || err.message.includes("permission")) {
              msg = "NFC 权限被拒绝，请在系统设置中开启 NFC 并授权。";
            } else if (err.message.includes("NotSupported") || err.message.includes("not supported")) {
              msg = "此设备不支持 NFC 功能。";
            } else if (err.message.includes("NotReadable") || err.message.includes("not readable")) {
              msg = "NFC 不可用，请确认已开启手机 NFC 功能。";
            } else {
              msg = "NFC 启动失败：" + err.message;
            }
          }
          reject(new Error(msg));
        });
      });
    }

    function showNfcScan(item, onMatch, onCancel) {
      if (!supportsNfc()) {
        showNfcNotSupported(item, onCancel);
        return;
      }

      const overlay = document.createElement("div");
      overlay.className = "nfc-scan-overlay";
      overlay.setAttribute("aria-label", "NFC 扫描");
      overlay.innerHTML = `
        <div class="nfc-scan-dialog">
          <div class="nfc-device-visual">
            <span class="nfc-wave"></span>
            <span class="nfc-wave"></span>
            <span class="nfc-wave"></span>
            <div class="nfc-device-core">${icon("scan")}</div>
          </div>
          <h2>请触碰 NFC 标签</h2>
          <p class="nfc-hint">
            将设备靠近器材上的 NFC 标签以验证借用
            <strong>${escapeAttr(item.name)} · ${escapeAttr(item.assetId)}</strong>
          </p>
          <button class="nfc-btn-cancel" style="width:100%;" data-nfc-cancel>取消借用</button>
        </div>
      `;

      overlay.querySelector("[data-nfc-cancel]").addEventListener("click", () => {
        removeNfcOverlay();
        if (onCancel) onCancel();
      });
      overlay.addEventListener("click", (e) => {
        if (e.target === overlay) { removeNfcOverlay(); if (onCancel) onCancel(); }
      });

      let active = true;
      function removeNfcOverlay() {
        active = false;
        if (overlay.isConnected) overlay.remove();
      }

      document.querySelector("#app").appendChild(overlay);

      scanNfcTag(45000)
        .then(({ serialNumber }) => {
          if (!active) return;
          if (nfcTagMatchesEquipment(serialNumber, item)) {
            showNfcSuccess(overlay, () => {
              removeNfcOverlay();
              if (onMatch) onMatch(serialNumber);
            });
          } else {
            showNfcMismatch(overlay, item, () => {
              removeNfcOverlay();
              showNfcScan(item, onMatch, onCancel);
            }, () => {
              removeNfcOverlay();
              if (onCancel) onCancel();
            });
          }
        })
        .catch((err) => {
          if (!active) return;
          showNfcError(overlay, err.message, () => {
            removeNfcOverlay();
            showNfcScan(item, onMatch, onCancel);
          }, () => {
            removeNfcOverlay();
            if (onCancel) onCancel();
          });
        });
    }

    function showNfcSuccess(overlay, onContinue) {
      overlay.querySelector(".nfc-scan-dialog").innerHTML = `
        <div class="nfc-scan-icon nfc-scan-success-icon">${icon("check")}</div>
        <h2>验证成功</h2>
        <p class="nfc-hint">NFC 标签已识别，器材验证通过。</p>
        <button class="nfc-btn-retry" style="width:100%;" data-nfc-continue>继续借用</button>
      `;
      overlay.querySelector("[data-nfc-continue]").addEventListener("click", () => {
        if (onContinue) onContinue();
      });
    }

    function showNfcMismatch(overlay, item, onRetry, onCancel) {
      overlay.querySelector(".nfc-scan-dialog").innerHTML = `
        <div class="nfc-scan-icon nfc-scan-error-icon">${icon("alert")}</div>
        <h2>标签不匹配</h2>
        <p class="nfc-hint">
          此 NFC 标签与「${escapeAttr(item.name)}」的登记标签不匹配。
          请确认触碰的是该器材的正确标签。
        </p>
        <div class="nfc-actions">
          <button class="nfc-btn-cancel" data-nfc-cancel>取消</button>
          <button class="nfc-btn-retry" data-nfc-retry>重新扫描</button>
        </div>
      `;
      overlay.querySelector("[data-nfc-cancel]").addEventListener("click", () => {
        if (onCancel) onCancel();
      });
      overlay.querySelector("[data-nfc-retry]").addEventListener("click", () => {
        if (onRetry) onRetry();
      });
    }

    function showNfcError(overlay, message, onRetry, onCancel) {
      overlay.querySelector(".nfc-scan-dialog").innerHTML = `
        <div class="nfc-scan-icon nfc-scan-error-icon">${icon("alert")}</div>
        <h2>扫描失败</h2>
        <p class="nfc-hint">${escapeAttr(message)}</p>
        <div class="nfc-actions">
          <button class="nfc-btn-cancel" data-nfc-cancel>取消</button>
          <button class="nfc-btn-retry" data-nfc-retry>重试</button>
        </div>
      `;
      overlay.querySelector("[data-nfc-cancel]").addEventListener("click", () => {
        if (onCancel) onCancel();
      });
      overlay.querySelector("[data-nfc-retry]").addEventListener("click", () => {
        if (onRetry) onRetry();
      });
    }

    function showNfcNotSupported(item, onCancel) {
      const overlay = document.createElement("div");
      overlay.className = "nfc-scan-overlay";
      overlay.setAttribute("aria-label", "NFC 不可用");
      overlay.innerHTML = `
        <div class="nfc-scan-dialog">
          <div class="nfc-scan-icon nfc-scan-error-icon">${icon("alert")}</div>
          <h2>NFC 不可用</h2>
          <p class="nfc-hint">
            您的设备或浏览器不支持 Web NFC。
            请使用安卓设备 + Chrome 浏览器打开此页面。
          </p>
          <button class="nfc-btn-cancel" style="width:100%;" data-nfc-cancel>返回</button>
        </div>
      `;
      overlay.querySelector("[data-nfc-cancel]").addEventListener("click", () => {
        overlay.remove();
        if (onCancel) onCancel();
      });
      overlay.addEventListener("click", (e) => {
        if (e.target === overlay) { overlay.remove(); if (onCancel) onCancel(); }
      });
      document.querySelector("#app").appendChild(overlay);
    }

    /* ==================== NFC 机器模式 — 验证码流程 ==================== */
    function generateVerificationCode() {
      return String(Math.floor(100000 + Math.random() * 900000));
    }

    function verificationCodeExpiresAt() {
      return new Date(Date.now() + 5 * 60 * 1000).toISOString();
    }

    function isVerificationCodeExpired(loan) {
      if (!loan || !loan.verificationCodeExpiresAt) return true;
      return Date.now() > new Date(loan.verificationCodeExpiresAt).getTime();
    }

    async function findLoanByVerificationCode(code) {
      const rows = await supabaseRequest(
        `loans?select=*&verification_code=eq.${encodeURIComponent(code)}&order=created_at.desc&limit=1`
      );
      return Array.isArray(rows) && rows.length ? dbLoanToLocal(rows[0]) : null;
    }

    async function completeNfcMachineVerification(loanId, equipmentId, serialNumber) {
      const now = new Date().toISOString();
      return supabaseRequest(`loans?id=eq.${loanId}`, {
        method: "PATCH",
        body: {
          status: "待补借出照片",
          nfc_serial: serialNumber || "",
          nfc_verified_at: now,
        },
      });
    }

    /* ==================== NFC 机器模式页面 ==================== */
    let nfcMachineState = {
      step: "code",
      code: "",
      loanId: "",
      equipmentId: "",
      equipmentName: "",
      equipmentAssetId: "",
      studentName: "",
      message: "",
      error: false,
    };

    function resetNfcMachineState() {
      nfcMachineState = {
        step: "code",
        code: "",
        loanId: "",
        equipmentId: "",
        equipmentName: "",
        equipmentAssetId: "",
        studentName: "",
        message: "",
        error: false,
      };
    }

    function nfcMachinePage() {
      let stepContent;
      if (nfcMachineState.step === "scan") {
        const item = byId(nfcMachineState.equipmentId) || { name: nfcMachineState.equipmentName, assetId: nfcMachineState.equipmentAssetId };
        const loan = { studentName: nfcMachineState.studentName, studentId: nfcMachineState.studentId || "" };
        stepContent = nfcMachineStepScan(loan, item);
      } else if (nfcMachineState.step === "result") {
        stepContent = nfcMachineStepResult(nfcMachineState.resultSuccess, nfcMachineState.resultTitle, nfcMachineState.resultDesc);
      } else {
        stepContent = nfcMachineStepCode();
      }
      return `
        <section class="nfc-machine-screen">
          <header class="nfc-machine-header">
            <button class="icon-button" data-logout aria-label="退出" style="color:#fff;border-color:rgba(255,255,255,0.2);background:rgba(255,255,255,0.08);">${icon("logout")}</button>
            <h1>SportLoop</h1>
            <span class="nfc-machine-badge">NFC 验证机</span>
          </header>
          <div class="nfc-machine-body">
            ${stepContent}
          </div>
        </section>
      `;
    }

    function nfcMachineStepCode() {
      const msg = nfcMachineState.message
        ? `<p style="color:${nfcMachineState.error ? '#f87171' : 'rgba(255,255,255,0.55)'};font-size:14px;margin:0 0 20px;">${escapeHtml(nfcMachineState.message)}</p>`
        : "";
      return `
        <div class="nfc-machine-step">
          <h2>输入验证码</h2>
          <p class="nfc-machine-desc">学生在手机上发起借用后会得到一个 6 位验证码，请在此输入。</p>
          ${msg}
          <input class="nfc-machine-code-input" id="nfcMachineCodeInput" type="text" inputmode="numeric" maxlength="6" placeholder="000000" autofocus />
          <button class="nfc-machine-btn" id="nfcMachineCodeBtn">验证并继续</button>
        </div>
      `;
    }

    function nfcMachineStepScan(loan, item) {
      return `
        <div class="nfc-machine-step">
          <div class="nfc-machine-info-card">
            <p class="nfc-machine-equip-name">${escapeHtml(item.name)}</p>
            <p class="nfc-machine-equip-id">${escapeHtml(item.assetId)}</p>
            <p class="nfc-machine-student">${escapeHtml(loan.studentName || "学生")} · ${escapeHtml(loan.studentId || "")}</p>
          </div>
          <div class="nfc-machine-scan-visual" id="nfcMachineScanVisual">
            <span class="nfc-machine-wave"></span>
            <span class="nfc-machine-wave"></span>
            <span class="nfc-machine-wave"></span>
            <div class="nfc-machine-scan-core">${icon("scan")}</div>
          </div>
          <h2>请贴 NFC 标签</h2>
          <p class="nfc-machine-desc">将器材上的 NFC 标签贴到设备背面进行验证</p>
          <button class="nfc-machine-btn is-secondary" id="nfcMachineCancelScan">取消，重新输入验证码</button>
        </div>
      `;
    }

    function nfcMachineStepResult(success, title, desc) {
      const iconClass = success ? "is-success" : "is-error";
      const iconName = success ? "check" : "alert";
      return `
        <div class="nfc-machine-step">
          <div class="nfc-machine-result-icon ${iconClass}">${icon(iconName)}</div>
          <h2>${escapeHtml(title)}</h2>
          <p class="nfc-machine-desc">${escapeHtml(desc)}</p>
          ${success
            ? `<button class="nfc-machine-btn" id="nfcMachineNewCode">验证下一个</button>`
            : `<button class="nfc-machine-btn" id="nfcMachineRetry">重新验证</button>`
          }
        </div>
      `;
    }

    async function handleNfcMachineCodeSubmit() {
      const input = document.querySelector("#nfcMachineCodeInput");
      const code = String(input?.value || "").trim();
      if (code.length !== 6 || !/^\d{6}$/.test(code)) {
        nfcMachineState.message = "请输入 6 位数字验证码";
        nfcMachineState.error = true;
        renderNfcMachineStep();
        return;
      }

      nfcMachineState.code = code;
      nfcMachineState.message = "正在查找验证码...";
      nfcMachineState.error = false;
      renderNfcMachineStep();

      let loan;
      try {
        loan = await findLoanByVerificationCode(code);
      } catch (err) {
        nfcMachineState.message = "网络错误，请重试";
        nfcMachineState.error = true;
        renderNfcMachineStep();
        return;
      }

      if (!loan) {
        nfcMachineState.message = "验证码无效或已过期，请确认后重试";
        nfcMachineState.error = true;
        renderNfcMachineStep();
        return;
      }

      if (loan.status !== "等待NFC验证") {
        nfcMachineState.message = "该借用记录已处理过，无需重复验证";
        nfcMachineState.error = true;
        renderNfcMachineStep();
        return;
      }

      if (isVerificationCodeExpired(loan)) {
        nfcMachineState.message = "验证码已过期（超过 5 分钟），请重新发起借用";
        nfcMachineState.error = true;
        renderNfcMachineStep();
        return;
      }

      const item = byId(loan.equipmentId) || store.equipment.find((eq) => eq.id === loan.equipmentId);
      if (!item) {
        nfcMachineState.message = "未找到对应器材，请联系管理员";
        nfcMachineState.error = true;
        renderNfcMachineStep();
        return;
      }

      nfcMachineState.loanId = loan.id;
      nfcMachineState.equipmentId = item.id;
      nfcMachineState.equipmentName = item.name;
      nfcMachineState.equipmentAssetId = item.assetId;
      nfcMachineState.studentName = loan.studentName || "";
      nfcMachineState.step = "scan";
      nfcMachineState.message = "";
      renderNfcMachine();

      startNfcMachineScan(loan, item);
    }

    async function startNfcMachineScan(loan, item) {
      if (!supportsNfc()) {
        nfcMachineState.message = "此设备不支持 NFC";
        nfcMachineState.error = true;
        renderNfcMachineStep();
        return;
      }

      try {
        const { serialNumber } = await scanNfcTag(60000);
        if (!nfcTagMatchesEquipment(serialNumber, item)) {
          nfcMachineState.step = "result";
          nfcMachineState.resultSuccess = false;
          nfcMachineState.resultTitle = "标签不匹配";
          nfcMachineState.resultDesc = `此标签不属于「${item.name}」，请确认使用的是正确器材的标签。`;
          renderNfcMachine();
          return;
        }

        await completeNfcMachineVerification(loan.id, item.id, serialNumber);

        const localLoan = loanById(loan.id);
        if (localLoan) {
          localLoan.status = "待补借出照片";
          localLoan.nfcSerial = serialNumber;
          localLoan.nfcVerifiedAt = new Date().toISOString();
          saveStore();
        }

        nfcMachineState.step = "result";
        nfcMachineState.resultSuccess = true;
        nfcMachineState.resultTitle = "验证成功";
        nfcMachineState.resultDesc = `${item.name} NFC 验证通过，学生可在手机上上传借出前照片完成借用。`;
      } catch (err) {
        nfcMachineState.step = "result";
        nfcMachineState.resultSuccess = false;
        nfcMachineState.resultTitle = "扫描失败";
        nfcMachineState.resultDesc = err.message || "NFC 读取失败，请重试。";
      }
      renderNfcMachine();
    }

    function renderNfcMachine() {
      const app = document.querySelector("#app");
      if (!app) return;
      app.innerHTML = nfcMachinePage();
      bindNfcMachine();
    }

    function renderNfcMachineStep() {
      const app = document.querySelector("#app");
      if (!app) return;
      app.innerHTML = nfcMachinePage();
      bindNfcMachine();
    }

    function bindNfcMachine() {
      document.querySelectorAll("[data-logout]").forEach((node) => node.addEventListener("click", handleLogout));
      document.querySelectorAll("[data-back]").forEach((node) => node.addEventListener("click", () => {
        resetNfcMachineState();
        back();
      }));
      const codeBtn = document.querySelector("#nfcMachineCodeBtn");
      if (codeBtn) {
        codeBtn.addEventListener("click", handleNfcMachineCodeSubmit);
      }

      const codeInput = document.querySelector("#nfcMachineCodeInput");
      if (codeInput) {
        codeInput.addEventListener("keydown", (e) => {
          if (e.key === "Enter") handleNfcMachineCodeSubmit();
        });
        setTimeout(() => codeInput.focus(), 150);
      }

      const cancelBtn = document.querySelector("#nfcMachineCancelScan");
      if (cancelBtn) {
        cancelBtn.addEventListener("click", () => {
          resetNfcMachineState();
          renderNfcMachine();
        });
      }

      const newCodeBtn = document.querySelector("#nfcMachineNewCode");
      if (newCodeBtn) {
        newCodeBtn.addEventListener("click", () => {
          resetNfcMachineState();
          renderNfcMachine();
        });
      }

      const retryBtn = document.querySelector("#nfcMachineRetry");
      if (retryBtn) {
        retryBtn.addEventListener("click", () => {
          nfcMachineState.step = "code";
          nfcMachineState.code = "";
          nfcMachineState.message = "";
          nfcMachineState.error = false;
          renderNfcMachine();
        });
      }

      document.querySelectorAll("[data-route]").forEach((node) => {
        node.addEventListener("click", () => {
          resetNfcMachineState();
          if (node.dataset.route === "login") {
            clearAuthSession();
          }
          route(node.dataset.route);
        });
      });
    }

    function showNameEditor() {
      const overlay = document.createElement("div");
      overlay.className = "confirm-overlay";
      overlay.innerHTML = `
        <form class="confirm-dialog name-dialog">
          <h2>编辑昵称</h2>
          <input name="nickname" value="${escapeAttr(profileNickname())}" maxlength="12" required aria-label="昵称" placeholder="请输入昵称" />
          <div class="confirm-actions">
            <button class="btn-cancel" type="button">取消</button>
            <button class="btn-danger" type="submit">保存</button>
          </div>
        </form>
      `;
      const input = overlay.querySelector("input");
      overlay.querySelector(".btn-cancel").addEventListener("click", () => overlay.remove());
      overlay.querySelector("form").addEventListener("submit", (event) => {
        event.preventDefault();
        const nickname = input.value.trim();
        if (!nickname) {
          input.focus();
          return;
        }
        store.profile = { ...(store.profile || {}), nickname };
        saveStore();
        const profile = profileData();
        if (profile.realName && profile.studentId && profile.college && profile.authStatus === "已认证") {
          runRemote(() => upsertRemoteProfile(profile));
        }
        state.notice = "昵称已更新";
        overlay.remove();
        render();
      });
      overlay.addEventListener("click", (e) => {
        if (e.target === overlay) overlay.remove();
      });
      document.querySelector("#app").appendChild(overlay);
      window.setTimeout(() => {
        input.focus();
        input.select();
      }, 0);
    }

    function setIdentityStatus(message, isError = true) {
      const status = document.querySelector("#identityStatus");
      if (!status) return;
      status.textContent = message;
      status.classList.toggle("is-error", isError);
    }

    async function submitIdentityForm(event) {
      event.preventDefault();
      const form = event.currentTarget;
      const realName = normalizeIdentityText(form.realName.value);
      const studentId = normalizeStudentId(form.studentId.value);
      const college = normalizeIdentityText(form.college.value);
      if (!realName || !studentId || !college) {
        setIdentityStatus("姓名、学号和院系都要填写完整");
        return;
      }
      if (!/^[0-9A-Z]{6,18}$/.test(studentId)) {
        setIdentityStatus("学号格式不正确，请输入 6 到 18 位数字或字母");
        return;
      }

      const profileId = "current-student";
      const bindings = Array.isArray(store.identityBindings) ? store.identityBindings : [];
      const currentBinding = bindings.find((item) => item.profileId === profileId);
      const sameStudentId = bindings.find((item) => item.studentId === studentId && item.profileId !== profileId);
      if (sameStudentId) {
        setIdentityStatus("这个学号已经被其他身份绑定，不能重复认证");
        return;
      }
      if (currentBinding && currentBinding.studentId !== studentId) {
        setIdentityStatus("当前身份已经绑定过学号，不能重复换号");
        return;
      }

      const verifiedAt = currentBinding?.verifiedAt || nowText();
      const nextProfile = {
        ...profileData(),
        realName,
        studentId,
        college,
        authStatus: "已认证",
        campusRole: "学生",
        campusCard: "已绑定",
        verifiedAt,
      };
      try {
        await upsertRemoteProfile(nextProfile);
      } catch (error) {
        const message = String(error.message || "");
        setIdentityStatus(message.includes("duplicate") || message.includes("unique") ? "这个学号已经被绑定，不能重复认证" : message);
        return;
      }
      const record = { profileId, realName, studentId, college, verifiedAt };
      store.identityBindings = bindings.filter((item) => item.profileId !== profileId).concat(record);
      store.profile = nextProfile;
      saveStore();
      state.notice = "校园身份认证已保存";
      route("profileInfo");
    }

    function setContactStatus(message, isError = true) {
      const status = document.querySelector("#contactStatus");
      if (!status) return;
      status.textContent = message;
      status.classList.toggle("is-error", isError);
    }

    async function submitAdminContactForm(event) {
      event.preventDefault();
      const form = event.currentTarget;
      const profile = profileData();
      const textField = form.elements.message;
      const categoryField = form.elements.category;
      const text = String(textField.value || "").trim();
      const category = String(categoryField.value || "其他问题").trim();
      if (!text) {
        setContactStatus("留言内容不能为空");
        textField.focus();
        return;
      }

      const message = {
        id: makeUuid(),
        userId: state.currentUserId,
        senderProfileId: state.currentUserId,
        senderName: profile.realName || profileNickname(),
        studentId: profile.studentId,
        category,
        text,
        status: "待回复",
        createdAt: nowText(),
        reply: "",
        repliedAt: "",
      };
      try {
        await createRemoteAdminContact(message);
      } catch (error) {
        setContactStatus(error.message || "发送失败");
        return;
      }
      adminMessageList().unshift(message);
      pushMessage("已发送给管理员", "你的留言已同步到管理员端，管理员回复后会出现在消息和联系记录里。");
      saveStore();
      state.notice = "已发送给管理员";
      render();
    }

    async function replyAdminMessage(messageId, card) {
      const message = adminMessageList().find((item) => item.id === messageId);
      const textarea = card ? card.querySelector("textarea") : null;
      const reply = String(textarea?.value || "").trim();
      if (!message || !textarea) return;
      if (!reply) {
        textarea.focus();
        return;
      }

      message.reply = reply;
      message.status = "已回复";
      message.repliedAtMs = Date.now();
      message.repliedAt = nowText();
      try {
        await saveRemoteAdminContact(message);
        await supabaseRequest("student_messages", {
          method: "POST",
          body: { user_id: message.userId, title: "管理员已回复", body: reply },
        });
      } catch (error) {
        state.notice = error.message || "回复发送失败";
        render();
        return;
      }
      pushMessage("管理员已回复", reply);
      createAdminOperationLog("回复学生留言", "admin_contacts", message.id, `${message.senderName || "学生"} 的留言已回复`, {
        studentId: message.studentId,
        category: message.category,
      });
      saveStore();
      state.notice = "回复已发送给学生";
      render();
    }

    function activeLoanCountForEquipment(equipmentId) {
      return store.loans.filter((loan) =>
        loan.equipmentId === equipmentId && ["等待NFC验证", "待补借出照片", "使用中", "待归还", "异常待归还"].includes(loan.status)
      ).length;
    }

    function parseMachineInventoryText(rawText) {
      const lines = String(rawText || "").split(/\r?\n/).map((line) => line.trim()).filter(Boolean);
      if (!lines.length) throw new Error("请先粘贴机器导出的库存清单");
      const seenTags = new Map();
      const duplicateTags = [];
      const groups = new Map();

      lines.forEach((line, index) => {
        const parts = line.split(/[,，\t]/).map((part) => normalizeIdentityText(part));
        if (parts.length < 5) throw new Error(`第 ${index + 1} 行格式不完整`);
        const assetId = parts[0].toUpperCase();
        const name = parts[1];
        const category = parts[2];
        const venue = parts[3];
        const tagId = parts[4].toUpperCase();
        if (!assetId || !name || !category || !venue || !tagId) throw new Error(`第 ${index + 1} 行有空字段`);
        if (seenTags.has(tagId)) {
          duplicateTags.push(tagId);
          return;
        }
        seenTags.set(tagId, assetId);

        const existing = groups.get(assetId);
        if (existing) {
          if (existing.name !== name || existing.category !== category || existing.venue !== venue) {
            throw new Error(`${assetId} 的名称、分类或场馆不一致`);
          }
          existing.nfcTags.push(tagId);
          return;
        }

        groups.set(assetId, { assetId, name, category, venue, nfcTags: [tagId] });
      });

      return { groups: [...groups.values()], inputCount: lines.length, duplicateTags };
    }

    function currentNfcTagIndex() {
      const index = new Map();
      store.equipment.forEach((item) => {
        (Array.isArray(item.nfcTags) ? item.nfcTags : []).forEach((tag) => {
          index.set(String(tag).toUpperCase(), item.assetId);
        });
      });
      return index;
    }

    function machineInventoryItemsFromGroups(groups) {
      const syncedAt = new Date().toISOString();
      const tagIndex = currentNfcTagIndex();
      let addedChipCount = 0;
      let duplicateCount = 0;
      const duplicateTags = [];
      const items = groups.map((group) => {
        const current = store.equipment.find((item) => item.assetId === group.assetId);
        const currentTags = new Set((Array.isArray(current?.nfcTags) ? current.nfcTags : []).map((tag) => String(tag).toUpperCase()));
        const newTags = [];
        group.nfcTags.forEach((tag) => {
          const tagId = String(tag).toUpperCase();
          const boundAsset = tagIndex.get(tagId);
          if (boundAsset && boundAsset !== group.assetId) throw new Error(`芯片号 ${tagId} 已绑定到 ${boundAsset}`);
          if (currentTags.has(tagId)) {
            duplicateCount += 1;
            duplicateTags.push(tagId);
            return;
          }
          currentTags.add(tagId);
          newTags.push(tagId);
          addedChipCount += 1;
        });
        const available = current ? Number(current.available || 0) + newTags.length : newTags.length;
        const total = current ? Number(current.total || 0) + newTags.length : newTags.length;
        if (!newTags.length && current) return null;
        return {
          id: current?.id || `eq-${makeUuid()}`,
          assetId: group.assetId,
          name: group.name,
          category: group.category,
          image: current?.image || "",
          total,
          available,
          status: available > 0 ? "可借" : "补充中",
          health: current?.health ?? 100,
          venue: group.venue,
          desc: current?.desc || "NFC 机器入库同步器材库存。",
          nfcTags: [...currentTags],
          machineSyncedAt: syncedAt,
        };
      }).filter((item) => item && item.total > 0);
      return { items, addedChipCount, duplicateCount, duplicateTags, syncedAt };
    }

    function handleAdminVenueAdd(event) {
      event.preventDefault();
      const input = document.querySelector("#adminVenueInput");
      const name = (input ? input.value : "").trim();
      if (!name) { state.notice = "请输入场馆名称"; render(); return; }
      if (!Array.isArray(store.venues)) store.venues = [];
      if (store.venues.some((v) => v.name === name)) { state.notice = "场馆已存在"; render(); return; }
      const maxId = store.venues.reduce((max, v) => Math.max(max, Number(v.id.replace(/\D/g, "")) || 0), 0);
      store.venues.push({ id: "v" + String(maxId + 1), name, open: true });
      saveStore();
      state.notice = "已添加场馆：" + name;
      render();
    }

    function handleAdminVenueToggle(venueId) {
      const venue = (store.venues || []).find((v) => v.id === venueId);
      if (!venue) return;
      venue.open = !venue.open;
      saveStore();
      state.notice = venue.open ? "已开放：" + venue.name : "已关闭：" + venue.name;
      render();
    }

    function handleAdminVenueAdd(event) {
      event.preventDefault();
      const input = document.querySelector("#adminVenueInput");
      const name = (input ? input.value : "").trim();
      if (!name) { state.notice = "请输入场馆名称"; render(); return; }
      if (!Array.isArray(store.venues)) store.venues = [];
      if (store.venues.some((v) => v.name === name)) { state.notice = "场馆已存在"; render(); return; }
      const maxId = store.venues.reduce((max, v) => Math.max(max, Number(v.id.replace(/\D/g, "")) || 0), 0);
      store.venues.push({ id: "v" + String(maxId + 1), name, open: true });
      saveStore();
      state.notice = "已添加场馆：" + name;
      render();
    }

    function handleAdminVenueToggle(venueId) {
      const venue = (store.venues || []).find((v) => v.id === venueId);
      if (!venue) return;
      venue.open = !venue.open;
      saveStore();
      state.notice = venue.open ? "已开放：" + venue.name : "已关闭：" + venue.name;
      render();
    }

    async function handleAdminNfcScan(event) {
      event.preventDefault();
      const select = document.querySelector("#adminNfcEquipment");
      const statusEl = document.querySelector("#adminNfcStatus");
      const resultEl = document.querySelector("#adminNfcResult");
      const btn = document.querySelector("#adminNfcScanBtn");
      const equipmentId = select?.value;
      const item = byId(equipmentId);
      if (!item) {
        if (resultEl) resultEl.textContent = "未找到对应器材";
        return;
      }

      if (!supportsNfc()) {
        if (resultEl) resultEl.textContent = "此设备不支持 NFC，请用安卓手机 + Chrome 浏览器";
        return;
      }

      if (btn) btn.disabled = true;
      if (statusEl) statusEl.textContent = "扫描中...";
      if (resultEl) resultEl.textContent = "请将 NFC 标签贴到设备背面";

      try {
        const { serialNumber } = await scanNfcTag(30000);
        const tagId = normalizeNfcSerial(serialNumber);

        const existingIndex = new Map();
        store.equipment.forEach((eq) => {
          (Array.isArray(eq.nfcTags) ? eq.nfcTags : []).forEach((tag) => {
            existingIndex.set(normalizeNfcSerial(tag), eq.id);
          });
        });

        if (existingIndex.has(tagId)) {
          const boundEq = byId(existingIndex.get(tagId));
          if (resultEl) resultEl.textContent = `该标签已绑定到「${boundEq ? boundEq.name : "其他器材"}」，不能重复录入`;
          if (statusEl) statusEl.textContent = "重复";
          return;
        }

        if (!Array.isArray(item.nfcTags)) item.nfcTags = [];
        item.nfcTags.push(tagId);
        item.total += 1;
        item.available += 1;
        item.status = item.available > 0 ? "可借" : "补充中";

        await updateRemoteEquipment(item);
        saveStore();
        createAdminOperationLog("NFC录入器材", "equipment", item.id, `${item.name} 新增 NFC 标签 ${tagId}，库存 +1`);
        if (statusEl) statusEl.textContent = "成功";
        if (resultEl) resultEl.textContent = `${item.name} 已录入 · UID: ${tagId} · 当前库存 ${item.available}/${item.total}`;
      } catch (err) {
        if (statusEl) statusEl.textContent = "失败";
        if (resultEl) resultEl.textContent = err.message || "NFC 扫描失败";
      } finally {
        if (btn) btn.disabled = false;
        render();
      }
    }

    async function handleAdminDeleteTag(equipmentId, tagValue) {
      const item = byId(equipmentId);
      if (!item) return;
      const tags = Array.isArray(item.nfcTags) ? item.nfcTags : [];
      const idx = tags.findIndex((tag) => String(tag) === String(tagValue));
      if (idx < 0) return;
      tags.splice(idx, 1);
      item.nfcTags = tags;
      item.total = Math.max(0, item.total - 1);
      item.available = Math.max(0, Math.min(item.available, item.total));
      if (item.total === 0) item.status = "补充中";
      try {
        await updateRemoteEquipment(item);
        createAdminOperationLog("删除NFC标签", "equipment", item.id, `${item.name} 删除 NFC 标签 ${tagValue}`);
        saveStore();
        state.notice = "NFC 标签已删除";
      } catch (err) {
        item.total += 1;
        item.available += 1;
        tags.push(tagValue);
        state.notice = err.message || "删除失败";
      }
      render();
    }

    }

    function csvCell(value) {
      const text = String(value ?? "").replace(/\r?\n/g, " ");
      return /[",，\n]/.test(text) ? `"${text.replace(/"/g, '""')}"` : text;
    }

    function rowsToCsv(rows) {
      if (!rows.length) return "";
      const keys = Object.keys(rows[0]);
      return [
        keys.map(csvCell).join(","),
        ...rows.map((row) => keys.map((key) => csvCell(row[key])).join(",")),
      ].join("\n");
    }

    function downloadTextFile(filename, content, type = "text/csv;charset=utf-8") {
      const blob = new Blob(["\ufeff", content], { type });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.href = url;
      link.download = filename;
      document.body.appendChild(link);
      link.click();
      link.remove();
      URL.revokeObjectURL(url);
    }

    function exportAdminData(kind) {
      const stamp = new Date().toISOString().slice(0, 10);
      const datasets = {
        equipment: {
          filename: `sportloop-equipment-${stamp}.csv`,
          label: "库存",
          rows: store.equipment.map((item) => ({
            器材编号: item.assetId,
            名称: item.name,
            分类: item.category,
            场馆: item.venue,
            总量: item.total,
            可借: item.available,
            状态: item.status,
            芯片数: Array.isArray(item.nfcTags) ? item.nfcTags.length : 0,
            最近同步: item.machineSyncedAt || "",
          })),
        },
        sync: {
          filename: `sportloop-machine-sync-${stamp}.csv`,
          label: "机器同步记录",
          rows: machineSyncLogList().map((log) => ({
            时间: log.createdAt,
            类型: log.mode,
            摘要: log.summary,
            器材类数: log.itemCount,
            新增芯片: log.chipCount,
            重复芯片: log.duplicateCount,
            失败: log.failedCount,
          })),
        },
        logs: {
          filename: `sportloop-admin-logs-${stamp}.csv`,
          label: "操作记录",
          rows: adminOperationLogList().map((log) => ({
            时间: log.createdAt,
            动作: log.action,
            对象类型: log.targetType,
            对象ID: log.targetId,
            摘要: log.summary,
          })),
        },
      };
      const data = datasets[kind];
      if (!data) return;
      const rows = data.rows.length ? data.rows : [{ 提示: `暂无${data.label}` }];
      downloadTextFile(data.filename, rowsToCsv(rows));
      createAdminOperationLog("导出数据", "export", kind, `已导出${data.label}`, { rows: data.rows.length });
      state.notice = `${data.label}已导出`;
      render();
    }

    function setAdminFanIndex(index) {
      const max = adminModuleCards(adminDashboardData()).length - 1;
      state.adminFanIndex = Math.max(0, Math.min(max, Number(index) || 0));
      updateAdminFanView(0, false);
    }

    function shiftAdminFan(step) {
      setAdminFanIndex((Number(state.adminFanIndex) || 0) + step);
    }

    function updateAdminFanView(progress = 0, dragging = false) {
      const stage = document.querySelector("[data-admin-fan-stage]");
      const cards = Array.from(document.querySelectorAll("[data-admin-fan-index]"));
      if (!stage || !cards.length) return;
      const activeIndex = adminFanActiveIndex(cards.length);
      const width = stage.clientWidth || adminFanFallbackWidth();
      state.adminFanIndex = activeIndex;
      stage.classList.toggle("is-dragging", dragging);
      cards.forEach((card) => {
        const index = Number(card.dataset.adminFanIndex);
        if (!Number.isInteger(index)) return;
        const view = adminFanCardView(index, activeIndex, progress, width);
        card.classList.toggle("is-active", view.isActive);
        card.classList.toggle("is-hidden", view.isHidden);
        card.style.setProperty("--fan-x", view.fanX);
        card.style.setProperty("--fan-y", view.fanY);
        card.style.setProperty("--fan-rotate", view.fanRotate);
        card.style.setProperty("--fan-z", view.fanZ);
        card.style.setProperty("--fan-scale", view.fanScale);
        card.style.setProperty("--fan-opacity", view.fanOpacity);
        card.style.setProperty("--fan-pointer", view.fanPointer);
        const hint = card.querySelector("[data-admin-fan-hint]");
        if (hint) hint.textContent = view.isActive ? "点击进入" : "";
      });
    }

    function handleAdminFanDrag(stage, deltaX) {
      const distance = adminFanSwipeDistance(stage);
      const progress = Math.max(-1.15, Math.min(1.15, deltaX / distance));
      updateAdminFanView(progress, true);
    }

    function finishAdminFanDrag(stage, deltaX, moved) {
      const distance = adminFanSwipeDistance(stage);
      const threshold = Math.max(38, distance * 0.34);
      const didSwitch = moved && Math.abs(deltaX) >= threshold;
      if (didSwitch) {
        shiftAdminFan(deltaX < 0 ? 1 : -1);
      } else {
        updateAdminFanView(0, false);
      }
      if (!didSwitch) {
        state.adminFanSuppressClick = false;
        state.adminFanSuppressUntil = 0;
        return false;
      }
      const now = Date.now();
      state.adminFanLastSwipeAt = now;
      state.adminFanSuppressClick = true;
      state.adminFanSuppressUntil = now + 90;
      window.setTimeout(() => {
        state.adminFanSuppressClick = false;
        state.adminFanSuppressUntil = 0;
      }, 100);
      return true;
    }

    function bind() {
      if (state.route === "nfcMachine") {
        bindNfcMachine();
        return;
      }
      document.querySelectorAll("[data-route]").forEach((node) => node.addEventListener("click", () => route(node.dataset.route)));
      document.querySelectorAll("[data-back]").forEach((node) => node.addEventListener("click", back));
      document.querySelectorAll("[data-logout]").forEach((node) => node.addEventListener("click", handleLogout));
      document.querySelectorAll("[data-detail]").forEach((node) => node.addEventListener("click", () => route("detail", { id: node.dataset.detail })));
      document.querySelectorAll("[data-edit-profile-name]").forEach((node) => node.addEventListener("click", showNameEditor));
      const identityForm = document.querySelector("#identityForm");
      if (identityForm) identityForm.addEventListener("submit", submitIdentityForm);
      const adminContactForm = document.querySelector("#adminContactForm");
      if (adminContactForm) adminContactForm.addEventListener("submit", submitAdminContactForm);
      const adminNfcScanForm = document.querySelector("#adminNfcScanForm");
      if (adminNfcScanForm) adminNfcScanForm.addEventListener("submit", handleAdminNfcScan);
      const adminVenueForm = document.querySelector("#adminVenueForm");
      if (adminVenueForm) adminVenueForm.addEventListener("submit", handleAdminVenueAdd);
      document.querySelectorAll("[data-admin-venue-toggle]").forEach((node) =>
        node.addEventListener("click", () => handleAdminVenueToggle(node.dataset.adminVenueToggle))
      );
      document.querySelectorAll("[data-admin-delete-tag]").forEach((node) =>
        node.addEventListener("click", () => handleAdminDeleteTag(node.dataset.adminDeleteTag, node.dataset.tagValue))
      );
      document.querySelectorAll("[data-admin-export]").forEach((node) =>
        node.addEventListener("click", () => exportAdminData(node.dataset.adminExport))
      );
      document.querySelectorAll("[data-admin-route]").forEach((node) =>
        node.addEventListener("click", () => {
          if (state.adminFanSuppressClick) {
            const shouldSuppress = Date.now() <= (Number(state.adminFanSuppressUntil) || 0);
            state.adminFanSuppressClick = false;
            state.adminFanSuppressUntil = 0;
            if (shouldSuppress) return;
          }
          route(node.dataset.adminRoute);
        })
      );
      const adminFanStage = document.querySelector("[data-admin-fan-stage]");
      if (adminFanStage) {
        updateAdminFanView(0, false);
        let startX = 0;
        let startY = 0;
        let currentDeltaX = 0;
        let fanDragging = false;
        let fanGestureActive = false;
        let activePointerId = 0;
        const startFanGesture = (x, y) => {
          startX = x;
          startY = y;
          currentDeltaX = 0;
          fanDragging = false;
          fanGestureActive = true;
        };
        const moveFanGesture = (x, y, event) => {
          if (!fanGestureActive) return;
          const deltaX = x - startX;
          const deltaY = y - startY;
          const isHorizontal = Math.abs(deltaX) > 8 && Math.abs(deltaX) > Math.abs(deltaY);
          if (!isHorizontal && !fanDragging) return;
          if (!fanDragging && Number.isFinite(Number(event?.pointerId))) {
            adminFanStage.setPointerCapture?.(event.pointerId);
          }
          fanDragging = true;
          currentDeltaX = deltaX;
          if (event?.cancelable) event.preventDefault();
          handleAdminFanDrag(adminFanStage, currentDeltaX);
        };
        const endFanGesture = (x) => {
          if (!fanGestureActive) return;
          const deltaX = Number.isFinite(x) ? x - startX : currentDeltaX;
          fanGestureActive = false;
          finishAdminFanDrag(adminFanStage, deltaX, fanDragging || Math.abs(deltaX) > 12);
        };
        if (window.PointerEvent) {
          adminFanStage.addEventListener("pointerdown", (event) => {
            if (event.pointerType === "mouse" && event.button !== 0) return;
            activePointerId = event.pointerId;
            startFanGesture(event.clientX, event.clientY);
          });
          adminFanStage.addEventListener("pointermove", (event) => {
            moveFanGesture(event.clientX, event.clientY, event);
          });
          adminFanStage.addEventListener("pointerup", (event) => {
            endFanGesture(event.clientX);
            if (adminFanStage.hasPointerCapture?.(event.pointerId)) {
              adminFanStage.releasePointerCapture?.(event.pointerId);
            }
            activePointerId = 0;
          });
          adminFanStage.addEventListener("pointercancel", () => {
            fanGestureActive = false;
            if (activePointerId && adminFanStage.hasPointerCapture?.(activePointerId)) {
              adminFanStage.releasePointerCapture?.(activePointerId);
            }
            activePointerId = 0;
            updateAdminFanView(0, false);
          });
        } else {
          adminFanStage.addEventListener("touchstart", (event) => {
            const touch = event.changedTouches[0];
            if (touch) startFanGesture(touch.clientX, touch.clientY);
          }, { passive: true });
          adminFanStage.addEventListener("touchmove", (event) => {
            const touch = event.changedTouches[0];
            if (touch) moveFanGesture(touch.clientX, touch.clientY, event);
          }, { passive: false });
          adminFanStage.addEventListener("touchend", (event) => {
            endFanGesture(event.changedTouches[0]?.clientX);
          });
          adminFanStage.addEventListener("touchcancel", () => {
            fanGestureActive = false;
            updateAdminFanView(0, false);
          });
        }
      }
      const batchBorrowForm = document.querySelector("#batchBorrowForm");
      if (batchBorrowForm) batchBorrowForm.addEventListener("submit", submitBatchBorrowRequest);
      document.querySelectorAll("[data-sync-borrow]").forEach((node) => node.addEventListener("click", () => {
        if (node.disabled) return;
        const itemId = node.dataset.syncBorrow || state.selectedId;
        const item = byId(itemId);
        if (!item) return;
        showConfirm("确认借用「" + item.name + "」？本次时长为 " + borrowDurationLabel() + "。\n\n确认后将生成验证码，请前往场馆 NFC 机器完成验证。", () => {
          const result = syncBorrowFromMachine(itemId, { skipNavigate: true });
          if (!result) {
            render();
            return;
          }
          state.activeLoanId = result.id;
          route("borrowConfirm", { loanId: result.id });
        });
      }));
      document.querySelectorAll("[data-cancel-borrow]").forEach((node) => node.addEventListener("click", () => {
        const loan = loanById(node.dataset.cancelBorrow);
        if (!loan) return;
        const item = byId(loan.equipmentId);
        showConfirm(`确定取消「${item ? item.name : "器材"}」的借用申请吗？`, () => {
          cancelPendingBorrow(node.dataset.cancelBorrow);
        }, "确认取消");
      }));
      document.querySelectorAll("[data-view-code]").forEach((node) => node.addEventListener("click", () => {
        state.activeLoanId = node.dataset.viewCode;
        route("borrowConfirm", { loanId: node.dataset.viewCode });
      }));
      document.querySelectorAll("[data-sync-return]").forEach((node) => node.addEventListener("click", () => {
        route("scanBorrow", { loanId: node.dataset.syncReturn, syncContext: "return" });
      }));
      document.querySelectorAll("[data-batch-sync-borrow]").forEach((node) => node.addEventListener("click", () => {
        const request = batchRequestById(node.dataset.batchSyncBorrow);
        if (!request) return;
        showConfirm(`确认已在场馆机器完成 ${batchRequestItemCount(request)} 件器材的批量借出？`, () => {
          syncBatchBorrowFromMachine(request.id);
        });
      }));
      document.querySelectorAll("[data-batch-sync-return]").forEach((node) => node.addEventListener("click", () => {
        const request = batchRequestById(node.dataset.batchSyncReturn);
        if (!request) return;
        showConfirm(`确认已在场馆机器完成 ${batchRequestItemCount(request)} 件器材的批量归还？`, () => {
          syncBatchReturnFromMachine(request.id);
        });
      }));
      document.querySelectorAll("[data-borrow-periods]").forEach((node) => node.addEventListener("click", () => {
        state.borrowPeriods = Number(node.dataset.borrowPeriods) || 1;
        render();
      }));

      if (state.route === "scanBorrow" && state.scanPhase === "scanning") {
        clearScanTimers();
        const isReturn = state.syncContext === "return";
        window.__scanTimer = window.setTimeout(() => {
          const result = isReturn
            ? syncReturnFromMachine(state.activeLoanId, { skipNavigate: true })
            : syncBorrowFromMachine(state.selectedId, { skipNavigate: true });
          if (!result) {
            state.scanPhase = "idle";
            route(isReturn ? "borrow" : "detail");
            return;
          }
          if (!isReturn) state.activeLoanId = result.id;
          state.scanPhase = "success";
          render();
          window.__scanSuccessTimer = window.setTimeout(() => {
            state.scanPhase = "idle";
            if (isReturn) {
              route("borrow");
            } else {
              route("borrowConfirm", { loanId: result.id });
              state.previous = "home";
            }
          }, 1400);
        }, 2600);
      }

      const pollingLoan = state.route === "borrowConfirm" ? loanById(state.activeLoanId) : null;
      if ((state.route === "borrow" && (pendingNfcLoans().length > 0 || store.loans.some((loan) => loan.status === "待补借出照片" && !loan.beforePhotoDataUrl)))
          || (state.route === "borrowConfirm" && pollingLoan && pollingLoan.status === "等待NFC验证")) {
        window.clearTimeout(window.__borrowPollTimer);
        window.__borrowPollTimer = window.setTimeout(async () => {
          try { await refreshRemoteStore(); } catch (_) { /* ignore */ }
          if (state.route === "borrow") {
            const justVerified = store.loans.find((loan) => loan.status === "待补借出照片" && !loan.beforePhotoDataUrl);
            if (justVerified) {
              route("borrowConfirm", { loanId: justVerified.id });
            } else {
              render();
            }
          }
          if (state.route === "borrowConfirm") {
            const current = loanById(state.activeLoanId);
            if (current && current.status !== "等待NFC验证") {
              render();
            } else if (!current) {
              route("borrow");
            }
          }
        }, 5000);
      }

      document.querySelectorAll("[data-category]").forEach((node) => node.addEventListener("click", () => { state.category = node.dataset.category; render(); }));
      document.querySelectorAll("[data-loan-detect]").forEach((node) => node.addEventListener("click", () => route("detect", { loanId: node.dataset.loanDetect })));
      document.querySelectorAll("[data-borrow-confirm]").forEach((node) => node.addEventListener("click", () => route("borrowConfirm", { loanId: node.dataset.borrowConfirm })));
      document.querySelectorAll("[data-result-loan]").forEach((node) => node.addEventListener("click", () => route("result", { loanId: node.dataset.resultLoan })));
      document.querySelectorAll("[data-report-loan]").forEach((node) => node.addEventListener("click", () => route("report", { loanId: node.dataset.reportLoan })));
      document.querySelectorAll("[data-renew-loan]").forEach((node) => node.addEventListener("click", () => {
        if (node.disabled) return;
        route("renewDetail", { loanId: node.dataset.renewLoan });
      }));
      document.querySelectorAll("[data-submit-renew]").forEach((node) => node.addEventListener("click", () => {
        if (node.disabled) return;
        submitRenewLoan(node.dataset.submitRenew);
      }));
      document.querySelectorAll("[data-save-borrow-before]").forEach((node) => node.addEventListener("click", () => {
        if (node.disabled) return;
        finishBorrowWithBeforePhoto(node.dataset.saveBorrowBefore);
      }));
      document.querySelectorAll("[data-ai-detect]").forEach((node) => node.addEventListener("click", () => runAiDetection(node.dataset.aiDetect)));
      document.querySelectorAll("[data-admin-pause]").forEach((node) => node.addEventListener("click", () => updateOrder(node.dataset.adminPause, "暂停借出")));
      document.querySelectorAll("[data-admin-repair]").forEach((node) => node.addEventListener("click", () => updateOrder(node.dataset.adminRepair, "维修中")));
      document.querySelectorAll("[data-admin-complete]").forEach((node) => node.addEventListener("click", () => updateOrder(node.dataset.adminComplete, "已完成")));
      document.querySelectorAll("[data-admin-reply]").forEach((node) => node.addEventListener("click", () => replyAdminMessage(node.dataset.adminReply, node.closest(".admin-contact-card"))));
      document.querySelectorAll("[data-admin-batch-approve]").forEach((node) => node.addEventListener("click", () => approveBatchRequest(node.dataset.adminBatchApprove, true)));
      document.querySelectorAll("[data-admin-batch-reject]").forEach((node) => node.addEventListener("click", () => approveBatchRequest(node.dataset.adminBatchReject, false)));

      // 清除缓存数据重置
      const resetBtn = document.querySelector("[data-reset]");
      if (resetBtn) {
        resetBtn.addEventListener("click", () => {
          showConfirm("确定要清除所有缓存数据吗？此操作不可撤销。", () => {
            localStorage.removeItem(STORAGE_KEY);
            clearAuthSession();
            store = clone(seed);
            saveStore();
            state.notice = "已清空数据并完成系统重置！";
            route("home");
          }, "确认清除");
        });
      }

      // 搜索框焦点事件优化
      const searchInput = document.querySelector("#searchInput");
      if (searchInput) {
        searchInput.addEventListener("input", (event) => {
          state.query = event.target.value.trim();
          render();
          const next = document.querySelector("#searchInput");
          next?.focus();
          next?.setSelectionRange(next.value.length, next.value.length);
        });
      }

      // 借出前照片上传事件
      const borrowBeforePhotoInput = document.querySelector("#borrowBeforePhotoInput");
      if (borrowBeforePhotoInput) {
        borrowBeforePhotoInput.addEventListener("change", (e) => {
          if (e.target.files && e.target.files[0]) {
            document.querySelector("#borrowBeforePhotoName").innerText = "已选择借出前照片：" + e.target.files[0].name;
          }
        });
      }
      const photoInput = document.querySelector("#photoInput");
      if (photoInput) {
        photoInput.addEventListener("change", (e) => {
          if (e.target.files && e.target.files[0]) {
            document.querySelector("#photoName").innerText = "已选择归还照片：" + e.target.files[0].name;
          }
        });
      }

      // 报修表单 — 器材切换时联动更新问题类型
      const reportEquip = document.querySelector("#reportEquipment");
      if (reportEquip) {
        reportEquip.addEventListener("change", () => {
          const typeSelect = document.querySelector("#reportType");
          if (typeSelect) typeSelect.innerHTML = issueOptionsFor(reportEquip.value);
        });
      }

      // 报修表单提交拦截处理
      const reportForm = document.querySelector("#reportForm");
      if (reportForm) {
        reportForm.addEventListener("submit", (e) => {
          e.preventDefault();
          const eqId = document.querySelector("#reportEquipment").value;
          const repType = document.querySelector("#reportType").value;
          const repDesc = document.querySelector("#reportDesc").value;
          createOrder(eqId, "手机端自主报备", repType + " (" + repDesc + ")");
          state.notice = "故障工单已同步到管理员端！";
          route("home");
        });
      }
    }

    // ==================== 4. 电脑大屏说明面板侧交互 ====================
    document.querySelector("#btnAdminAccess").addEventListener("click", () => {
      route("admin");
    });

    document.querySelector("#btnClearCache").addEventListener("click", () => {
      showConfirm("确定要清除所有缓存数据吗？此操作不可撤销。", () => {
        localStorage.removeItem(STORAGE_KEY);
        clearAuthSession();
        store = clone(seed);
        saveStore();
        state.notice = "数据已重置！";
        route("home");
      }, "确认清除");
    });

    async function initApp() {
      if (authSession?.accessToken) {
        if (store.authUserId !== authSession.userId || isSeedDemoProfile(store.profile)) resetAccountScopedStore(authSession.userId);
        try {
          await loadRemoteStore();
        } catch (error) {
          reportRemoteSyncError(error);
        }
      }
      render();
    }

    // 首次进入渲染
    window.onload = function() {
      initApp();
    };
  </script>
</body>
</html>
