    function blankStudentProfile() {
      return {
        nickname: "",
        realName: "",
        studentId: "",
        authStatus: "未认证",
        college: "",
        campusRole: "学生",
        campusCard: "未绑定",
        credit: "合格",
      };
    }

    function emptyRemoteProfile() {
      return blankStudentProfile();
    }

    function isSeedDemoProfile(profile = {}) {
      return profile.nickname === seed.profile.nickname
        && profile.realName === seed.profile.realName
        && profile.studentId === seed.profile.studentId
        && profile.authStatus === seed.profile.authStatus
        && profile.college === seed.profile.college;
    }

    function resetAccountScopedStore(userId) {
      store.authUserId = userId || "";
      store.profile = emptyRemoteProfile();
      store.equipment = [];
      store.loans = [];
      store.batchRequests = [];
      store.workOrders = [];
      store.identityBindings = [];
      store.adminMessages = [];
      store.machineSyncLogs = [];
      store.adminOperationLogs = [];
      store.messages = [];
      saveStore();
    }

    function dbLoanToLocal(row) {
      const borrowedAtMs = Date.parse(row.borrowed_at || "");
      const dueAtMs = Date.parse(row.due_at || "");
      const returnedAtMs = row.returned_at ? Date.parse(row.returned_at) : null;
      return {
        id: row.id,
        equipmentId: row.equipment_id,
        borrowedAt: Number.isFinite(borrowedAtMs) ? formatDateTime(borrowedAtMs) : "",
        borrowedAtMs,
        dueAt: Number.isFinite(dueAtMs) ? formatDueTime(dueAtMs) : "",
        dueAtMs,
        durationPeriods: row.duration_periods,
        durationMinutes: row.duration_minutes,
        durationLabel: durationLabelFromMinutes(row.duration_periods, row.duration_minutes),
        status: row.status,
        detectResult: row.detect_result || "",
        beforePhotoDataUrl: row.before_photo_data_url || "",
        returnPhotoDataUrl: row.return_photo_data_url || "",
        returnMachineAllowed: Boolean(row.return_machine_allowed),
        returnedAt: row.returned_at ? dbTimeText(row.returned_at) : "",
        returnedAtMs,
        returnedOnTime: row.returned_on_time,
        renewedTimes: row.renewed_times || 0,
        renewalRecords: row.renewal_records || [],
        batchRequestId: row.batch_request_id || "",
        nfcSerial: row.nfc_serial || "",
        nfcVerifiedAt: row.nfc_verified_at || "",
        verificationCode: row.verification_code || "",
        verificationCodeExpiresAt: row.verification_code_expires_at || "",
        studentName: row.student_name || "",
        studentId: row.student_id || "",
      };
    }

    function jsonArrayValue(value) {
      if (Array.isArray(value)) return value;
      if (typeof value === "string") {
        try {
          const parsed = JSON.parse(value);
          return Array.isArray(parsed) ? parsed : [];
        } catch {
          return [];
        }
      }
      return [];
    }

    function dbBatchRequestToLocal(row) {
      const borrowedAtMs = row.borrowed_at ? Date.parse(row.borrowed_at) : null;
      const returnedAtMs = row.returned_at ? Date.parse(row.returned_at) : null;
      return {
        id: row.id,
        userId: row.user_id,
        studentName: row.student_name || "",
        studentId: row.student_id || "",
        items: jsonArrayValue(row.items),
        durationPeriods: Number(row.duration_periods) || 1,
        durationMinutes: Number(row.duration_minutes) || CLASS_PERIOD_MINUTES,
        durationLabel: durationLabelFromMinutes(row.duration_periods, row.duration_minutes),
        status: row.status || "待审核",
        adminNote: row.admin_note || "",
        createdAt: dbTimeText(row.created_at),
        borrowedAt: row.borrowed_at ? dbTimeText(row.borrowed_at) : "",
        borrowedAtMs,
        returnedAt: row.returned_at ? dbTimeText(row.returned_at) : "",
        returnedAtMs,
      };
    }

    function dbMessageToLocal(row) {
      return {
        id: row.id,
        title: row.title,
        text: row.body,
        time: dbTimeText(row.created_at),
      };
    }

    function dbContactToLocal(row) {
      return {
        id: row.id,
        userId: row.user_id,
        senderProfileId: row.user_id,
        senderName: row.sender_name,
        studentId: row.student_id,
        category: row.category,
        text: row.body,
        status: row.status,
        createdAt: dbTimeText(row.created_at),
        reply: row.reply || "",
        repliedAt: row.replied_at ? dbTimeText(row.replied_at) : "",
      };
    }

    function dbWorkOrderToLocal(row) {
      return {
        id: row.id,
        userId: row.user_id,
        equipmentId: row.equipment_id,
        loanId: row.loan_id || "",
        title: row.title,
        source: row.source,
        status: row.status,
        createdAt: dbTimeText(row.created_at),
        restored: !!row.restored,
      };
    }

    function jsonObjectValue(value) {
      if (value && typeof value === "object" && !Array.isArray(value)) return value;
      if (typeof value === "string") {
        try {
          const parsed = JSON.parse(value);
          return parsed && typeof parsed === "object" && !Array.isArray(parsed) ? parsed : {};
        } catch {
          return {};
        }
      }
      return {};
    }

    function dbMachineSyncLogToLocal(row) {
      const createdAtMs = Date.parse(row.created_at || "");
      return {
        id: row.id,
        operatorId: row.operator_id || "",
        mode: row.mode || "入库同步",
        itemCount: Number(row.item_count) || 0,
        chipCount: Number(row.chip_count) || 0,
        duplicateCount: Number(row.duplicate_count) || 0,
        failedCount: Number(row.failed_count) || 0,
        summary: row.summary || "",
        details: jsonObjectValue(row.details),
        createdAt: dbTimeText(row.created_at),
        createdAtMs: Number.isFinite(createdAtMs) ? createdAtMs : 0,
      };
    }

    function dbAdminOperationLogToLocal(row) {
      const createdAtMs = Date.parse(row.created_at || "");
      return {
        id: row.id,
        operatorId: row.operator_id || "",
        action: row.action || "",
        targetType: row.target_type || "",
        targetId: row.target_id || "",
        summary: row.summary || "",
        details: jsonObjectValue(row.details),
        createdAt: dbTimeText(row.created_at),
        createdAtMs: Number.isFinite(createdAtMs) ? createdAtMs : 0,
      };
    }

    async function handleLogin(account, password) {
      const role = state.loginRole || "student";
      const email = normalizeLoginEmail(account);
      try {
        const data = await supabaseAuthRequest("token?grant_type=password", { email, password });
        await finishAuth(data, role);
      } catch (error) {
        const message = String(error.message || "");
        if (message.includes("Invalid login credentials")) throw new Error("账号未注册或密码错误，请先注册");
        throw error;
      }
    }

    async function handleRegister(account, password) {
      const role = state.loginRole || "student";
      const email = normalizeLoginEmail(account);
      const data = await supabaseAuthRequest("signup", { email, password, data: { sportloopRole: role } });
      if (data.user?.identities && data.user.identities.length === 0) {
        throw new Error("这个账号已经注册过，请直接登录");
      }
      if (!data.access_token) {
        state.route = "credentials";
        state.loading = false;
        state.notice = "注册成功，请返回登录。如果登录不了，请在 Supabase 关闭邮箱确认";
        render();
        return;
      }
      await finishAuth(data, role, email);
    }

    function declaredUserRole(user = {}) {
      const role = user.user_metadata?.sportloopRole;
      return role === "admin" || role === "student" ? role : "";
    }

    function actualUserRole(user, hasAdminAccess) {
      if (hasAdminAccess) return "admin";
      return declaredUserRole(user) || "student";
    }

    function actualSessionRole() {
      if (state.isAdmin) return "admin";
      return authSession?.declaredRole || "student";
    }

    function roleMismatchMessage(actualRole) {
      if (state.loginRole === "machine" && actualRole !== "admin") return "NFC 机器端需要管理员账号，请使用管理员账号登录";
      return actualRole === "admin" ? "这是管理员账号，请从管理员端登录" : "这是学生账号，请从学生端登录";
    }

    async function checkAdminAccess() {
      return await supabaseRequest("rpc/is_admin", { method: "POST", body: {} }) === true;
    }

    function ensureRoleMatch(requestedRole, actualRole) {
      if (requestedRole === actualRole) return;
      if (requestedRole === "machine" && actualRole === "admin") return;
      throw new Error(roleMismatchMessage(actualRole));
    }

    async function finishAuth(data, role, fallbackEmail = "") {
      const user = data.user || {};
      saveAuthSession({
        accessToken: data.access_token,
        refreshToken: data.refresh_token,
        expiresAt: data.expires_at || Math.floor(Date.now() / 1000) + Number(data.expires_in || 3600),
        userId: user.id,
        email: user.email || fallbackEmail,
        role,
        declaredRole: declaredUserRole(user),
      });
      state.isAdmin = await checkAdminAccess();
      const actualRole = actualUserRole(user, state.isAdmin);
      try {
        ensureRoleMatch(role, actualRole);
      } catch (error) {
        clearAuthSession();
        throw error;
      }
      saveAuthSession({ ...authSession, role: actualRole, loginRole: state.loginRole });
      if (store.authUserId !== user.id || isSeedDemoProfile(store.profile)) resetAccountScopedStore(user.id);
      try {
        await loadRemoteStore();
      } catch (error) {
        reportRemoteSyncError(error);
      }
      state.loading = false;
      state.route = actualRole === "admin"
        ? ((authSession.loginRole || state.loginRole) === "machine" ? "nfcMachine" : "admin")
        : "home";
      state.notice = actualRole === "admin" && !state.isAdmin ? "管理员账号已登录，等待授权" : "";
      render();
    }

    async function refreshAdminAccess() {
      state.isAdmin = await checkAdminAccess();
      const requestedRole = authSession?.role || state.loginRole || "student";
      const actualRole = actualSessionRole();
      try {
        ensureRoleMatch(requestedRole, actualRole);
      } catch (error) {
        clearAuthSession();
        state.route = "credentials";
        state.notice = error.message;
        throw error;
      }
    }

    async function loadRemoteStore() {
      if (!authSession?.accessToken) return;
      await refreshAdminAccess();

      const [equipmentRows, profileRows, loanRows, messageRows, contactRows, orderRows, batchRows, syncLogRows, operationLogRows] = await Promise.all([
        supabaseRequest("equipment?select=*&order=name.asc"),
        supabaseRequest(`student_profiles?select=*&user_id=eq.${authSession.userId}`),
        supabaseRequest("loans?select=*&order=created_at.desc"),
        supabaseRequest("student_messages?select=*&order=created_at.desc"),
        supabaseRequest("admin_contacts?select=*&order=created_at.desc"),
        supabaseRequest("work_orders?select=*&order=created_at.desc"),
        supabaseRequest("batch_borrow_requests?select=*&order=created_at.desc"),
        supabaseRequest("machine_sync_logs?select=*&order=created_at.desc&limit=40"),
        supabaseRequest("admin_operation_logs?select=*&order=created_at.desc&limit=60"),
      ]);

      store.equipment = equipmentRows.map(dbEquipmentToLocal);
      store.authUserId = authSession.userId;
      const remoteProfile = profileRows.length ? dbProfileToLocal(profileRows[0]) : emptyRemoteProfile();
      store.profile = isSeedDemoProfile(remoteProfile) ? emptyRemoteProfile() : { ...emptyRemoteProfile(), ...remoteProfile };
      store.loans = loanRows.map(dbLoanToLocal);
      store.messages = messageRows.map(dbMessageToLocal);
      store.adminMessages = contactRows.map(dbContactToLocal);
      store.workOrders = orderRows.map(dbWorkOrderToLocal);
      store.batchRequests = batchRows.map(dbBatchRequestToLocal);
      store.machineSyncLogs = syncLogRows.map(dbMachineSyncLogToLocal);
      store.adminOperationLogs = operationLogRows.map(dbAdminOperationLogToLocal);
      saveStore();
    }

    async function refreshRemoteStore() {
      if (!authSession?.accessToken || state.remoteLoading) return;
      state.remoteLoading = true;
      const routeBefore = state.route;
      try {
        await loadRemoteStore();
        if (state.route === routeBefore) render();
      } catch (error) {
        reportRemoteSyncError(error);
      } finally {
        state.remoteLoading = false;
      }
    }

    const adminModuleRoutes = {
      batch: "adminBatch",
      messages: "adminMessages",
      orders: "adminOrders",
      equipment: "adminEquipment",
      syncLogs: "adminSyncLogs",
      logs: "adminLogs",
      export: "adminExport",
      venues: "adminVenues",
    };

    function shouldRefreshOnRoute(to) {
      return ["home", "list", "borrow", "batchBorrow", "renew", "messages", "admin", ...Object.values(adminModuleRoutes), "profile", "profileInfo", "creditRules", "identity", "contactAdmin"].includes(to);
    }

    const adminRoutes = new Set(["admin", "nfcMachine", ...Object.values(adminModuleRoutes)]);
    const studentRoutes = new Set([
      "home", "list", "detail", "scanBorrow", "borrowConfirm", "borrow", "batchBorrow", "renew", "renewDetail",
      "detect", "result", "report", "messages", "contactAdmin", "nfcMachine", "profile", "profileInfo", "creditRules", "identity",
    ]);

    function currentUserRole() {
      const loginRole = authSession?.loginRole || state.loginRole;
      if (loginRole === "machine") return "machine";
      const role = authSession?.role || state.loginRole;
      return role === "admin" ? "admin" : "student";
    }

    function normalizeRouteForRole(to) {
      if (!state.loggedIn) return to;
      if (currentUserRole() === "machine") {
        if (to === "nfcMachine" || to === "login" || to === "roleSelect") return to;
        return "nfcMachine";
      }
      if (currentUserRole() === "admin") return adminRoutes.has(to) ? to : "admin";
      if (adminRoutes.has(to)) return "home";
      return studentRoutes.has(to) ? to : "home";
    }

    function runRemote(task) {
      if (!authSession?.accessToken) return;
      task().catch((error) => {
        reportRemoteSyncError(error);
      });
    }

    async function upsertRemoteProfile(profile) {
      return supabaseRequest("student_profiles?on_conflict=user_id", {
        method: "POST",
        headers: { Prefer: "resolution=merge-duplicates,return=representation" },
        body: {
          user_id: authSession.userId,
          nickname: profile.nickname || "",
          real_name: profile.realName || "",
          student_id: profile.studentId || "",
          college: profile.college || "",
          auth_status: profile.authStatus || "未认证",
          campus_role: profile.campusRole || "学生",
          campus_card: profile.campusCard || "未绑定",
        },
      });
    }

    function saveRemoteStudentMessage(message, userId = authSession?.userId) {
      if (!userId || !authSession?.accessToken) return;
      runRemote(() => supabaseRequest("student_messages", {
        method: "POST",
        body: { user_id: userId, title: message.title, body: message.text },
      }));
    }

    function updateRemoteEquipment(item) {
      return supabaseRequest(`equipment?id=eq.${item.id}`, {
        method: "PATCH",
        body: {
          total: item.total,
          available: item.available,
          status: item.status,
          health: item.health,
          nfc_tags: Array.isArray(item.nfcTags) ? item.nfcTags : [],
          machine_synced_at: item.machineSyncedAt || null,
        },
      });
    }

    function saveRemoteEquipment(item) {
      runRemote(() => updateRemoteEquipment(item));
    }

    async function createRemoteEquipment(item) {
      return supabaseRequest("equipment", {
        method: "POST",
        body: equipmentToDbPayload(item),
      });
    }

    async function upsertRemoteEquipmentBatch(items) {
      return supabaseRequest("equipment?on_conflict=asset_id", {
        method: "POST",
        headers: { Prefer: "resolution=merge-duplicates,return=representation" },
        body: items.map(equipmentToDbPayload),
      });
    }

    function updateRemoteLoan(loan) {
      return supabaseRequest(`loans?id=eq.${loan.id}`, {
        method: "PATCH",
        body: {
          due_at: toIso(loan.dueAtMs),
          duration_periods: loan.durationPeriods,
          duration_minutes: loan.durationMinutes,
          status: loan.status,
          detect_result: loan.detectResult || "",
          before_photo_data_url: loan.beforePhotoDataUrl || "",
          return_photo_data_url: loan.returnPhotoDataUrl || "",
          return_machine_allowed: Boolean(loan.returnMachineAllowed),
          returned_at: loan.returnedAtMs ? toIso(loan.returnedAtMs) : null,
          returned_on_time: loan.returnedOnTime,
          renewed_times: loan.renewedTimes || 0,
          renewal_records: loan.renewalRecords || [],
          batch_request_id: loan.batchRequestId || null,
          nfc_serial: loan.nfcSerial || "",
          nfc_verified_at: loan.nfcVerifiedAt || null,
          verification_code: loan.verificationCode || "",
          verification_code_expires_at: loan.verificationCodeExpiresAt || null,
          student_name: loan.studentName || "",
          student_id: loan.studentId || "",
        },
      });
    }

    function saveRemoteLoan(loan) {
      runRemote(() => updateRemoteLoan(loan));
    }

    function insertRemoteLoan(loan, userId = authSession?.userId) {
      return supabaseRequest("loans", {
        method: "POST",
        body: {
          id: loan.id,
          user_id: userId,
          equipment_id: loan.equipmentId,
          borrowed_at: toIso(loan.borrowedAtMs),
          due_at: toIso(loan.dueAtMs),
          duration_periods: loan.durationPeriods,
          duration_minutes: loan.durationMinutes,
          status: loan.status,
          detect_result: loan.detectResult || "",
          before_photo_data_url: loan.beforePhotoDataUrl || "",
          return_photo_data_url: loan.returnPhotoDataUrl || "",
          return_machine_allowed: Boolean(loan.returnMachineAllowed),
          batch_request_id: loan.batchRequestId || null,
          nfc_serial: loan.nfcSerial || "",
          nfc_verified_at: loan.nfcVerifiedAt || null,
          verification_code: loan.verificationCode || "",
          verification_code_expires_at: loan.verificationCodeExpiresAt || null,
          student_name: loan.studentName || "",
          student_id: loan.studentId || "",
        },
      });
    }

    function createRemoteLoan(loan) {
      runRemote(() => insertRemoteLoan(loan));
    }

    function batchRequestRemoteBody(request) {
      return {
        id: request.id,
        user_id: request.userId || authSession.userId,
        student_name: request.studentName || "",
        student_id: request.studentId || "",
        items: request.items || [],
        duration_periods: request.durationPeriods,
        duration_minutes: request.durationMinutes,
        status: request.status,
        admin_note: request.adminNote || "",
        borrowed_at: request.borrowedAtMs ? toIso(request.borrowedAtMs) : null,
        returned_at: request.returnedAtMs ? toIso(request.returnedAtMs) : null,
      };
    }

    async function createRemoteBatchRequest(request) {
      return supabaseRequest("batch_borrow_requests", {
        method: "POST",
        body: batchRequestRemoteBody(request),
      });
    }

    async function saveRemoteBatchRequest(request) {
      return supabaseRequest(`batch_borrow_requests?id=eq.${request.id}`, {
        method: "PATCH",
        body: batchRequestRemoteBody(request),
      });
    }

    function createRemoteWorkOrder(order) {
      runRemote(() => supabaseRequest("work_orders", {
        method: "POST",
        body: {
          id: order.id,
          user_id: authSession.userId,
          equipment_id: order.equipmentId,
          loan_id: order.loanId || null,
          title: order.title,
          source: order.source,
          status: order.status,
          restored: !!order.restored,
        },
      }));
    }

    function saveRemoteWorkOrder(order) {
      runRemote(() => supabaseRequest(`work_orders?id=eq.${order.id}`, {
        method: "PATCH",
        body: { status: order.status, restored: !!order.restored },
      }));
    }

    async function createRemoteAdminContact(message) {
      return supabaseRequest("admin_contacts", {
        method: "POST",
        body: {
          id: message.id,
          user_id: authSession.userId,
          sender_name: message.senderName,
          student_id: message.studentId,
          category: message.category,
          body: message.text,
          status: message.status,
        },
      });
    }

    async function saveRemoteAdminContact(message) {
      return supabaseRequest(`admin_contacts?id=eq.${message.id}`, {
        method: "PATCH",
        body: {
          status: message.status,
          reply: message.reply || "",
          replied_at: message.repliedAtMs ? toIso(message.repliedAtMs) : new Date().toISOString(),
        },
      });
    }

    function createRemoteMachineSyncLog(log) {
      if (!authSession?.accessToken) return;
      runRemote(() => supabaseRequest("machine_sync_logs", {
        method: "POST",
        body: {
          id: log.id,
          operator_id: authSession.userId,
          mode: log.mode,
          item_count: log.itemCount,
          chip_count: log.chipCount,
          duplicate_count: log.duplicateCount,
          failed_count: log.failedCount,
          summary: log.summary,
          details: log.details || {},
          created_at: log.createdAtMs ? toIso(log.createdAtMs) : new Date().toISOString(),
        },
      }));
    }

    function createRemoteAdminOperationLog(log) {
      if (!authSession?.accessToken) return;
      runRemote(() => supabaseRequest("admin_operation_logs", {
        method: "POST",
        body: {
          id: log.id,
          operator_id: authSession.userId,
          action: log.action,
          target_type: log.targetType,
          target_id: log.targetId,
          summary: log.summary,
          details: log.details || {},
          created_at: log.createdAtMs ? toIso(log.createdAtMs) : new Date().toISOString(),
        },
      }));
    }


    function mergeEquipmentImages(cachedList) {
      const seedById = Object.fromEntries(seed.equipment.map((item) => [item.id, item]));
      return (cachedList || []).map((item) => {
        const base = seedById[item.id];
        const merged = base && !item.image ? { ...item, image: base.image } : item;
        return {
          ...merged,
          nfcTags: Array.isArray(merged.nfcTags) ? merged.nfcTags : [],
          machineSyncedAt: merged.machineSyncedAt || "",
        };
      });
    }

    function loadStore() {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return { ...clone(seed), authUserId: "" };
      const parsed = JSON.parse(raw);
      return {
        authUserId: parsed.authUserId || "",
        profile: { ...clone(seed.profile), ...(parsed.profile || {}) },
        equipment: mergeEquipmentImages(parsed.equipment),
        loans: parsed.loans || [],
        batchRequests: parsed.batchRequests || [],
        workOrders: parsed.workOrders || [],
        identityBindings: parsed.identityBindings || [],
        adminMessages: parsed.adminMessages || [],
        machineSyncLogs: parsed.machineSyncLogs || [],
        adminOperationLogs: parsed.adminOperationLogs || [],
        venues: parsed.venues || clone(seed.venues || []),
        messages: parsed.messages || clone(seed.messages),
      };
    }

    function cleanVenue(value = "") {
      return value.replace(/\s*\d+\s*号机/g, "").replace(/自助机/g, "").trim();
    }

    let store = loadStore();
    let authSession = loadAuthSession();
    applyAuthSessionToState();
    store.equipment.forEach((item) => {
      item.venue = cleanVenue(item.venue);
      item.nfcTags = Array.isArray(item.nfcTags) ? item.nfcTags : [];
      item.machineSyncedAt = item.machineSyncedAt || "";
    });
    saveStore();

    if (!Array.isArray(store.venues) || !store.venues.length) {
      const unique = [...new Set(store.equipment.map((item) => cleanVenue(item.venue)).filter(Boolean))];
      store.venues = unique.length
        ? unique.map((name, i) => ({ id: "v" + String(i + 1), name, open: true }))
        : clone(seed.venues || []);
      saveStore();
    }

    function stripLoanPhotosForLocalCache(loan = {}) {
      const cached = { ...loan };
      if (typeof cached.beforePhotoDataUrl === "string" && cached.beforePhotoDataUrl.startsWith("data:image/")) {
        cached.beforePhotoDataUrl = "";
      }
      if (typeof cached.returnPhotoDataUrl === "string" && cached.returnPhotoDataUrl.startsWith("data:image/")) {
        cached.returnPhotoDataUrl = "";
      }
      return cached;
    }

    function localStoreSnapshot() {
      return {
        ...store,
        loans: (store.loans || []).map(stripLoanPhotosForLocalCache),
      };
    }

    function isStorageQuotaError(error) {
      const message = String(error?.message || "").toLowerCase();
      return error?.name === "QuotaExceededError"
        || error?.code === 22
        || message.includes("quota");
    }

    function saveStore() {
      const payload = JSON.stringify(localStoreSnapshot());
      try {
        localStorage.setItem(STORAGE_KEY, payload);
      } catch (error) {
        if (!isStorageQuotaError(error)) throw error;
        localStorage.removeItem(STORAGE_KEY);
        try {
          localStorage.setItem(STORAGE_KEY, payload);
        } catch {
          throw new Error("浏览器缓存空间不足，请点清空数据缓存后重试");
        }
      }
    }

    function profileData() {
      const defaults = state.loggedIn ? emptyRemoteProfile() : clone(seed.profile);
      const localProfile = state.loggedIn && isSeedDemoProfile(store.profile) ? {} : (store.profile || {});
      return { ...defaults, ...localProfile };
    }

    function profileNickname() {
      const profile = profileData();
      const savedName = typeof profile.nickname === "string" ? profile.nickname.trim() : "";
      return savedName || (state.loggedIn ? "未设置昵称" : seed.profile.nickname);
    }

    function profileMetaText() {
      const profile = profileData();
      const studentId = profile.studentId || "未绑定学号";
      const college = profile.college || "未绑定院系";
      return `学号 ${studentId}　|　${profile.authStatus}　|　${college}`;
    }

    function normalizeIdentityText(value) {
      return String(value || "").trim().replace(/\s+/g, "");
    }

    function normalizeStudentId(value) {
      return normalizeIdentityText(value).toUpperCase();
    }

    function icon(name) {
      return icons[name] || "";
    }

    function nowText() {
      return formatDateTime(Date.now());
    }

    function formatDateTime(ms) {
      return new Intl.DateTimeFormat("zh-CN", { month: "2-digit", day: "2-digit", hour: "2-digit", minute: "2-digit" }).format(new Date(ms));
    }

    function formatDueTime(ms) {
      if (!Number.isFinite(ms)) return "未设置";
      const due = new Date(ms);
      const now = new Date();
      const sameDay = due.getFullYear() === now.getFullYear() && due.getMonth() === now.getMonth() && due.getDate() === now.getDate();
      return sameDay
        ? `今日 ${new Intl.DateTimeFormat("zh-CN", { hour: "2-digit", minute: "2-digit" }).format(due)}`
        : formatDateTime(ms);
    }

    function selectedBorrowPeriods() {
      return BORROW_PERIOD_OPTIONS.includes(Number(state.borrowPeriods)) ? Number(state.borrowPeriods) : 1;
    }

    function borrowDurationLabel(periods = selectedBorrowPeriods()) {
      const safePeriods = BORROW_PERIOD_OPTIONS.includes(Number(periods)) ? Number(periods) : 1;
      const hours = (safePeriods * CLASS_PERIOD_MINUTES) / 60;
      return `${safePeriods} 节课 · ${Number.isInteger(hours) ? hours : hours.toFixed(1)} 小时`;
    }

    function borrowDurationOptions() {
      return BORROW_PERIOD_OPTIONS.map((periods) => `
        <button class="duration-option ${selectedBorrowPeriods() === periods ? "active" : ""}" data-borrow-periods="${periods}" type="button">
          <strong>${periods} 节课</strong>
          <span>${borrowDurationLabel(periods).split(" · ")[1]}</span>
        </button>
      `).join("");
    }

    function byId(id) {
      return store.equipment.find((item) => item.id === id) || null;
    }

    function loanById(id) {
      return store.loans.find((loan) => loan.id === id);
    }

    function loanNeedsBeforePhoto(loan) {
      return !!loan
        && ["待补借出照片", "使用中", "待归还", "异常待归还"].includes(loan.status)
        && !loan.beforePhotoDataUrl;
    }

    function loanDisplayStatus(loan) {
      if (loan.status === "等待NFC验证") return "等待NFC验证";
      return loanNeedsBeforePhoto(loan) ? "待补借出照片" : loan.status;
    }

    function activeBorrowLoans() {
      return store.loans.filter((loan) => ["待补借出照片", "使用中", "待归还", "异常待归还"].includes(loan.status));
    }

    function pendingNfcLoans() {
      return store.loans.filter((loan) => loan.status === "等待NFC验证").filter((loan) => !isVerificationCodeExpired(loan));
    }

    function expiredNfcLoans() {
      return store.loans.filter((loan) => loan.status === "等待NFC验证" && isVerificationCodeExpired(loan));
    }

    async function cancelPendingBorrow(loanId) {
      const loan = loanById(loanId);
      if (!loan) return;
      if (loan.status !== "等待NFC验证" && loan.status !== "待补借出照片") return;
      const item = byId(loan.equipmentId);
      if (loan.status === "待补借出照片" && item) {
        item.available = Math.min(item.total, item.available + 1);
        item.status = item.available > 0 ? "可借" : "补充中";
        saveRemoteEquipment(item);
      }
      loan.status = "已取消";
      saveStore();
      runRemote(() => supabaseRequest(`loans?id=eq.${loan.id}`, { method: "PATCH", body: { status: "已取消" } }));
      pushMessage("借用已取消", `${item ? item.name : "器材"} 的借用申请已取消。`);
      state.notice = "借用申请已取消";
      render();
    }

    function confirmedBorrowLoans() {
      return activeBorrowLoans().filter((loan) => !loanNeedsBeforePhoto(loan));
    }

    function canRenewLoan(loan) {
      return !!loan && !loanNeedsBeforePhoto(loan) && loan.status === "使用中";
    }

    function renewedDueAtMs(loan, periods = selectedBorrowPeriods()) {
      const base = Number.isFinite(Number(loan?.dueAtMs)) ? Number(loan.dueAtMs) : Date.now();
      const start = Math.max(Date.now(), base);
      return start + periods * CLASS_PERIOD_MINUTES * 60 * 1000;
    }

    function activeLoan() {
      return activeBorrowLoans()[0] || null;
    }

    function pushMessage(title, text) {
      const message = { id: makeUuid(), title, text, time: nowText() };
      store.messages.unshift(message);
      saveRemoteStudentMessage(message);
    }

    function adminMessageList() {
      if (!Array.isArray(store.adminMessages)) store.adminMessages = [];
      return store.adminMessages;
    }

    function machineSyncLogList() {
      if (!Array.isArray(store.machineSyncLogs)) store.machineSyncLogs = [];
      return store.machineSyncLogs.sort((a, b) => Number(b.createdAtMs || 0) - Number(a.createdAtMs || 0));
    }

    function adminOperationLogList() {
      if (!Array.isArray(store.adminOperationLogs)) store.adminOperationLogs = [];
      return store.adminOperationLogs.sort((a, b) => Number(b.createdAtMs || 0) - Number(a.createdAtMs || 0));
    }

    function createMachineSyncLog(payload) {
      const createdAtMs = Date.now();
      const log = {
        id: makeUuid(),
        operatorId: state.currentUserId,
        mode: payload.mode || "入库同步",
        itemCount: Number(payload.itemCount) || 0,
        chipCount: Number(payload.chipCount) || 0,
        duplicateCount: Number(payload.duplicateCount) || 0,
        failedCount: Number(payload.failedCount) || 0,
        summary: payload.summary || "",
        details: payload.details || {},
        createdAt: formatDateTime(createdAtMs),
        createdAtMs,
      };
      machineSyncLogList().unshift(log);
      store.machineSyncLogs = machineSyncLogList().slice(0, 40);
      saveStore();
      createRemoteMachineSyncLog(log);
      return log;
    }

    function createAdminOperationLog(action, targetType, targetId, summary, details = {}) {
      const createdAtMs = Date.now();
      const log = {
        id: makeUuid(),
        operatorId: state.currentUserId,
        action,
        targetType,
        targetId,
        summary,
        details,
        createdAt: formatDateTime(createdAtMs),
        createdAtMs,
      };
      adminOperationLogList().unshift(log);
      store.adminOperationLogs = adminOperationLogList().slice(0, 80);
      saveStore();
      createRemoteAdminOperationLog(log);
      return log;
    }

    function batchRequestList() {
      if (!Array.isArray(store.batchRequests)) store.batchRequests = [];
      return store.batchRequests;
    }

    function batchRequestById(id) {
      return batchRequestList().find((request) => request.id === id) || null;
    }

    function clearScanTimers() {
      window.clearTimeout(window.__scanTimer);
      window.clearTimeout(window.__scanSuccessTimer);
    }

    function route(to, payload = {}) {
      to = normalizeRouteForRole(to);
      if (state.route === "scanBorrow" && to !== "scanBorrow") {
        clearScanTimers();
        state.scanPhase = "idle";
      }
      if (!state.navHistory) state.navHistory = [];
      if (state.route && state.route !== to) {
        state.navHistory.push(state.route);
        if (state.navHistory.length > 20) state.navHistory.shift();
      }
      state.previous = state.route;
      state.route = to;
      if (payload.id) state.selectedId = payload.id;
      if (payload.loanId) state.activeLoanId = payload.loanId;
      if (to === "renewDetail" && payload.loanId) state.borrowPeriods = 1;
      if (to === "scanBorrow") {
        state.scanPhase = "scanning";
        state.syncContext = payload.syncContext || "borrow";
      }
      render();
      if (state.loggedIn && shouldRefreshOnRoute(to)) refreshRemoteStore();
    }

    function back() {
      if (!state.navHistory) state.navHistory = [];
      while (state.navHistory.length > 0) {
        const prev = state.navHistory.pop();
        if (prev && prev !== state.route) {
          state.route = prev;
          render();
          if (state.loggedIn && shouldRefreshOnRoute(prev)) refreshRemoteStore();
          return;
        }
      }
      route("home");
    }

    function statusClass(status) {
      if (status === "可借" || status === "已归还" || status === "已完成" || status === "已回复" || status === "已通过" || status === "已同步") return "ok";
      if (status === "补充中" || status === "等待NFC验证" || status === "待补借出照片" || status === "待补照片" || status === "使用中" || status === "待归还" || status === "待回复" || status === "待审核" || status === "已借出") return "warn";
      return "bad";
    }

    function tag(status) {
      return `<span class="tag ${statusClass(status)}">${status}</span>`;
    }

    function shell(title, body, options = {}) {
      const left = options.left === "none"
        ? `<span></span>`
        : `<button class="icon-button" data-back aria-label="返回">${icon("back")}</button>`;
      const right = options.right === "none"
        ? `<span></span>`
        : options.right === "logout"
          ? `<button class="icon-button" data-logout aria-label="退出登录">${icon("logout")}</button>`
          : `<button class="avatar" data-route="profile" aria-label="个人中心"></button>`; /* [IMAGE-12] 顶栏头像 */
      return `
        <section class="screen${options.admin ? " admin-shell" : ""}">
          <header class="topbar">
            ${left}
            <div class="page-title">${title}</div>
            ${right}
          </header>
          ${notice()}
          ${body}
          ${options.tabs === false ? "" : tabbar()}
        </section>
      `;
    }

    function notice() {
      if (!state.notice) return "";
      const html = `<div class="toast" id="noticeToast">${escapeHtml(state.notice)}</div>`;
      window.clearTimeout(window.__noticeTimer);
      window.__noticeTimer = window.setTimeout(() => {
        state.notice = "";
        const toast = document.querySelector("#noticeToast");
        if (toast) toast.remove();
      }, 2200);
      return html;
    }

    function tabbar() {
      const tabs = [
        ["home", "首页", "home"],
        ["list", "器材", "search"],
        ["borrow", "借用", "bag"],
        ["messages", "消息", "bell"],
        ["profile", "我的", "user"],
      ];
      return `
        <nav class="tabbar" aria-label="底部导航">
          ${tabs.map(([name, label, svg]) => `
            <button class="tab-button ${state.route === name ? "active" : ""}" data-route="${name}" aria-label="${label}">
              ${icon(svg)}<span>${label}</span>
            </button>
          `).join("")}
        </nav>
      `;
    }

    /** 将路径转为浏览器可用的 src（相对路径 / 正斜杠 / file:// / URL 编码） */
    function toImageSrc(raw) {
      if (!raw) return "";
      const s = String(raw).trim();
      if (/^(https?:|data:|blob:|file:)/i.test(s)) return s;

      const forward = s.replace(/\\/g, "/");
      const encodeSeg = (seg) => (/[^\x00-\x7F]/.test(seg) ? encodeURIComponent(seg) : seg);

      if (/^[a-zA-Z]:/.test(forward)) {
        const m = forward.match(/^([a-zA-Z]):\/?(.*)$/);
        if (!m) return forward;
        const segments = m[2].split("/").filter(Boolean).map(encodeSeg);
        return `file:///${m[1]}:/${segments.join("/")}`;
      }

      return forward.split("/").map(encodeSeg).join("/");
    }

    function escapeAttr(value) {
      return String(value)
        .replace(/&/g, "&amp;")
        .replace(/"/g, "&quot;")
        .replace(/</g, "&lt;");
    }

    function escapeHtml(value) {
      return String(value)
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;");
    }

    /** 静态资源 URL 加版本参数，绕过浏览器对同名图片的强缓存 */
    function assetUrl(path) {
      const src = toImageSrc(path);
      if (!src || /^(data:|blob:)/i.test(src)) return src;
      const join = src.includes("?") ? "&" : "?";
      return `${src}${join}v=${ASSET_VERSION}`;
    }

    // [IMAGE-FN] 器材图统一渲染：所有页面的器材缩略图/大图均由此函数输出 <img>
    function equipmentImage(item, className = "item-img") {
      const name = item?.name || "暂无图片";
      const rawImage = item?.image || "";
      const src = rawImage ? assetUrl(rawImage) : "";
      const hasImageFile = src && (src.includes(".") || src.startsWith("data:") || src.startsWith("file:"));

      if (hasImageFile) {
        return `
          <div class="${className}" style="display:flex; align-items:center; justify-content:center; background:rgba(159,18,57,0.03); border-radius:12px; overflow:hidden; width:100%; height:100%;">
            <img src="${escapeAttr(src)}" alt="${escapeAttr(name)}" loading="lazy" decoding="async" style="width:100%; height:100%; object-fit:cover;" onerror="this.onerror=null; this.parentElement.innerHTML='无图';"><!-- [IMAGE-ERR] 加载失败占位 -->
          </div>
        `;
      }
      
      return `<span class="${className}" style="display:flex; align-items:center; justify-content:center; background:rgba(159,18,57,0.05); border-radius:12px; color:var(--muted); font-size:12px; font-weight:900;">无图</span>`;
    }

    // ⚡ 完美重组的首页核心渲染方法：保留全部原有生态，只精准重构顶部卡片和加上反馈入口
    function homePage() {
      const totalAvailable = store.equipment.reduce((sum, item) => sum + item.available, 0);
      const openVenues = (Array.isArray(store.venues) ? store.venues.filter((v) => v.open).length : 0);
      const health = store.equipment.length ? Math.round(store.equipment.reduce((sum, item) => sum + item.health, 0) / store.equipment.length) : 0;
      const currentLoan = activeLoan();
      const popularEquipment = store.equipment.slice(0, 5);

      return `
        <section class="screen home-screen">
          <header class="home-top">
            <button class="icon-button" data-route="messages" aria-label="消息通知">${icon("bell")}</button>
            <div class="brand"><img class="logo-mark app-icon" src="${escapeAttr(assetUrl(APP_ICON_SRC))}" alt="SportLoop" decoding="async" /><span>SportLoop</span></div>
            <button class="icon-button" data-route="list" aria-label="器材列表">${icon("search")}</button>
          </header>
          ${notice()}
          <main class="scroll">
            <section class="new-hero-container">
              <div class="new-hero-left">
                <h1 class="new-hero-title">Sports</h1>
                <h1 class="new-hero-title">器材借用</h1>
                <p class="new-hero-subtitle">先看状态，再去借用</p>
                <div class="new-stats-stack">
                  <div class="new-stat-card">
                    <div class="new-stat-icon-wrapper red-theme">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line><polyline points="8 14 10 16 14 12"></polyline></svg>
                    </div>
                    <div class="new-stat-text">
                      <span class="new-stat-label">今日可借</span>
                      <span class="new-stat-val">${totalAvailable} <small>件</small></span>
                    </div>
                  </div>

                  <div class="new-stat-card">
                    <div class="new-stat-icon-wrapper blue-theme">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><polyline points="9 11 11 13 15 9"></polyline></svg>
                    </div>
                    <div class="new-stat-text">
                      <span class="new-stat-label">状态良好</span>
                      <span class="new-stat-val">${health}%</span>
                    </div>
                  </div>

                  <div class="new-stat-card">
                    <div class="new-stat-icon-wrapper purple-theme">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="9" y1="3" x2="9" y2="21"></line><line x1="15" y1="3" x2="15" y2="21"></line><line x1="3" y1="9" x2="21" y2="9"></line><line x1="3" y1="15" x2="21" y2="15"></line></svg>
                    </div>
                    <div class="new-stat-text">
                      <span class="new-stat-label">开放场地</span>
                      <span class="new-stat-val">${openVenues} <small>个</small></span>
                    </div>
                  </div>
                </div>
              </div>
            </section>

            ${currentLoan ? currentLoanCard(currentLoan) : flowCard()}

            <section class="home-feedback-card" data-route="report" style="cursor: pointer; margin-bottom: 16px;">
              <div class="feedback-card-content">
                <div class="feedback-card-text">
                  <h3>💬 反馈器材问题</h3>
                  <p>球拍磨损、没气？点击快速反馈报损</p>
                </div>
                <div class="feedback-arrow">${icon("chevron")}</div>
              </div>
            </section>

            <div class="section-head">
              <h2>器材种类</h2>
            </div>
            <div class="equipment-grid">
              ${popularEquipment.length ? popularEquipment.map(equipmentCard).join("") : `<div class="empty">暂无器材，管理员录入后会显示在这里。</div>`}
            </div>
          </main>
          ${tabbar()}
        </section>
      `;
    }

    function flowCard() {
      const steps = [
        ["发起借用", "bag"],
        ["获取验证码", "search"],
        ["NFC 机器验证", "scan"],
        ["上传照片", "camera"],
        ["完成借用", "check"],
      ];
      return `
        <section class="action-panel" style="margin-bottom:14px;">
          <h2 style="margin:0 0 12px;">开始借用</h2>
          <div class="flow" style="border:0;box-shadow:none;background:transparent;padding:0;">
            ${steps.map(([label, svg], index) => `<div><i>${icon(svg)}</i><b>${index + 1}</b><span>${label}</span></div>`).join("")}
          </div>
          <div class="button-row" style="margin-top:14px;">
            <button class="primary-button" data-route="list">${icon("search")} 查看器材</button>
            <button class="secondary-button" data-route="batchBorrow">${icon("bag")} 批量申请</button>
          </div>
        </section>
      `;
    }

    function kpi(label, value, unit) {
      return `<div class="kpi"><span>${label}</span><strong>${value}<small>${unit}</small></strong></div>`;
    }

    function quickStartCard() {
      return `
        <section class="action-panel">
          <div>
            <h2>开始借用</h2>
            <p>选择器材 → 获取验证码 → 场馆 NFC 机器验证 → 完成借用。</p>
          </div>
          <div class="button-row">
            <button class="primary-button" data-route="list">${icon("search")} 查看器材</button>
            <button class="secondary-button" data-route="batchBorrow">${icon("bag")} 批量申请</button>
          </div>
        </section>
      `;
    }

    function currentLoanCard(loan) {
      const item = byId(loan.equipmentId);
      if (!item) return "";
      const pendingBeforePhoto = loanNeedsBeforePhoto(loan);
      const action = pendingBeforePhoto
        ? `<button class="primary-button" style="min-height:36px; border-radius:10px; font-size:12px;" data-borrow-confirm="${loan.id}">${icon("camera")} 上传借出前照片</button>`
        : `<button class="primary-button" style="min-height:36px; border-radius:10px; font-size:12px;" data-loan-detect="${loan.id}" data-detect-mode="photo">${icon("camera")} 归还前检测</button>`;
      return `
        <section class="active-loan">
          ${equipmentImage(item, "loan-thumb")}<!-- [IMAGE-FN→loan-thumb] 首页·当前借用卡片 -->
          <div>
            <p class="eyebrow">当前借用</p>
            <h2>${item.name}</h2>
            <p style="font-size: 11px; margin-top: 2px;">${item.assetId} · ${loanDisplayStatus(loan)}</p>
            <div class="button-row" style="margin-top: 8px;">
              <button class="secondary-button" style="min-height:36px; border-radius:10px; font-size:12px;" data-report-loan="${loan.id}">${icon("wrench")} 报损</button>
              ${action}
            </div>
          </div>
        </section>
      `;
    }

    function equipmentCard(item) {
      return `
        <button class="equipment-card" data-detail="${item.id}" aria-label="查看${item.name}">
          ${equipmentImage(item, "item-img")}
          <span style="width:100%;">
            <strong style="white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">${item.name}</strong>
            <small>可借 ${item.available} 件</small>
          </span>
        </button>
      `;
    }

    function flow() {
      const steps = [
        ["手机发起借用", "search"],
        ["获取验证码", "bag"],
        ["NFC 机器验证", "scan"],
        ["拍照检测", "camera"],
        ["管理员维保", "wrench"],
      ];
      return `<div class="flow">${steps.map(([label, svg], index) => `<div><i>${icon(svg)}</i><b>${index + 1}</b><span>${label}</span></div>`).join("")}</div>`;
    }

    function listPage() {
      const categories = ["全部", ...new Set(store.equipment.map((item) => item.category))];
      const filtered = store.equipment.filter((item) => {
        const hitCategory = state.category === "全部" || item.category === state.category;
        const hitQuery = !state.query || item.name.includes(state.query) || item.assetId.includes(state.query.toUpperCase());
        return hitCategory && hitQuery;
      });
      const body = `
        <div class="search-row">
          <label class="search-box">
            ${icon("search")}
            <input id="searchInput" value="${escapeAttr(state.query)}" placeholder="搜索器材或编号" aria-label="搜索器材或编号" />
          </label>
        </div>
        <main class="scroll admin-dashboard-scroll">
          <div class="chips">
            ${categories.map((name) => `<button class="chip ${state.category === name ? "active" : ""}" data-category="${name}">${name}</button>`).join("")}
          </div>
          <div class="list-meta"><span>${filtered.length} 类器材</span><span>可借优先</span></div>
          <div class="list-stack">${filtered.length ? filtered.map(listItem).join("") : `<div class="empty">暂无器材。管理员录入后会出现在这里。</div>`}</div>
        </main>
      `;
      return shell("器材列表", body);
    }

    function listItem(item) {
      return `
        <button class="list-card" data-detail="${item.id}">
          <span class="list-media">${equipmentImage(item, "list-img")}</span>
          <span>
            <strong>${item.name}</strong>
            <small>可借 ${item.available} 件</small>
          </span>
        </button>
      `;
    }

    function detailPage() {
      const item = byId(state.selectedId);
      if (!item) return shell("器材详情", `<main class="scroll"><div class="empty">暂无这个器材，请先回到器材列表。</div></main>`);
      const periods = selectedBorrowPeriods();
      const durationText = borrowDurationLabel(periods);
      const body = `
        <main class="scroll admin-dashboard-scroll">
          <section class="detail-card">
            ${equipmentImage(item, "detail-img")}
            <div class="detail-title">
              <div>
                <h1>${item.name}</h1>
                <p>可借 ${item.available} 件</p>
              </div>
            </div>
            <div class="info-list">
              <div><span>借用方式</span><strong>手机发起借用 → 获取验证码 → 场馆 NFC 机器验证 → 上传借出前照片生效</strong></div>
            </div>
            <div class="duration-picker">
              <div class="duration-picker-head">
                <strong>选择借用时长</strong>
                <span>1 节课 = ${CLASS_PERIOD_MINUTES} 分钟</span>
              </div>
              <div class="duration-options">${borrowDurationOptions()}</div>
              <p class="machine-hint" style="margin:0;">当前选择：${durationText}</p>
            </div>
            <button class="primary-button" data-sync-borrow="${item.id}" ${item.available <= 0 ? "disabled" : ""}>${icon("bag")} 借用</button>
            <p class="machine-hint" style="margin-top:12px;">点击借用后将生成 6 位验证码，请前往场馆 NFC 识别机器输入验证码并贴 NFC 标签完成验证。</p>
          </section>
        </main>
      `;
      return shell("器材详情", body);
    }

    function metric(value, label) {
      return `<div class="metric"><strong>${value}</strong><span>${label}</span></div>`;
    }

    function scanBorrowPage() {
      const isReturn = state.syncContext === "return";
      const loan = isReturn ? loanById(state.activeLoanId) : null;
      const item = isReturn ? byId(loan?.equipmentId || state.selectedId) : byId(state.selectedId);
      if (!item) return shell(isReturn ? "同步归还记录" : "同步借用记录", `<main class="scroll"><div class="empty">暂无这个器材，无法同步。</div></main>`, { tabs: false });
      const isSuccess = state.scanPhase === "success";
      return `
        <section class="screen scan-screen">
          <header class="scan-screen-header">
            <button class="icon-button" data-back aria-label="返回">${icon("back")}</button>
            <div class="page-title">${isReturn ? "同步归还记录" : "同步借用记录"}</div>
            <span class="scan-header-spacer" aria-hidden="true"></span>
          </header>
          <div class="scan-screen-body">
            ${isSuccess ? `
              <div class="scan-success-card" style="margin:0 auto 18px;">
                <div class="scan-success-icon">${icon("check")}</div>
                <h2 style="margin:0;font-size:22px;">同步成功</h2>
                <p style="margin:8px 0 0;color:rgba(255,255,255,0.72);font-size:14px;">${item.assetId} 已与手机对齐</p>
              </div>
            ` : `
              <div class="sync-visual">
                <span class="sync-ring"></span>
                <span class="sync-ring"></span>
                <span class="sync-ring"></span>
                <div class="sync-core">${icon(isReturn ? "check" : "bag")}</div>
              </div>
            `}
            ${isSuccess ? `
              <p class="scan-hint">
                ${isReturn ? "即将更新归还状态" : "即将进入借用确认"}
                <strong>${item.name}</strong>
              </p>
            ` : ""}
          </div>
        </section>
      `;
    }

    function borrowConfirmPage() {
      const loan = loanById(state.activeLoanId);
      if (!loan) {
        return shell("借用确认", `<main class="scroll"><div class="empty">未找到借用记录。</div></main>`, { tabs: false });
      }
      const item = byId(loan.equipmentId);
      if (!item) return shell("借用确认", `<main class="scroll"><div class="empty">未找到对应器材。</div></main>`, { tabs: false });
      const needsBeforePhoto = loanNeedsBeforePhoto(loan);
      const isAwaitingNfc = loan.status === "等待NFC验证";
      let body;
      if (!needsBeforePhoto && !isAwaitingNfc) {
        state.navHistory = ["home"];
      }
      if (isAwaitingNfc) {
        const expiresIn = loan.verificationCodeExpiresAt
          ? Math.max(0, Math.round((new Date(loan.verificationCodeExpiresAt).getTime() - Date.now()) / 60000))
          : 5;
        body = `
          <main class="scroll">
            <section class="result-card">
              <div class="borrow-confirm-hero">
                <div class="borrow-confirm-badge">${icon("scan")}</div>
                <h1 style="margin:0;font-size:28px;">前往 NFC 机器验证</h1>
                <p class="body-text" style="text-align:center;margin-top:10px;">请记下验证码，前往场馆的 NFC 识别机器完成验证。</p>
              </div>
              <div style="text-align:center;padding:24px 0;">
                <div style="font-size:56px;font-weight:900;letter-spacing:12px;color:var(--brand);font-family:'DIN Alternate','SF Pro Display',monospace;">${loan.verificationCode || "------"}</div>
                <p style="margin:8px 0 0;color:var(--muted);font-size:13px;">6 位验证码 · ${expiresIn} 分钟内有效</p>
              </div>
              ${equipmentImage(item, "detail-img")}<!-- [IMAGE-FN→detail-img] 借用确认页 -->
              <div class="detail-title" style="margin-top:14px;">
                <div>
                  <h1 style="font-size:24px;">${item.name}</h1>
                  <p>${item.assetId}</p>
                </div>
                ${tag(loanDisplayStatus(loan))}
              </div>
              <div class="info-list" style="margin-top:14px;">
                <div><span>借出时间</span><strong>${loan.borrowedAt}</strong></div>
                <div><span>借用时长</span><strong>${loan.durationLabel || "未设置"}</strong></div>
                <div><span>归还截止</span><strong>${loan.dueAt || "未设置"}</strong></div>
              </div>
              <p class="machine-hint" style="margin-top:16px;">
                到达 NFC 机器后：<br>
                1. 打开机器上的 SportLoop NFC 验证页面<br>
                2. 输入上方 6 位验证码<br>
                3. 将器材 NFC 标签贴到机器背面<br>
                4. 验证通过后回到此页面，上传借出前照片完成借用
              </p>
              <button class="primary-button" style="margin-top:12px;width:100%;" data-route="borrow">${icon("bag")} 查看我的借用</button>
            </section>
          </main>
        `;
      } else {
        body = `
          <main class="scroll">
            <section class="result-card">
              <div class="borrow-confirm-hero">
                <div class="borrow-confirm-badge">${icon(needsBeforePhoto ? "camera" : "check")}</div>
                <h1 style="margin:0;font-size:28px;">${needsBeforePhoto ? "上传借出前照片" : "借用成功"}</h1>
                <p class="body-text" style="text-align:center;margin-top:10px;">${needsBeforePhoto ? "NFC 验证已完成。请上传借出前照片，保存后这次借用才正式生效。" : "借出前照片已保存，借用记录已经生效。"}</p>
              </div>
              ${equipmentImage(item, "detail-img")}<!-- [IMAGE-FN→detail-img] 借用确认页 -->
              <div class="detail-title" style="margin-top:14px;">
                <div>
                  <h1 style="font-size:24px;">${item.name}</h1>
                  <p>${item.assetId}</p>
                </div>
                ${tag(loanDisplayStatus(loan))}
              </div>
              <div class="info-list" style="margin-top:14px;">
                <div><span>借出时间</span><strong>${loan.borrowedAt}</strong></div>
                <div><span>借用时长</span><strong>${loan.durationLabel || "未设置"}</strong></div>
                <div><span>归还截止</span><strong>${loan.dueAt || "未设置"}</strong></div>
                <div><span>归还要求</span><strong>归还照片检测正常后，机器才可扫码归还</strong></div>
              </div>
              ${needsBeforePhoto ? `
                <label class="upload-real" style="margin-top:18px;">
                  ${icon("camera")} 上传借出前照片
                  <input id="borrowBeforePhotoInput" type="file" accept="image/*" capture="environment" />
                </label>
                <div id="borrowBeforePhotoName" class="photo-name">未选择借出前照片</div>
                <button class="primary-button" style="margin-top:16px;width:100%;" data-save-borrow-before="${loan.id}">${icon("check")} 保存并完成借用</button>
              ` : `
                <div class="button-row" style="margin-top:18px;">
                  <button class="secondary-button" data-detail="${item.id}">查看器材</button>
                  <button class="primary-button" data-route="borrow">我的借用</button>
                </div>
                <button class="primary-button" style="margin-top:10px;width:100%;" data-route="home">返回首页</button>
              `}
            </section>
          </main>
        `;
      }
      return shell("借用确认", body, { tabs: false });
    }

    function borrowPage() {
      const pending = pendingNfcLoans();
      const active = activeBorrowLoans();
      const history = store.loans.filter((loan) => !["等待NFC验证", "待补借出照片", "使用中", "待归还", "异常待归还"].includes(loan.status));
      const body = `
        <main class="scroll">
          ${pending.length ? `
          <div class="section-head"><h2>待 NFC 验证</h2></div>
          <div class="list-stack">${pending.map(pendingNfcCard).join("")}</div>
          ` : ""}
          <section class="action-panel" style="margin-bottom:14px;">
            <div>
              <h2>批量借出申请</h2>
              <p>多人活动或课堂用器材，先提交申请，管理员通过后再到机器批量借还。</p>
            </div>
            <button class="primary-button" data-route="batchBorrow">${icon("bag")} 去申请</button>
          </section>
          <div class="section-head"><h2>当前借用</h2></div>
          ${active.length ? active.map(loanCard).join("") : `<div class="empty">还没有进行中的借用。在器材详情页发起借用，获得验证码后前往场馆 NFC 机器完成验证。</div>`}
          <div class="section-head"><h2>历史记录</h2></div>
          <div class="timeline">${history.length ? history.map(historyRow).join("") : `<div class="empty">暂无历史记录。</div>`}</div>
        </main>
      `;
      return shell("我的借用", body);
    }

    function pendingNfcCard(loan) {
      const item = byId(loan.equipmentId);
      if (!item) return "";
      const expiresIn = loan.verificationCodeExpiresAt
        ? Math.max(0, Math.round((new Date(loan.verificationCodeExpiresAt).getTime() - Date.now()) / 60000))
        : 5;
      return `
        <section class="borrow-card" style="margin-bottom:14px;border-left:3px solid var(--brand);">
          <div class="borrow-head">
            ${equipmentImage(item, "loan-thumb")}
            <div>
              <h2>${item.name}</h2>
              <p style="font-size:13px;margin-top:4px;color:var(--brand);font-weight:800;">验证码：${loan.verificationCode || "------"}（${expiresIn} 分钟有效）</p>
              <p style="font-size:11px;margin-top:2px;">${loan.borrowedAt} · ${loan.durationLabel || ""}</p>
              ${tag(loanDisplayStatus(loan))}
            </div>
          </div>
          <div class="button-row" style="margin-top:10px;">
            <button class="secondary-button" data-view-code="${loan.id}" style="color:var(--brand);">${icon("scan")} 查看验证码</button>
            <button class="secondary-button" data-cancel-borrow="${loan.id}" style="color:var(--bad);">${icon("alert")} 取消借用</button>
          </div>
        </section>
      `;
    }

    function batchBorrowPage() {
      const available = store.equipment.filter((item) => item.status === "可借" && item.available > 0);
      const ownRequests = batchRequestList().filter((request) => request.userId === state.currentUserId);
      const formContent = available.length ? `
        <form class="batch-apply-panel" id="batchBorrowForm">
          <div>
            <h2 style="margin:0;font-size:22px;">选择批量器材</h2>
            <p class="body-text" style="margin-top:6px;">至少选择 2 件。管理员审批通过后，机器批量借出和归还按钮才会开放。</p>
          </div>
          <div class="duration-picker">
            <div class="duration-picker-head">
              <strong>借用时长</strong>
              <span>1 节课 = ${CLASS_PERIOD_MINUTES} 分钟</span>
            </div>
            <div class="duration-options">${borrowDurationOptions()}</div>
          </div>
          <div class="batch-equipment-list">${available.map(batchEquipmentOption).join("")}</div>
          <p class="batch-form-status" id="batchBorrowStatus"></p>
          <button class="primary-button" type="submit">${icon("check")} 提交申请</button>
        </form>
      ` : `<div class="empty">暂无可借器材。管理员录入并开放库存后，才能提交批量申请。</div>`;
      const body = `
        <main class="scroll">
          ${formContent}
          <div class="section-head"><h2>我的批量申请</h2></div>
          <div class="list-stack">${ownRequests.length ? ownRequests.map(studentBatchRequestCard).join("") : `<div class="empty">暂无批量申请。</div>`}</div>
        </main>
      `;
      return shell("批量申请", body, { tabs: false });
    }

    function batchEquipmentOption(item) {
      return `
        <article class="batch-equipment-option">
          <label class="batch-equipment-main">
            <input type="checkbox" data-batch-select="${escapeAttr(item.id)}" />
            <span class="list-media">${equipmentImage(item, "list-img")}</span><!-- [IMAGE-FN→list-img] 批量申请·器材选择 -->
            <span>
              <strong>${escapeHtml(item.name)}</strong>
              <small>可借 ${item.available} 件</small>
            </span>
          </label>
          <label class="batch-qty">
            <span>数量</span>
            <input type="number" min="1" max="${item.available}" step="1" value="1" inputmode="numeric" data-batch-qty="${escapeAttr(item.id)}" />
          </label>
        </article>
      `;
    }

    function batchRequestItemCount(request) {
      return (request.items || []).reduce((sum, item) => sum + Number(item.qty || 0), 0);
    }

    function batchRequestItemsHtml(request) {
      return `
        <div class="batch-item-list">
          ${(request.items || []).map((item) => `<span class="batch-item-line">${escapeHtml(item.name)} × ${Number(item.qty || 0)}</span>`).join("")}
        </div>
      `;
    }

    function batchRequestTitle(request) {
      return `
        <div class="batch-request-title">
          <strong>${escapeHtml(request.studentName || "未命名学生")} · ${escapeHtml(request.studentId || "未绑定学号")}</strong>
          <small>${escapeHtml(request.createdAt || "")}</small>
        </div>
      `;
    }

    function batchRequestMeta(request) {
      return `
        <div class="batch-request-meta">
          <span>${batchRequestItemCount(request)} 件</span>
          <span>${escapeHtml(request.durationLabel || borrowDurationLabel(request.durationPeriods))}</span>
          <span>${escapeHtml(request.adminNote || "等待流程更新")}</span>
        </div>
      `;
    }

    function studentBatchRequestCard(request) {
      const borrowAction = request.status === "已通过"
        ? `<button class="primary-button" data-batch-sync-borrow="${escapeAttr(request.id)}">${icon("bag")} 机器批量借出</button>`
        : "";
      const returnAction = request.status === "已借出"
        ? `<button class="primary-button" data-batch-sync-return="${escapeAttr(request.id)}">${icon("refresh")} 机器批量归还</button>`
        : "";
      const actions = borrowAction || returnAction
        ? `<div class="batch-request-actions">${borrowAction || ""}${returnAction || ""}<button class="secondary-button" data-route="borrow">${icon("clock")} 查看记录</button></div>`
        : `<p class="machine-hint" style="margin:0;">${batchStudentHint(request.status)}</p>`;
      return `
        <article class="batch-request-card">
          <div class="batch-request-head">
            ${batchRequestTitle(request)}
            ${tag(request.status)}
          </div>
          ${batchRequestMeta(request)}
          ${batchRequestItemsHtml(request)}
          ${actions}
        </article>
      `;
    }

    function batchStudentHint(status) {
      if (status === "待审核") return "申请已提交，等待管理员审批。";
      if (status === "已拒绝") return "管理员未通过这次申请，请调整后重新提交。";
      if (status === "待补照片") return "机器批量扫码已同步，请到我的借用里逐件上传借出前照片。";
      if (status === "已归还") return "这次批量借还已经完成。";
      return "管理员通过后才可以到机器批量借还。";
    }

    function renewPage() {
      const active = confirmedBorrowLoans().filter(canRenewLoan);
      const body = `
        <main class="scroll">
          <section class="action-panel">
            <div>
              <h2>选择要续借的器材</h2>
              <p>续借必须绑定具体借用记录，先点器材，再选择延长时长。</p>
            </div>
          </section>
          <div class="section-head"><h2>当前可续借</h2></div>
          <div class="list-stack">${active.length ? active.map(renewLoanCard).join("") : `<div class="empty">当前没有可续借的器材。请先完成借出同步。</div>`}</div>
        </main>
      `;
      return shell("申请续借", body, { tabs: false });
    }

    function renewLoanCard(loan) {
      const item = byId(loan.equipmentId);
      if (!item) return "";
      const renewable = canRenewLoan(loan);
      return `
        <section class="borrow-card" style="margin-bottom: 14px;">
          <div class="borrow-head">
            ${equipmentImage(item, "loan-thumb")}<!-- [IMAGE-FN→loan-thumb] 续借选择·当前借用卡片 -->
            <div>
              <h2>${item.name}</h2>
              <p style="font-size: 11px; margin-top:2px;">${item.assetId} · ${loan.borrowedAt}</p>
              <p style="font-size: 11px; margin-top:2px;">当前截止 ${loan.dueAt || "未设置"}</p>
              ${tag(loanDisplayStatus(loan))}
            </div>
          </div>
          <div class="button-row" style="margin-top: 14px;">
            <button class="secondary-button" data-detail="${item.id}">查看器材</button>
            <button class="primary-button" data-renew-loan="${loan.id}" ${renewable ? "" : "disabled"}>${icon("refresh")} 申请续借</button>
          </div>
          ${renewable ? "" : `<p class="machine-hint">这条记录已经进入归还或异常流程，不能再续借。</p>`}
        </section>
      `;
    }

    function renewDetailPage() {
      const loan = loanById(state.activeLoanId);
      if (!loan) {
        return shell("续借确认", `<main class="scroll"><div class="empty">未找到要续借的借用记录。</div></main>`, { tabs: false });
      }
      const item = byId(loan.equipmentId);
      if (!item) return shell("续借确认", `<main class="scroll"><div class="empty">未找到对应器材。</div></main>`, { tabs: false });
      const periods = selectedBorrowPeriods();
      const extensionLabel = borrowDurationLabel(periods);
      const newDueAtMs = renewedDueAtMs(loan, periods);
      const renewable = canRenewLoan(loan);
      const body = `
        <main class="scroll">
          <section class="result-card">
            ${equipmentImage(item, "detail-img")}<!-- [IMAGE-FN→detail-img] 续借确认页 -->
            <div class="detail-title" style="margin-top:14px;">
              <div>
                <h1 style="font-size:24px;">${item.name}</h1>
                <p>${item.assetId}</p>
              </div>
              ${tag(loanDisplayStatus(loan))}
            </div>
            <div class="info-list" style="margin-top:14px;">
              <div><span>借出时间</span><strong>${loan.borrowedAt}</strong></div>
              <div><span>当前截止</span><strong>${loan.dueAt || "未设置"}</strong></div>
              <div><span>续借时长</span><strong>${extensionLabel}</strong></div>
              <div><span>续借后截止</span><strong>${formatDueTime(newDueAtMs)}</strong></div>
            </div>
            <div class="duration-picker">
              <div class="duration-picker-head">
                <strong>选择续借时长</strong>
                <span>1 节课 = ${CLASS_PERIOD_MINUTES} 分钟</span>
              </div>
              <div class="duration-options">${borrowDurationOptions()}</div>
              <p class="machine-hint" style="margin:0;">续借会从当前截止时间继续往后算；如果已经超时，则从现在开始算。</p>
            </div>
            <button class="primary-button" data-submit-renew="${loan.id}" ${renewable ? "" : "disabled"}>${icon("refresh")} 提交续借申请</button>
            ${renewable ? "" : `<p class="machine-hint">这条记录当前不可续借，请按归还流程处理。</p>`}
          </section>
        </main>
      `;
      return shell("续借确认", body, { tabs: false });
    }

    function loanCard(loan) {
      const item = byId(loan.equipmentId);
      if (!item) return "";
      const pendingBeforePhoto = loanNeedsBeforePhoto(loan);
      const canReturn = loanCanMachineReturn(loan);
      const showCancel = loan.status === "待补借出照片";
      const primaryAction = pendingBeforePhoto
        ? `<button class="primary-button" data-borrow-confirm="${loan.id}">${icon("camera")} 上传借出前照片</button>`
        : canReturn
          ? `<button class="primary-button" data-sync-return="${loan.id}">${icon("bag")} 同步机器归还</button>`
          : loan.status === "异常待归还"
            ? `<button class="primary-button" data-result-loan="${loan.id}">${icon("alert")} 查看检测结果</button>`
            : `<button class="primary-button" data-loan-detect="${loan.id}">${icon("camera")} 归还检测</button>`;
      const buttons = [ `<button class="secondary-button" data-report-loan="${loan.id}">${icon("wrench")} 报损</button>` ];
      if (canRenewLoan(loan)) buttons.push(`<button class="secondary-button" data-renew-loan="${loan.id}">${icon("refresh")} 续借</button>`);
      if (showCancel) buttons.push(`<button class="secondary-button" data-cancel-borrow="${loan.id}" style="color:var(--bad);">${icon("alert")} 取消</button>`);
      buttons.push(primaryAction);
      return `
        <section class="borrow-card" style="margin-bottom: 14px;">
          <div class="borrow-head">
            ${equipmentImage(item, "loan-thumb")}
            <div>
              <h2>${item.name}</h2>
              <p style="font-size: 11px; margin-top:2px;">${item.assetId} · ${loan.borrowedAt}</p>
              <p style="font-size: 11px; margin-top:2px;">${loan.durationLabel || "未设置时长"} · 截止 ${loan.dueAt || "未设置"}</p>
              ${tag(loanDisplayStatus(loan))}
            </div>
          </div>
          <div class="button-row" style="grid-template-columns: repeat(${buttons.length}, minmax(0, 1fr)); margin-top: 14px;">
            ${buttons.join("")}
          </div>
        </section>
      `;
    }

    function historyRow(loan) {
      const item = byId(loan.equipmentId);
      if (!item) return `<div class="timeline-item"><strong>未知器材</strong><span>${loan.status} · ${loan.returnedAt || loan.borrowedAt}</span></div>`;
      const punctualText = loan.returnedOnTime === true ? "准时" : (loan.returnedOnTime === false ? "超时" : "未计入准时率");
      return `<div class="timeline-item"><strong>${item.name}</strong><span>${loan.status} · ${loan.returnedAt || loan.borrowedAt} · ${punctualText}</span></div>`;
    }

    function detectPage() {
      const loan = loanById(state.activeLoanId) || activeLoan();
      if (!loan) return shell("归还前检测", `<main class="scroll"><div class="empty">没有可检测的借用记录。</div></main>`);
      const item = byId(loan.equipmentId);
      if (!item) return shell("归还前检测", `<main class="scroll"><div class="empty">未找到对应器材。</div></main>`);
      if (!loan.beforePhotoDataUrl) {
        return shell("归还前检测", `
          <main class="scroll">
            <div class="empty">这条记录还没有借出前照片，不能做归还对比。</div>
            <div class="button-row" style="padding:0 18px;">
              <button class="primary-button" data-borrow-confirm="${loan.id}">${icon("camera")} 去上传借出前照片</button>
            </div>
          </main>
        `, { tabs: false });
      }
      const body = `
        <main class="scroll">
          <section class="camera-panel">
            <div class="camera-box">
              ${equipmentImage(item, "camera-img")}<!-- [IMAGE-FN→camera-img] 归还前检测 -->
              <span class="scan-line"></span>
            </div>
            <h1>归还前检测</h1>
            <p>上传归还照片，系统会和借出前照片对比。检测正常后，机器端才允许扫码归还。</p>
            <label class="upload-real">
              ${icon("camera")} 上传归还照片
              <input id="photoInput" type="file" accept="image/*" capture="environment" /><!-- [IMAGE-13] 用户拍摄/选择的归还检测照片（非静态资源） -->
            </label>
            <div id="photoName" class="photo-name">未选择归还照片</div>
          </section>
          <div class="button-row">
            <button class="primary-button" data-ai-detect="${loan.id}">${icon("camera")} 开始损耗检测</button>
          </div>
        </main>
      `;
      return shell("拍照检测", body, { tabs: false });
    }

    function resultPage() {
      const loan = loanById(state.activeLoanId);
      if (!loan) return shell("检测结果", `<main class="scroll"><div class="empty">暂无检测结果。</div></main>`);
      const item = byId(loan.equipmentId);
      if (!item) return shell("检测结果", `<main class="scroll"><div class="empty">未找到对应器材。</div></main>`);
      const result = parseDetectionResult(loan.detectResult);
      const abnormal = result.status === "异常";
      const canReturn = loanCanMachineReturn(loan);
      const body = `
        <main class="scroll">
          <section class="result-card">
            ${equipmentImage(item, "detail-img")}<!-- [IMAGE-FN→detail-img] 检测结果页 -->
            <div class="detail-title">
              <div>
                <h1>${abnormal ? "检测异常" : "检测正常"}</h1>
                <p>${escapeHtml(result.summary)}</p>
              </div>
              ${tag(loanDisplayStatus(loan))}
            </div>
            <div class="metric-row">
              ${metric(confidenceText(result.confidence), "可信度")}
              ${metric(result.riskLabel, "风险")}
              ${metric(String(result.issueCount), "问题点")}
            </div>
            ${result.issues.length ? `<p class="machine-hint">疑似问题：${result.issues.map(escapeHtml).join("、")}</p>` : ""}
            <p class="machine-hint">${canReturn ? "检测正常，系统已允许机器扫码归还。请到场馆机器完成归还后，再同步状态。" : "检测未通过，暂不允许机器扫码归还，请等待管理员复核。"}</p>
            ${canReturn
              ? `<button class="primary-button" data-sync-return="${loan.id}">${icon("bag")} 同步机器归还</button>`
              : `<div class="button-row">
                  <button class="secondary-button" data-loan-detect="${loan.id}">${icon("camera")} 重新上传照片</button>
                  <button class="primary-button" data-report-loan="${loan.id}">${icon("wrench")} 反馈给管理员</button>
                </div>
                <button class="secondary-button" data-route="home" style="margin-top:10px;">${icon("back")} 返回首页</button>`}
          </section>
        </main>
      `;
      return shell("检测结果", body, { tabs: false });
    }

    function reportPage() {
      const loan = loanById(state.activeLoanId) || activeLoan();
      const item = loan ? byId(loan.equipmentId) : byId(state.selectedId);
      if (!item) {
        return shell("报损反馈", `<main class="scroll"><div class="empty">暂无可报损器材。场馆或系统问题请先联系管理员。</div></main>`);
      }
      const locked = !!loan;
      const equipField = locked
        ? `<div class="field"><span>问题器材</span><div class="locked-equip">${item.name} · ${item.assetId}</div><input type="hidden" id="reportEquipment" value="${item.id}" /></div>`
        : `<label class="field"><span>问题器材</span><select id="reportEquipment">${store.equipment.map((eq) => `<option value="${eq.id}" ${eq.id === item.id ? "selected" : ""}>${eq.name} · ${eq.assetId}</option>`).join("")}</select></label>`;
      const body = `
        <main class="scroll">
          <form class="form-card" id="reportForm">
            ${equipField}
            <label class="field"><span>问题类型</span><select id="reportType">${issueOptionsFor(item.id)}</select></label>
            <label class="field"><span>问题说明</span><textarea id="reportDesc" placeholder="简单说明发现位置 and 使用场景"></textarea></label>
            <label class="upload-real">${icon("camera")} 上传照片<input id="reportPhoto" type="file" accept="image/*" capture="environment" /></label><!-- [IMAGE-14] 报损上传照片（非静态资源） -->
            <button class="primary-button" type="submit">${icon("wrench")} 提交报损</button>
          </form>
        </main>
      `;
      return shell("报损反馈", body);
    }

    function messagesPage() {
      const messages = Array.isArray(store.messages) ? store.messages : [];
      const body = `
        <main class="scroll">
          <div class="message-list">
            ${messages.length ? messages.map((message) => `
              <article class="message-item">
                <i>${icon("bell")}</i>
                <div>
                  <strong>${escapeHtml(message.title)}</strong>
                  <p>${escapeHtml(message.text)}</p>
                  <small>${escapeHtml(message.time)}</small>
                </div>
              </article>
            `).join("") : `<div class="empty">暂无消息。</div>`}
          </div>
        </main>
      `;
      return shell("消息", body);
    }

    function adminDashboardData() {
      const pending = store.workOrders.filter((order) => order.status !== "已完成");
      const waitingMessages = adminMessageList().filter((message) => message.status !== "已回复");
      const batchRequests = batchRequestList();
      const pendingBatchRequests = batchRequests.filter((request) => request.status === "待审核");
      const totalAvailable = store.equipment.reduce((sum, item) => sum + item.available, 0);
      const totalStock = store.equipment.reduce((sum, item) => sum + item.total, 0);
      const healthyCount = store.equipment.filter((item) => item.health >= 90).length;
      const maintenanceCount = store.equipment.filter((item) => item.status !== "可借").length;
      const progress = adminProgressMetrics();
      const filteredEquipment = filteredAdminEquipmentList();
      const syncLogs = machineSyncLogList();
      const operationLogs = adminOperationLogList();
      const equipmentDesc = store.equipment.length
        ? `当前 ${totalAvailable}/${totalStock} 件可借，${healthyCount} 类器材健康度良好。`
        : "暂无器材，先录入后学生端才会显示。";
      const equipmentStatus = store.equipment.length ? `${maintenanceCount} 需关注` : "未录入";
      const equipmentContent = `
        ${adminNfcScanForm()}
        <div class="list-stack">
          ${filteredEquipment.length ? filteredEquipment.map(adminEquipmentRow).join("") : `<div class="empty">暂无器材。请用上方 NFC 扫描录入。</div>`}
        </div>
      `;
      return {
        pending,
        waitingMessages,
        batchRequests,
        pendingBatchRequests,
        totalAvailable,
        totalStock,
        progress,
        filteredEquipment,
        syncLogs,
        operationLogs,
        equipmentDesc,
        equipmentStatus,
        equipmentContent,
      };
    }

    function adminModuleCards(data) {
      return [
        ["batch", "批量申请", data.pendingBatchRequests.length],
        ["messages", "学生留言", data.waitingMessages.length],
        ["orders", "报修工单", data.pending.length],
        ["equipment", "器材档案", store.equipment.length],
        ["syncLogs", "同步记录", data.syncLogs.length],
        ["logs", "操作记录", data.operationLogs.length],
        ["venues", "场馆管理", (store.venues || []).length],
        ["export", "数据导出", 3],
      ];
    }

    function adminModuleDetails(data) {
      return {
        venues: {
          title: "场馆管理",
          desc: "添加体育场馆，并控制开放/关闭状态。",
          status: `${(store.venues || []).filter((v) => v.open).length} 开放`,
          content: adminVenueManager(),
        },
        export: {
          title: "数据导出",
          desc: "导出库存、机器同步和管理员操作，方便盘点交接。",
          status: "CSV",
          content: adminExportTools(),
        },
        batch: {
          title: "批量申请",
          desc: "审批通过后，学生才能在机器批量借还。",
          status: `${data.pendingBatchRequests.length} 待审批`,
          content: data.batchRequests.length ? data.batchRequests.map(adminBatchRequestCard).join("") : `<div class="empty">暂无批量申请。</div>`,
        },
        messages: {
          title: "学生留言",
          desc: "优先处理未回复咨询，回复后会同步到学生端。",
          status: `${data.waitingMessages.length} 待回复`,
          content: adminMessageList().length ? adminMessageList().map(adminContactCard).join("") : `<div class="empty">暂无学生留言。</div>`,
        },
        orders: {
          title: "报修工单",
          desc: "跟踪器材异常、暂停借出和维修完成状态。",
          status: `${data.pending.length} 待处理`,
          content: store.workOrders.length ? store.workOrders.map(orderCard).join("") : `<div class="empty">暂无工单。学生提交异常后会出现在这里。</div>`,
        },
        equipment: {
          title: "器材档案",
          desc: data.equipmentDesc,
          status: data.equipmentStatus,
          content: data.equipmentContent,
        },
        syncLogs: {
          title: "机器入库同步记录",
          desc: "记录机器端入库同步结果，重复芯片不会重复增加库存。",
          status: `${data.syncLogs.length} 条`,
          content: data.syncLogs.length ? data.syncLogs.slice(0, 12).map(adminMachineSyncLogCard).join("") : `<div class="empty">暂无机器同步记录。</div>`,
        },
        logs: {
          title: "操作记录",
          desc: "记录管理员录入、审批、维修、导出等关键动作。",
          status: `${data.operationLogs.length} 条`,
          content: data.operationLogs.length ? data.operationLogs.slice(0, 16).map(adminOperationLogCard).join("") : `<div class="empty">暂无管理员操作记录。</div>`,
        },
      };
    }

    function adminPage() {
      const data = adminDashboardData();
      const body = `
        <main class="scroll">
          <section class="admin-hero admin-dashboard-hero">
            <div class="admin-ring-top">
              <div>
                <p class="admin-overline">今日运营</p>
                <h1>管理员工作台</h1>
                <p class="admin-ring-summary">留言·任务·库存实时计算</p>
              </div>
              <span class="admin-ring-mode">实时</span>
            </div>
            <div class="admin-ring-stage">
              ${adminActivityRing(data.progress)}
            </div>
          </section>
          ${adminQuickNav(adminModuleCards(data))}
          <div class="admin-kpi-grid">
            ${adminKpi("待回复", data.waitingMessages.length, "条", "message")}
            ${adminKpi("待审批", data.pendingBatchRequests.length, "单", "check")}
            ${adminKpi("可借总量", data.totalAvailable, "件", "bag")}
          </div>
        </main>
      `;
      if (!state.isAdmin) {
        const body = `
          <main class="scroll">
            <section class="admin-hero">
              <h1>管理员未授权</h1>
              <p>这个账号已经登录，但还没有加入管理员名单。</p>
            </section>
            <section class="profile-settings identity-form">
              <p class="identity-hint">把下面这个 UID 复制到 Supabase 的 <strong>admin_users</strong> 表里，再重新登录管理员端。</p>
              <div class="field">
                <span>当前账号 UID</span>
                <input value="${escapeAttr(state.currentUserId || "")}" readonly />
              </div>
            </section>
          </main>
        `;
        return shell("管理员端", body, { left: "none", right: "logout", tabs: false, admin: true });
      }
      return shell("管理员端", body, { left: "none", right: "logout", tabs: false, admin: true });
    }

    function adminModulePage(key) {
      if (!state.isAdmin) return adminPage();
      const data = adminDashboardData();
      const details = adminModuleDetails(data);
      const current = details[key] || details.batch;
      const body = `
        <main class="scroll admin-module-scroll">
          ${adminSection(key, current.title, current.desc, current.status, current.content)}
        </main>
      `;
      return shell(current.title, body, { left: "back", right: "logout", tabs: false, admin: true });
    }

    function boundedPercent(value) {
      return Math.max(0, Math.min(100, Math.round(Number(value) || 0)));
    }

    function percentOf(done, total) {
      if (total === 0) return 0;
      return boundedPercent((done / total) * 100);
    }

    function adminProgressMetrics() {
      const messages = adminMessageList();
      const batchRequests = batchRequestList();
      const repliedMessages = messages.filter((message) => message.status === "已回复").length;
      const completedOrders = store.workOrders.filter((order) => order.status === "已完成").length;
      const finishedBatchRequests = batchRequests.filter((request) => request.status !== "待审核").length;
      const taskTotal = store.workOrders.length + batchRequests.length;
      const taskDone = completedOrders + finishedBatchRequests;
      const totalStock = store.equipment.reduce((sum, item) => sum + item.total, 0);
      const totalAvailable = store.equipment.reduce((sum, item) => sum + item.available, 0);
      const messageRate = messages.length ? percentOf(repliedMessages, messages.length) : 100;
      const workRate = taskTotal ? percentOf(taskDone, taskTotal) : 100;
      const stockRate = totalStock ? percentOf(totalAvailable, totalStock) : 0;
      return {
        messageRate,
        workRate,
        stockRate,
        overallRate: boundedPercent((messageRate + workRate + stockRate) / 3),
      };
    }

    function adminRingStyle(metrics) {
      return `--message-rate: ${metrics.messageRate}%; --work-rate: ${metrics.workRate}%; --stock-rate: ${metrics.stockRate}%;`;
    }

    function adminActivityRing(metrics) {
      return `
        <div class="admin-activity-ring" style="${escapeAttr(adminRingStyle(metrics))}" role="img" aria-label="管理员运营完成度 ${metrics.overallRate}%">
          <span class="admin-ring-layer admin-ring-message"></span>
          <span class="admin-ring-layer admin-ring-work"></span>
          <span class="admin-ring-layer admin-ring-stock"></span>
          <div class="admin-ring-center">
            <strong>${metrics.overallRate}%</strong>
            <span>完成度</span>
          </div>
        </div>
        <div class="admin-ring-legend">
          <span class="admin-ring-legend-item is-message">留言<b>${metrics.messageRate}%</b></span>
          <span class="admin-ring-legend-item is-work">任务<b>${metrics.workRate}%</b></span>
          <span class="admin-ring-legend-item is-stock">库存<b>${metrics.stockRate}%</b></span>
        </div>
      `;
    }

    function adminKpi(label, value, unit, iconName) {
      return `
        <article class="admin-kpi-card is-compact">
          <i class="admin-kpi-icon">${icon(iconName)}</i>
          <div>
            <small>${escapeHtml(label)}</small>
            <strong>${value}<span>${escapeHtml(unit)}</span></strong>
          </div>
        </article>
      `;
    }

    function adminNfcScanForm() {
      const options = store.equipment.map((item) =>
        `<option value="${escapeAttr(item.id)}">${escapeHtml(item.name)}</option>`
      ).join("");
      return `
        <form class="admin-machine-sync-card" id="adminNfcScanForm">
          <div class="admin-machine-sync-head">
            <div>
              <h3>NFC 扫描录入器材</h3>
              <p>选择器材种类，然后扫描 NFC 标签自动录入 UID 并增加库存。</p>
            </div>
            <span class="admin-equipment-chip" id="adminNfcStatus">就绪</span>
          </div>
          <div style="display:grid;gap:12px;">
            <label class="field" style="margin:0;">
              <span>器材种类</span>
              <select id="adminNfcEquipment" style="color:#fff;background:#1a1a2e;border:1px solid rgba(255,255,255,0.3);border-radius:12px;padding:12px;font-size:16px;width:100%;min-height:48px;appearance:auto;-webkit-appearance:auto;">${options}</select>
            </label>
            <button class="primary-button" type="submit" id="adminNfcScanBtn">${icon("scan")} 扫描 NFC 标签</button>
          </div>
          <p style="margin:10px 0 0;color:var(--muted);font-size:12px;" id="adminNfcResult"></p>
        </form>
      `;
    }

    function adminExportTools() {
      return `
        <article class="admin-tool-card">
          <div class="admin-tool-head">
            <div>
              <h3>导出管理数据</h3>
              <p>生成 CSV 文件，可用表格软件打开。</p>
            </div>
            <span class="admin-equipment-chip">本地生成</span>
          </div>
          <div class="admin-export-actions">
            <button class="secondary-button" type="button" data-admin-export="equipment">${icon("file")} 库存</button>
            <button class="secondary-button" type="button" data-admin-export="sync">${icon("refresh")} 同步</button>
            <button class="secondary-button" type="button" data-admin-export="logs">${icon("file")} 操作</button>
          </div>
        </article>
      `;

    function adminVenueManager() {
      const venues = Array.isArray(store.venues) ? store.venues : [];
