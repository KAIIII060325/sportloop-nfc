<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#9f1239">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-title" content="SportLoop">
  <link rel="manifest" href="manifest.webmanifest">
  <link rel="preload" as="image" href="assets/hero.png?v=12">
  <link rel="apple-touch-icon" href="assets/app-icon.png?v=12">
  <title>SportLoop</title>
  <style>
    /* ==================== 1. 用户的 STYLES.CSS 原样导入 ==================== */
    :root {
      --brand: #9f1239;
      --brand-deep: #6f0b27;
      --brand-soft: #fff1f4;
      --ink: #121016;
      --muted: #6f6870;
      --subtle: #9c949b;
      --line: #eadde1;
      --bg: #fbf8f8;
      --card: rgba(255, 255, 255, 0.88);
      --ok: #167444;
      --ok-bg: #e7f6ee;
      --warn: #b45d08;
      --warn-bg: #fff2df;
      --bad: #a10f2b;
      --bad-bg: #ffe6ec;
      --shadow: 0 14px 38px rgba(92, 12, 34, 0.13);
      --shadow-soft: 0 8px 22px rgba(92, 12, 34, 0.08);
      --radius-sm: 10px;
      --radius-md: 18px;
      --radius-lg: 28px;
      --tab-h: 66px;
      font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "PingFang SC", "Microsoft YaHei", Arial, sans-serif;
    }

    * {
      box-sizing: border-box;
    }

    html {
      background: var(--bg);
    }

    body {
      margin: 0;
      min-height: 100vh;
      color: var(--ink);
      background:
        radial-gradient(circle at 20% 8%, rgba(159, 18, 57, 0.12), transparent 28%),
        linear-gradient(135deg, #ffffff 0%, #fff7f8 46%, #f5f1ef 100%);
    }

    :where(.page-title, .brand span, .tag, .chip, .text-button, .primary-button, .secondary-button,
      .segmented button, .tab-button span, .kpi span, .metric span, .field > span,
      .profile-stat-label, .profile-shortcut strong, .profile-setting-row strong,
      .profile-setting-row span, .new-stat-label, .new-stat-val, .flow span) {
      word-break: keep-all;
      white-space: nowrap;
    }

    :where(.body-text, .machine-hint, .message-item p, .order-card p, .role-card p,
      .feedback-card-text p, .empty, .borrow-card p) {
      overflow-wrap: anywhere;
    }

    button,
    input,
    select,
    textarea {
      font: inherit;
    }

    button {
      border: 0;
      cursor: pointer;
    }

    button:disabled {
      opacity: 0.45;
      cursor: not-allowed;
    }

    button:focus-visible,
    input:focus-visible,
    select:focus-visible,
    textarea:focus-visible {
      outline: 3px solid rgba(159, 18, 57, 0.25);
      outline-offset: 2px;
    }

    svg {
      width: 24px;
      height: 24px;
    }

    .stage {
      min-height: 100dvh;
      display: grid;
      grid-template-columns: 1fr;
      align-items: start;
      justify-content: center;
      padding: 0;
    }

    .phone-shell {
      display: flex;
      justify-content: center;
      transform: none;
    }

    .phone-frame {
      width: 100%;
      height: 100dvh;
      padding: 0;
      border-radius: 0;
      background: transparent;
      box-shadow: none;
    }

    .phone-screen {
      position: relative;
      width: 100%;
      height: 100%;
      overflow: hidden;
      border-radius: 0;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(251, 248, 248, 0.96)),
        linear-gradient(135deg, rgba(159, 18, 57, 0.08), transparent 34%);
    }

    .app {
      position: absolute;
      inset: 0;
      padding-top: calc(18px + env(safe-area-inset-top));
    }

    .app.is-admin-view {
      background:
        radial-gradient(circle at 12% 12%, rgba(122, 103, 168, 0.18), transparent 28%),
        radial-gradient(circle at 86% 70%, rgba(196, 107, 130, 0.08), transparent 32%),
        linear-gradient(180deg, #181620 0%, #211c2b 54%, #17151e 100%);
    }

    .screen {
      position: relative;
      height: 100%;
      display: flex;
      flex-direction: column;
    }

    .screen.admin-shell {
      color: rgba(255, 255, 255, 0.92);
      background:
        radial-gradient(circle at 12% 12%, rgba(122, 103, 168, 0.18), transparent 28%),
        radial-gradient(circle at 86% 70%, rgba(196, 107, 130, 0.08), transparent 32%),
        linear-gradient(180deg, #181620 0%, #211c2b 54%, #17151e 100%);
    }

    .admin-shell .topbar {
      color: #ffffff;
    }

    .admin-shell .page-title {
      color: #ffffff;
    }

    .admin-shell .icon-button {
      color: #ffffff;
      border-color: rgba(255, 255, 255, 0.14);
      background: rgba(255, 255, 255, 0.08);
      box-shadow: 0 12px 30px rgba(36, 26, 31, 0.24);
      backdrop-filter: blur(14px);
    }

    .scroll {
      flex: 1;
      overflow-y: auto;
      padding: 0 22px calc(var(--tab-h) + 34px + env(safe-area-inset-bottom));
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }

    .scroll::-webkit-scrollbar {
      display: none;
    }

    .topbar,
    .home-top {
      min-height: 58px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 0 22px 12px;
    }

    .page-title {
      min-width: 0;
      overflow: hidden;
      font-size: clamp(16px, 4.5vw, 19px);
      font-weight: 800;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 9px;
      min-width: 0;
      font-weight: 800;
    }

    .brand span {
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .brand img {
      width: 32px;
      height: 32px;
      border-radius: 50%;
    }

    .icon-button,
    .avatar {
      width: 46px;
      height: 46px;
      display: grid;
      place-items: center;
      flex: 0 0 46px;
      color: var(--ink);
      border: 1px solid rgba(234, 221, 225, 0.9);
      border-radius: 17px;
      background: rgba(255, 255, 255, 0.78);
      box-shadow: var(--shadow-soft);
      transition: transform 180ms ease, background 180ms ease;
    }

    /* [IMAGE-12] 用户头像占位（CSS 渐变；可改为 background-image: url('头像.png')） */
    .avatar {
      border-radius: 50%;
      background:
        radial-gradient(circle at 50% 34%, #c9bbc1 0 20%, transparent 21%),
        radial-gradient(circle at 50% 82%, #c9bbc1 0 34%, transparent 35%),
        #fff7f8;
    }

    .avatar.big {
      width: 64px;
      height: 64px;
    }

    .icon-button:active,
    .equipment-card:active,
    .list-card:active,
    .primary-button:active,
    .secondary-button:active,
    .chip:active,
    .tab-button:active,
    .text-button:active {
      transform: scale(0.97);
    }

    .toast {
      position: absolute;
      z-index: 90;
      top: 72px;
      left: 50%;
      max-width: calc(100% - 44px);
      transform: translateX(-50%);
      padding: 10px 14px;
      color: #ffffff;
      border-radius: 999px;
      background: rgba(18, 16, 22, 0.88);
      box-shadow: var(--shadow);
      font-size: 13px;
      line-height: 1.45;
      white-space: normal;
      overflow-wrap: anywhere;
    }

    .hero-card {
      position: relative;
      min-height: 282px;
      overflow: hidden;
      display: grid;
      grid-template-columns: 48% 52%;
      padding: 0;
      border-radius: 32px;
      color: #ffffff;
      border: 1px solid rgba(159, 18, 57, 0.18);
      background: #fffafa;
      box-shadow: 0 22px 48px rgba(111, 11, 39, 0.24);
    }

    .hero-card::before {
      content: "";
      position: absolute;
      inset: 0 auto 0 0;
      z-index: 0;
      width: 52%;
      background:
        radial-gradient(circle at 16% 10%, rgba(255, 255, 255, 0.2), transparent 26%),
        linear-gradient(145deg, #6f0b27 0%, #9f1239 62%, #b9163f 100%);
    }

    .hero-card::after {
      content: "";
      position: absolute;
      inset: 0 0 0 46%;
      z-index: 1;
      pointer-events: none;
      background: linear-gradient(90deg, rgba(111, 11, 39, 0.24), rgba(255, 250, 250, 0.1) 24%, rgba(255, 250, 250, 0));
    }

    .hero-copy {
      position: relative;
      z-index: 2;
      max-width: none;
      padding: 24px 18px 22px 20px;
      text-shadow: 0 2px 12px rgba(60, 0, 18, 0.18);
    }

    .eyebrow {
      margin: 0 0 8px;
      font-size: 12px;
      font-weight: 800;
      color: currentColor;
      opacity: 0.72;
    }

    .hero-card h1,
    .admin-hero h1,
    .detail-title h1,
    .result-card h1,
    .camera-panel h1,
    .profile-head h1 {
      margin: 0;
      font-size: 32px;
      line-height: 1.12;
      letter-spacing: 0;
    }

    .hero-card p:not(.eyebrow),
    .admin-hero p,
    .body-text,
    .camera-panel p,
    .detail-title p,
    .profile-head p {
      margin: 10px 0 0;
      line-height: 1.65;
      color: inherit;
      opacity: 0.78;
    }

    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      margin: 14px 0;
    }

    .kpi {
      min-height: 92px;
      padding: 14px 12px;
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      background: var(--card);
      box-shadow: var(--shadow-soft);
    }

    .kpi span,
    .kpi small,
    .metric span,
    .list-card small,
    .equipment-card small,
    .machine-item small,
    .timeline-item span,
    .message-item small,
    .order-card p {
      color: var(--muted);
    }

    .kpi strong {
      display: block;
      margin-top: 8px;
      font-size: 28px;
      font-family: "DIN Alternate", "SF Pro Display", Arial, sans-serif;
    }

    .kpi small {
      margin-left: 2px;
      font-size: 13px;
    }

    .action-panel,
    .active-loan,
    .detail-card,
    .borrow-card,
    .machine-card,
    .camera-panel,
    .result-card,
    .form-card,
    .profile-card,
    .admin-hero,
    .order-card {
      border: 1px solid var(--line);
      border-radius: var(--radius-lg);
      background: var(--card);
      box-shadow: var(--shadow-soft);
    }

    .action-panel {
      display: grid;
      gap: 16px;
      padding: 18px;
    }

    .action-panel h2,
    .section-head h2,
    .active-loan h2,
    .borrow-card h2 {
      margin: 0;
      font-size: 20px;
    }

    .action-panel p,
    .active-loan p,
    .borrow-card p,
    .empty {
      margin: 8px 0 0;
      color: var(--muted);
      line-height: 1.6;
    }

    .active-loan {
      display: grid;
      grid-template-columns: 98px 1fr;
      gap: 14px;
      align-items: center;
      padding: 16px;
    }

    /* [IMAGE-CSS-loan-thumb] [IMAGE-CSS-order-img] 借用卡片 / 工单单图尺寸 */
    .loan-thumb,
    .order-img {
      width: 92px;
      height: 78px;
      object-fit: contain;
    }

    .section-head,
    .list-meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      margin: 20px 0 12px;
    }

    .text-button {
      min-height: 44px;
      display: inline-flex;
      align-items: center;
      gap: 4px;
      color: var(--brand);
      background: transparent;
      font-weight: 800;
    }

    .equipment-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .equipment-card {
      min-height: 178px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      padding: 13px;
      text-align: left;
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      background: var(--card);
      box-shadow: var(--shadow-soft);
    }

    /* [IMAGE-CSS-item-img] 器材图：首页热门网格尺寸 */
    .item-img {
      width: 100%;
      height: 100px;
      object-fit: contain;
    }

    .equipment-card strong,
    .list-card strong,
    .message-item strong,
    .order-card strong,
    .machine-item strong {
      display: block;
      min-width: 0;
      overflow: hidden;
      font-size: clamp(13px, 3.8vw, 15px);
      line-height: 1.25;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .equipment-card small,
    .list-card small,
    .machine-item small {
      display: block;
      margin-top: 5px;
      overflow: hidden;
      font-size: clamp(10.5px, 3.2vw, 12px);
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .tag {
      display: inline-flex;
      align-items: center;
      width: fit-content;
      min-height: 24px;
      margin-top: 8px;
      padding: 3px 8px;
      border-radius: 7px;
      font-size: clamp(10.5px, 3vw, 12px);
      font-weight: 800;
    }

    .tag.ok {
      color: var(--ok);
      background: var(--ok-bg);
    }

    .tag.warn {
      color: var(--warn);
      background: var(--warn-bg);
    }

    .tag.bad {
      color: var(--bad);
      background: var(--bad-bg);
    }

    .flow {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 7px;
      padding: 14px;
      border: 1px solid var(--line);
      border-radius: var(--radius-lg);
      background: var(--card);
      box-shadow: var(--shadow-soft);
    }

    .flow div {
      text-align: center;
      font-size: clamp(9px, 2.8vw, 11px);
      line-height: 1.35;
    }

    .flow span {
      display: block;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .flow i {
      width: 42px;
      height: 42px;
      display: grid;
      place-items: center;
      margin: 0 auto 6px;
      color: var(--brand);
      border-radius: 50%;
      background: var(--brand-soft);
    }

    .flow b {
      display: grid;
      place-items: center;
      width: 18px;
      height: 18px;
      margin: -10px auto 5px;
      color: #ffffff;
      border-radius: 50%;
      background: var(--brand);
      font-size: 10px;
    }

    .search-row {
      padding: 0 22px 14px;
    }

    .search-box {
      position: relative;
      display: block;
    }

    .search-box svg {
      position: absolute;
      left: 15px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--muted);
    }

    .search-box input {
      width: 100%;
      height: 54px;
      padding: 0 16px 0 48px;
      border: 1px solid var(--line);
      border-radius: 18px;
      color: var(--ink);
      background: var(--card);
      box-shadow: var(--shadow-soft);
    }

    .chips {
      display: flex;
      gap: 10px;
      overflow-x: auto;
      padding-bottom: 4px;
      scrollbar-width: none;
    }

    .chips::-webkit-scrollbar {
      display: none;
    }

    .chip {
      min-height: 44px;
      flex: 0 0 auto;
      padding: 0 clamp(13px, 4vw, 17px);
      color: var(--ink);
      font-size: clamp(12px, 3.5vw, 14px);
      border: 1px solid var(--line);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.75);
      box-shadow: var(--shadow-soft);
    }

    .chip.active {
      color: #ffffff;
      border-color: transparent;
      background: linear-gradient(145deg, var(--brand), var(--brand-deep));
    }

    .list-stack,
    .timeline,
    .message-list,
    .admin-list {
      display: grid;
      gap: 10px;
    }

    .list-card {
      width: 100%;
      min-height: 116px;
      display: grid;
      grid-template-columns: 112px minmax(0, 1fr) auto;
      align-items: center;
      gap: 12px;
      padding: 12px;
      overflow: hidden;
      text-align: left;
      color: var(--ink);
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      background: var(--card);
      box-shadow: var(--shadow-soft);
    }

    .list-card.static {
      cursor: default;
    }

    .list-card > span:not(.list-media) {
      min-width: 0;
    }

    .list-media {
      position: relative;
      width: 112px;
      height: 86px;
      display: grid;
      place-items: center;
      flex: 0 0 112px;
      overflow: hidden;
      border-radius: 14px;
      background: #ffffff;
    }

    /* [IMAGE-CSS-list-img] 器材图：列表/管理员档案缩略图尺寸 */
    .list-img {
      display: block;
      width: 92px;
      height: 72px;
      object-fit: contain;
      object-position: center;
      margin: auto;
    }

    .detail-card,
    .result-card {
      padding: 18px;
    }

    /* [IMAGE-CSS-detail-img] 器材图：详情页/借用确认/检测结果大图尺寸 */
    .detail-img {
      width: 100%;
      height: 228px;
      object-fit: contain;
      border-radius: 22px;
      background: linear-gradient(145deg, rgba(159, 18, 57, 0.08), rgba(255, 255, 255, 0.7));
    }

    .detail-title {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
      margin-top: 14px;
    }

    .metric-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin: 16px 0;
    }

    .metric {
      padding: 13px 8px;
      text-align: center;
      border: 1px solid var(--line);
      border-radius: var(--radius-sm);
      background: rgba(255, 255, 255, 0.65);
    }

    .metric strong {
      display: block;
      margin-bottom: 4px;
      font-size: clamp(20px, 5.6vw, 22px);
      font-family: "DIN Alternate", "SF Pro Display", Arial, sans-serif;
      white-space: nowrap;
    }

    .metric span {
      font-size: clamp(12px, 3.5vw, 14px);
    }

    .info-list {
      display: grid;
      gap: 9px;
      margin: 16px 0;
    }

    .info-list div,
    .timeline-item {
      padding: 12px clamp(9px, 3vw, 13px);
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      background: rgba(255, 255, 255, 0.7);
    }

    .info-list div {
      display: grid;
      grid-template-columns: max-content minmax(0, 1fr);
      align-items: center;
      column-gap: clamp(9px, 3vw, 16px);
      min-height: 58px;
    }

    .info-list span {
      color: var(--muted);
      line-height: 1.35;
      white-space: nowrap;
    }

    .info-list strong {
      min-width: 0;
      font-size: clamp(11.8px, 3.05vw, 14.5px);
      line-height: 1.45;
      text-align: right;
      text-wrap: balance;
      overflow-wrap: anywhere;
      white-space: normal;
    }

    .duration-picker {
      display: grid;
      gap: 10px;
      margin: 16px 0;
      padding: 14px;
      border: 1px solid rgba(159, 18, 57, 0.12);
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.74);
      box-shadow: var(--shadow-soft);
    }

    .duration-picker-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
    }

    .duration-picker-head strong {
      font-size: clamp(14px, 3.9vw, 15px);
    }

    .duration-picker-head span {
      color: var(--muted);
      font-size: clamp(11px, 3.2vw, 12px);
      white-space: nowrap;
    }

    .duration-options {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
    }

    .duration-option {
      min-height: 64px;
      display: grid;
      align-content: center;
      gap: 4px;
      padding: 9px 6px;
      color: var(--ink);
      border: 1px solid var(--line);
      border-radius: 14px;
      background: #ffffff;
    }

    .duration-option strong {
      font-size: clamp(14px, 4.2vw, 16px);
      line-height: 1;
      white-space: nowrap;
    }

    .duration-option span {
      color: var(--muted);
      font-size: clamp(10px, 3vw, 11px);
      white-space: nowrap;
    }

    .duration-option.active {
      color: #ffffff;
      border-color: transparent;
      background: linear-gradient(145deg, var(--brand), var(--brand-deep));
      box-shadow: 0 12px 20px rgba(159, 18, 57, 0.2);
    }

    .duration-option.active span {
      color: rgba(255, 255, 255, 0.76);
    }

    .batch-apply-panel,
    .batch-request-card {
      display: grid;
      gap: 14px;
      padding: 16px;
      border: 1px solid rgba(159, 18, 57, 0.1);
      border-radius: 22px;
      background: rgba(255, 255, 255, 0.94);
      box-shadow: var(--shadow-soft);
    }

    .batch-apply-panel .duration-picker {
      margin: 0;
    }

    .batch-equipment-list {
      display: grid;
      gap: 10px;
    }

    .batch-equipment-option {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 78px;
      gap: 10px;
      align-items: center;
      padding: 10px;
      border: 1px solid var(--line);
      border-radius: 18px;
      background: rgba(255, 250, 252, 0.78);
    }

    .batch-equipment-main {
      min-width: 0;
      display: grid;
      grid-template-columns: 22px 72px minmax(0, 1fr);
      align-items: center;
      gap: 10px;
    }

    .batch-equipment-main input {
      width: 18px;
      height: 18px;
      accent-color: var(--brand);
    }

    .batch-equipment-main .list-media {
      width: 72px;
      height: 58px;
      border-radius: 12px;
    }

    .batch-equipment-main .list-img {
      width: 58px;
      height: 46px;
    }

    .batch-equipment-main strong,
    .batch-request-title strong {
      display: block;
      min-width: 0;
      overflow: hidden;
      color: var(--ink);
      font-size: clamp(14px, 4vw, 16px);
      line-height: 1.25;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .batch-equipment-main small,
    .batch-request-title small,
    .batch-item-line {
      display: block;
      min-width: 0;
      overflow-wrap: anywhere;
      color: var(--muted);
      font-size: clamp(10px, 3vw, 12px);
      line-height: 1.35;
    }

    .batch-qty {
      display: grid;
      gap: 5px;
      color: var(--muted);
      font-size: 11px;
      font-weight: 800;
    }

    .batch-qty input {
      width: 100%;
      height: 38px;
      padding: 0 8px;
      color: var(--ink);
      border: 1px solid var(--line);
      border-radius: 12px;
      background: #ffffff;
      font-size: 15px;
      font-weight: 900;
      text-align: center;
    }

    .batch-request-card {
      margin-bottom: 12px;
    }

    .batch-request-head {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: start;
      gap: 10px;
    }

    .batch-request-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 8px;
    }

    .batch-request-meta span {
      min-height: 26px;
      display: inline-flex;
      align-items: center;
      padding: 0 9px;
      border-radius: 999px;
      color: var(--brand);
      background: var(--brand-soft);
      font-size: 11px;
      font-weight: 850;
      white-space: nowrap;
    }

    .batch-item-list {
      display: grid;
      gap: 6px;
      padding: 10px;
      border-radius: 16px;
      background: rgba(159, 18, 57, 0.045);
    }

    .batch-request-actions {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
    }

    .batch-request-actions .primary-button,
    .batch-request-actions .secondary-button {
      min-height: 42px;
      border-radius: 14px;
      font-size: clamp(11px, 3.2vw, 13px);
    }

    .batch-form-status {
      min-height: 18px;
      margin: 0;
      color: var(--brand);
      font-size: 12px;
      font-weight: 850;
      line-height: 1.35;
    }

    @media (max-width: 390px) {
      .batch-equipment-option {
        grid-template-columns: 1fr;
      }

      .batch-equipment-main {
        grid-template-columns: 22px 64px minmax(0, 1fr);
      }

      .batch-equipment-main .list-media {
        width: 64px;
        height: 52px;
      }

      .batch-qty {
        grid-template-columns: auto 96px;
        align-items: center;
        justify-content: space-between;
      }
    }

    .primary-button,
    .secondary-button {
      min-height: 52px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      min-width: 0;
      width: 100%;
      padding: 0 clamp(10px, 3.8vw, 16px);
      border-radius: 17px;
      font-size: clamp(13px, 3.8vw, 16px);
      font-weight: 850;
      transition: transform 180ms ease, opacity 180ms ease;
    }

    .primary-button {
      color: #ffffff;
      background: linear-gradient(145deg, #c91946, #8c102e);
      box-shadow: 0 16px 28px rgba(159, 18, 57, 0.22);
    }

    .secondary-button {
      color: var(--brand);
      border: 1px solid rgba(159, 18, 57, 0.18);
      background: rgba(255, 255, 255, 0.8);
    }

    .primary-button:disabled,
    .secondary-button:disabled {
      cursor: not-allowed;
      opacity: 0.48;
      box-shadow: none;
    }

    .button-row {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      margin-top: 14px;
    }

    .loan-action-row {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .button-row .primary-button,
    .button-row .secondary-button {
      font-size: clamp(12px, 3.5vw, 15px);
    }

    .machine-card {
      padding: 18px;
    }

    .machine-visual {
      height: 260px;
      display: grid;
      place-items: center;
      text-align: center;
      color: #ffffff;
      border-radius: 24px;
      background:
        radial-gradient(circle at 50% 38%, rgba(255, 255, 255, 0.18), transparent 28%),
        linear-gradient(145deg, #211d20, #090809);
    }

    .scan-frame {
      width: 138px;
      height: 138px;
      display: grid;
      place-items: center;
      margin-bottom: 12px;
      border: 2px dashed rgba(255, 255, 255, 0.56);
      border-radius: 32px;
    }

    .scan-frame svg {
      width: 48px;
      height: 48px;
    }

    .field {
      display: grid;
      gap: 8px;
      margin-top: 15px;
      font-weight: 800;
    }

    .field > span {
      font-size: clamp(13px, 3.7vw, 15px);
    }

    .field input,
    .field select,
    .field textarea {
      min-height: 46px;
      width: 100%;
      padding: 12px;
      border: 1px solid var(--line);
      border-radius: 15px;
      color: var(--ink);
      background: rgba(255, 255, 255, 0.82);
    }

    .field textarea {
      min-height: 112px;
      resize: none;
    }

    .machine-item {
      display: grid;
      grid-template-columns: 92px 1fr;
      gap: 12px;
      align-items: center;
      margin: 14px 0;
      padding: 12px;
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      background: rgba(255, 255, 255, 0.7);
    }

    .segmented {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6px;
      margin: 12px 0;
      padding: 6px;
      border: 1px solid var(--line);
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.68);
    }

    .segmented button {
      min-height: 44px;
      border-radius: 13px;
      color: var(--ink);
      background: transparent;
      font-size: clamp(12px, 3.6vw, 14px);
      font-weight: 800;
    }

    .segmented button.active {
      color: #ffffff;
      background: var(--brand);
    }

    .borrow-card {
      padding: 15px;
    }

    .borrow-head {
      display: grid;
      grid-template-columns: 92px 1fr;
      gap: 14px;
      align-items: center;
    }

    .camera-panel {
      overflow: hidden;
      padding: 18px;
      color: #ffffff;
      background:
        linear-gradient(180deg, rgba(0, 0, 0, 0.08), rgba(0, 0, 0, 0.78)),
        #111111;
    }

    .camera-box {
      position: relative;
      height: 286px;
      display: grid;
      place-items: center;
      margin-bottom: 16px;
      border: 2px solid rgba(255, 255, 255, 0.18);
      border-radius: 24px;
    }

    /* [IMAGE-CSS-camera-img] 器材图：归还检测 / 同步页取景框内尺寸 */
    .camera-img {
      width: 260px;
      height: 210px;
      object-fit: contain;
      filter: drop-shadow(0 20px 22px rgba(0, 0, 0, 0.36));
    }

    .scan-line {
      position: absolute;
      left: 14px;
      right: 14px;
      top: 50%;
      height: 2px;
      background: #ffffff;
      box-shadow: 0 0 18px rgba(255, 255, 255, 0.78);
    }

    @keyframes scanSweep {
      0%, 100% { top: 14%; opacity: 0.4; }
      50% { top: 82%; opacity: 1; }
    }

    @keyframes scanPulse {
      0%, 100% { opacity: 0.45; }
      50% { opacity: 1; }
    }

    @keyframes scanSuccessPop {
      0% { transform: scale(0.88); opacity: 0; }
      100% { transform: scale(1); opacity: 1; }
    }

    .scan-screen {
      position: absolute;
      inset: 0;
      z-index: 90;
      display: flex;
      flex-direction: column;
      color: #ffffff;
      background: #050506;
    }

    .scan-screen-header {
      display: grid;
      grid-template-columns: 46px minmax(0, 1fr) 46px;
      align-items: center;
      column-gap: 10px;
      min-height: 58px;
      padding: 14px 24px 12px;
      flex-shrink: 0;
    }

    .scan-screen-header .page-title {
      color: #ffffff;
      text-align: center;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .scan-screen-header .scan-header-spacer {
      width: 46px;
      height: 46px;
    }

    .scan-screen-header .icon-button {
      position: relative;
      z-index: 2;
      color: #ffffff;
      border-color: rgba(255, 255, 255, 0.24);
      background: rgba(255, 255, 255, 0.14);
    }

    .scan-screen-body {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 0 24px 48px;
      text-align: center;
    }

    .scan-viewfinder {
      position: relative;
      width: min(100%, 292px);
      aspect-ratio: 1;
      margin-bottom: 22px;
      border-radius: 22px;
      overflow: hidden;
      background:
        linear-gradient(180deg, rgba(0, 0, 0, 0.12), rgba(0, 0, 0, 0.58)),
        radial-gradient(circle at 50% 18%, rgba(159, 18, 57, 0.32), transparent 44%),
        #171416;
      box-shadow: 0 18px 40px rgba(0, 0, 0, 0.42);
    }

    .scan-camera-feed {
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
    }

    .scan-camera-feed .camera-img,
    .scan-camera-feed img,
    .scan-camera-feed .equipment-placeholder-emoji {
      width: 72%;
      max-height: 58%;
      object-fit: contain;
      filter: brightness(0.9) contrast(1.05);
    }

    .scan-grid {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
      background-size: 22px 22px;
      pointer-events: none;
    }

    .scan-corner {
      position: absolute;
      width: 34px;
      height: 34px;
      border: 3px solid rgba(255, 255, 255, 0.92);
      pointer-events: none;
    }

    .scan-corner.tl {
      top: 16px;
      left: 16px;
      border-right: 0;
      border-bottom: 0;
      border-top-left-radius: 10px;
    }

    .scan-corner.tr {
      top: 16px;
      right: 16px;
      border-left: 0;
      border-bottom: 0;
      border-top-right-radius: 10px;
    }

    .scan-corner.bl {
      bottom: 16px;
      left: 16px;
      border-right: 0;
      border-top: 0;
      border-bottom-left-radius: 10px;
    }

    .scan-corner.br {
      bottom: 16px;
      right: 16px;
      border-left: 0;
      border-top: 0;
      border-bottom-right-radius: 10px;
    }

    .scan-line-animated {
      position: absolute;
      left: 12%;
      right: 12%;
      height: 2px;
      background: linear-gradient(90deg, transparent, #ffffff, transparent);
      box-shadow: 0 0 16px rgba(255, 255, 255, 0.85);
      animation: scanSweep 2s ease-in-out infinite;
    }

    .scan-barcode-mock {
      position: absolute;
      left: 50%;
      bottom: 22%;
      width: 58%;
      height: 42px;
      transform: translateX(-50%);
      border-radius: 6px;
      background:
        repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.88) 0 3px, transparent 3px 7px);
      opacity: 0.72;
      pointer-events: none;
    }

    .scan-hint {
      margin: 0;
      font-size: 14px;
      color: rgba(255, 255, 255, 0.72);
      line-height: 1.5;
    }

    .scan-hint strong {
      display: block;
      margin-top: 6px;
      color: #ffffff;
      font-size: 18px;
    }

    .scan-status-text {
      margin: 14px 0 0;
      font-size: 13px;
      color: rgba(255, 255, 255, 0.55);
    }

    .scan-status-text.is-scanning {
      animation: scanPulse 1.6s ease-in-out infinite;
    }

    .scan-success-overlay {
      position: absolute;
      inset: 0;
      z-index: 20;
      display: grid;
      place-items: center;
      background: rgba(8, 10, 12, 0.76);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.28s ease;
    }

    .scan-success-overlay.show {
      opacity: 1;
      pointer-events: auto;
    }

    .scan-success-card {
      width: min(88%, 260px);
      padding: 28px 22px;
      border-radius: 24px;
      text-align: center;
      background: rgba(255, 255, 255, 0.12);
      border: 1px solid rgba(255, 255, 255, 0.22);
      backdrop-filter: blur(12px);
      animation: scanSuccessPop 0.35s ease;
    }

    .scan-success-icon {
      width: 72px;
      height: 72px;
      margin: 0 auto 14px;
      display: grid;
      place-items: center;
      border-radius: 50%;
      color: var(--ok);
      background: var(--ok-bg);
    }

    .scan-success-icon svg {
      width: 36px;
      height: 36px;
    }

    .borrow-confirm-hero {
      text-align: center;
      margin-bottom: 16px;
    }

    .borrow-confirm-badge {
      width: 64px;
      height: 64px;
      margin: 0 auto 12px;
      display: grid;
      place-items: center;
      border-radius: 50%;
      color: var(--ok);
      background: var(--ok-bg);
    }

    .borrow-confirm-badge svg {
      width: 32px;
      height: 32px;
    }

    .sync-visual {
      position: relative;
      width: min(100%, 220px);
      height: 220px;
      margin: 0 auto 22px;
      display: grid;
      place-items: center;
    }

    .sync-ring {
      position: absolute;
      inset: 0;
      border: 2px solid rgba(255, 255, 255, 0.22);
      border-radius: 50%;
      animation: syncRing 2.2s ease-out infinite;
    }

    .sync-ring:nth-child(2) {
      animation-delay: 0.55s;
    }

    .sync-ring:nth-child(3) {
      animation-delay: 1.1s;
    }

    @keyframes syncRing {
      0% { transform: scale(0.42); opacity: 0.9; }
      100% { transform: scale(1.05); opacity: 0; }
    }

    .sync-core {
      width: 88px;
      height: 88px;
      display: grid;
      place-items: center;
      border-radius: 50%;
      color: #ffffff;
      background: rgba(159, 18, 57, 0.88);
      box-shadow: 0 12px 28px rgba(159, 18, 57, 0.45);
    }

    .sync-core svg {
      width: 40px;
      height: 40px;
    }

    .machine-hint {
      margin: 0 0 14px;
      padding: 12px 14px;
      border-radius: 14px;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.55;
      background: var(--brand-soft);
      border: 1px solid rgba(159, 18, 57, 0.14);
    }

    .upload-real {
      min-height: 52px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      margin-top: 14px;
      border: 1px dashed rgba(255, 255, 255, 0.42);
      border-radius: 17px;
      color: inherit;
      background: rgba(255, 255, 255, 0.12);
      font-weight: 800;
    }

    .form-card .upload-real {
      color: var(--brand);
      border-color: rgba(159, 18, 57, 0.28);
      background: var(--brand-soft);
    }

    .form-card .upload-real + .primary-button {
      margin-top: 16px;
    }

    .upload-real input {
      display: none;
    }

    .photo-name {
      margin-top: 9px;
      color: rgba(255, 255, 255, 0.7);
      font-size: 13px;
      text-align: center;
    }

    .form-card {
      padding: 17px;
    }

    .message-item {
      display: grid;
      grid-template-columns: 46px 1fr;
      gap: 12px;
      padding: 14px;
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      background: var(--card);
    }

    .message-item i {
      width: 46px;
      height: 46px;
      display: grid;
      place-items: center;
      color: var(--brand);
      border-radius: 16px;
      background: var(--brand-soft);
    }

    .message-item p {
      margin: 5px 0;
      color: var(--muted);
      line-height: 1.5;
    }

    .message-item small {
      color: var(--muted);
      font-size: 11px;
    }

    .contact-thread {
      align-items: flex-start;
      background: rgba(255, 255, 255, 0.92);
    }

    .admin-contact-reply {
      margin-top: 10px;
      padding: 10px 12px;
      border-radius: 14px;
      color: var(--ink);
      background: var(--brand-soft);
    }

    .admin-contact-reply b {
      display: block;
      margin-bottom: 4px;
      font-size: 12px;
    }

    .admin-contact-card {
      display: grid;
      gap: 12px;
      padding: 14px;
      border: 1px solid rgba(245, 239, 241, 0.12);
      border-radius: var(--radius-md);
      background:
        radial-gradient(circle at 12% 0%, rgba(196, 107, 130, 0.09), transparent 34%),
        linear-gradient(145deg, rgba(255, 255, 255, 0.075), rgba(255, 255, 255, 0.032));
      box-shadow: inset 0 0 0 1px rgba(154, 134, 200, 0.08), 0 14px 30px rgba(20, 16, 25, 0.22);
      backdrop-filter: blur(14px);
    }

    .admin-contact-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 10px;
    }

    .admin-contact-head > div {
      min-width: 0;
    }

    .admin-contact-card p {
      margin: 6px 0;
      color: rgba(245, 239, 241, 0.66);
      font-size: 13px;
      line-height: 1.55;
      overflow-wrap: anywhere;
    }

    .admin-reply-field {
      margin-top: 0;
    }

    .admin-reply-field textarea {
      min-height: 84px;
    }

    .admin-hero {
      padding: 20px;
      color: #ffffff;
      background: linear-gradient(145deg, #211e2a, #3a2f4d);
    }

    .admin-dashboard-hero {
      position: relative;
      display: grid;
      gap: 14px;
      padding: clamp(16px, 4.5vw, 22px);
      overflow: hidden;
      border: 1px solid rgba(196, 107, 130, 0.18);
      background:
        radial-gradient(circle at 82% 16%, rgba(196, 107, 130, 0.14), transparent 30%),
        radial-gradient(circle at 8% 92%, rgba(154, 134, 200, 0.12), transparent 34%),
        radial-gradient(circle at 86% 82%, rgba(111, 143, 200, 0.1), transparent 34%),
        linear-gradient(145deg, #1d1a25 0%, #282233 56%, #191720 100%);
      box-shadow: 0 24px 52px rgba(68, 38, 48, 0.18);
    }

    .admin-dashboard-hero::after {
      content: "";
      position: absolute;
      right: -44px;
      bottom: -56px;
      width: 150px;
      height: 150px;
      border-radius: 50%;
      border: 34px solid rgba(196, 107, 130, 0.06);
      pointer-events: none;
    }

    .admin-ring-top {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 14px;
    }

    .admin-ring-top h1 {
      margin-top: 4px;
    }

    .admin-overline {
      margin: 0;
      color: #c9bbb5;
      font-size: 12px;
      font-weight: 900;
      letter-spacing: 0.04em;
    }

    .admin-ring-summary {
      margin-top: 8px;
      color: rgba(245, 239, 241, 0.76);
      font-size: clamp(13px, 3.5vw, 15px);
      line-height: 1.35;
      white-space: nowrap;
      word-break: keep-all;
    }

    .admin-ring-mode {
      min-height: 34px;
      display: inline-grid;
      place-items: center;
      padding: 0 14px;
      border-radius: 999px;
      color: #ffffff;
      font-size: 12px;
      font-weight: 900;
      white-space: nowrap;
      background: linear-gradient(135deg, #c46b82, #8e4558);
      box-shadow: 0 0 18px rgba(196, 107, 130, 0.18);
    }

    .admin-ring-stage {
      position: relative;
      z-index: 1;
      display: grid;
      justify-items: center;
      gap: 14px;
    }

    .admin-activity-ring {
      position: relative;
      width: clamp(168px, 50vw, 212px);
      aspect-ratio: 1;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.018) 55%, transparent 56%);
    }

    .admin-ring-layer {
      position: absolute;
      border-radius: 50%;
      transform: rotate(-90deg);
      background: conic-gradient(var(--ring-color) var(--ring-value), rgba(255, 255, 255, 0.11) 0);
      -webkit-mask: radial-gradient(farthest-side, transparent calc(100% - var(--ring-width)), #000 0);
      mask: radial-gradient(farthest-side, transparent calc(100% - var(--ring-width)), #000 0);
      filter: drop-shadow(0 0 9px var(--ring-glow));
    }

    .admin-ring-message {
      inset: 0;
      --ring-width: 17px;
      --ring-value: var(--message-rate);
      --ring-color: #c46b82;
      --ring-glow: rgba(196, 107, 130, 0.24);
    }

    .admin-ring-work {
      inset: 28px;
      --ring-width: 15px;
      --ring-value: var(--work-rate);
      --ring-color: #9a86c8;
      --ring-glow: rgba(154, 134, 200, 0.24);
    }

    .admin-ring-stock {
      inset: 54px;
      --ring-width: 13px;
      --ring-value: var(--stock-rate);
      --ring-color: #6f8fc8;
      --ring-glow: rgba(111, 143, 200, 0.24);
    }

    .admin-ring-center {
      position: absolute;
      inset: clamp(62px, 18vw, 78px);
      display: grid;
      place-content: center;
      text-align: center;
      border-radius: 50%;
      background: rgba(25, 21, 24, 0.88);
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.08);
    }

    .admin-ring-center strong {
      color: #ffffff;
      font-size: clamp(30px, 9vw, 42px);
      line-height: 1;
      font-family: "DIN Alternate", "SF Pro Display", Arial, sans-serif;
    }

    .admin-ring-center span {
      margin-top: 6px;
      color: #bfaeb4;
      font-size: 11px;
      font-weight: 900;
    }

    .admin-ring-legend {
      width: 100%;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
    }

    .admin-ring-legend-item {
      min-width: 0;
      display: grid;
      gap: 4px;
      padding: 9px 8px;
      border-radius: 16px;
      color: rgba(255, 255, 255, 0.92);
      font-size: 11px;
      font-weight: 900;
      text-align: center;
      background: rgba(255, 255, 255, 0.07);
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.08);
    }

    .admin-ring-legend-item::before {
      content: "";
      width: 24px;
      height: 4px;
      justify-self: center;
      border-radius: 999px;
      background: var(--legend-color);
      box-shadow: 0 0 14px var(--legend-glow);
    }

    .admin-ring-legend-item.is-message {
      --legend-color: #c46b82;
      --legend-glow: rgba(196, 107, 130, 0.3);
      background: rgba(196, 107, 130, 0.1);
      box-shadow: inset 0 0 0 1px rgba(196, 107, 130, 0.16);
    }

    .admin-ring-legend-item.is-work {
      --legend-color: #9a86c8;
      --legend-glow: rgba(154, 134, 200, 0.3);
      background: rgba(154, 134, 200, 0.1);
      box-shadow: inset 0 0 0 1px rgba(154, 134, 200, 0.15);
    }

    .admin-ring-legend-item.is-stock {
      --legend-color: #6f8fc8;
      --legend-glow: rgba(111, 143, 200, 0.28);
      background: rgba(111, 143, 200, 0.1);
      box-shadow: inset 0 0 0 1px rgba(111, 143, 200, 0.15);
    }

    .admin-ring-legend-item b {
      color: #ffffff;
      font-size: 15px;
      font-family: "DIN Alternate", "SF Pro Display", Arial, sans-serif;
    }

    .admin-hero-main {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 14px;
      align-items: center;
    }

    .admin-hero-icon {
      width: 58px;
      height: 58px;
      display: grid;
      place-items: center;
      border-radius: 20px;
      color: #ffffff;
      background: rgba(255, 255, 255, 0.16);
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.18);
      backdrop-filter: blur(10px);
    }

    .admin-hero-icon svg {
      width: 28px;
      height: 28px;
      stroke-width: 2.4;
    }

    .admin-hero-meta {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
    }

    .admin-hero-meta span {
      min-height: 44px;
      display: grid;
      place-items: center;
      padding: 8px 6px;
      border-radius: 16px;
      color: rgba(255, 255, 255, 0.9);
      font-size: clamp(11px, 3.2vw, 12px);
      font-weight: 800;
      text-align: center;
      background: rgba(255, 255, 255, 0.14);
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.12);
    }

    .admin-kpi-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
      margin: 10px 0 8px;
    }

    .admin-dashboard-scroll {
      padding-top: 2px;
      background:
        radial-gradient(circle at 50% 42%, rgba(122, 103, 168, 0.16), transparent 36%),
        radial-gradient(circle at 12% 80%, rgba(196, 107, 130, 0.07), transparent 32%);
    }

    .admin-dashboard-scroll .admin-kpi-card {
      position: relative;
      overflow: hidden;
      --kpi-accent: #c46b82;
      --kpi-border: rgba(196, 107, 130, 0.22);
      border-color: rgba(255, 255, 255, 0.11);
      color: #ffffff;
      background:
        radial-gradient(circle at 18% 14%, rgba(255, 255, 255, 0.08), transparent 32%),
        linear-gradient(145deg, rgba(255, 255, 255, 0.095), rgba(255, 255, 255, 0.035));
      box-shadow: inset 0 0 0 1px var(--kpi-border), 0 14px 30px rgba(20, 16, 25, 0.24);
      backdrop-filter: blur(14px);
    }

    .admin-dashboard-scroll .admin-kpi-card:nth-child(2) {
      --kpi-accent: #9a86c8;
      --kpi-border: rgba(154, 134, 200, 0.22);
    }

    .admin-dashboard-scroll .admin-kpi-card:nth-child(3) {
      --kpi-accent: #6f8fc8;
      --kpi-border: rgba(111, 143, 200, 0.22);
    }

    .admin-dashboard-scroll .admin-kpi-card::before {
      content: "";
      position: absolute;
      left: 12px;
      right: 12px;
      top: 0;
      height: 3px;
      border-radius: 999px;
      background: var(--kpi-accent);
      opacity: 0.9;
    }

    .admin-dashboard-scroll .admin-kpi-icon {
      color: var(--kpi-accent);
      background: rgba(255, 255, 255, 0.07);
      box-shadow: inset 0 0 0 1px var(--kpi-border);
    }

    .admin-dashboard-scroll .admin-kpi-card small,
    .admin-dashboard-scroll .admin-kpi-card strong span {
      color: rgba(255, 255, 255, 0.62);
    }

    .admin-dashboard-scroll .admin-kpi-card strong {
      color: #ffffff;
    }

    .admin-quick-nav {
      position: relative;
      margin: 0 -8px 8px;
      padding: 0;
      overflow: visible;
      border: 0;
      border-radius: 0;
      background: transparent;
      box-shadow: none;
    }

    .admin-quick-head {
      display: none;
    }

    .admin-quick-head strong {
      display: block;
      color: var(--ink);
      font-size: clamp(18px, 5vw, 22px);
      font-weight: 950;
      line-height: 1.15;
      white-space: nowrap;
    }

    .admin-quick-head span {
      color: var(--muted);
      font-size: clamp(11px, 3vw, 13px);
      font-weight: 800;
      line-height: 1.3;
      white-space: nowrap;
    }

    .admin-quick-stage {
      position: relative;
      height: 238px;
      overflow: hidden;
      border-radius: 0;
      touch-action: pan-y;
      cursor: grab;
      user-select: none;
      -webkit-user-select: none;
      background: transparent;
    }

    .admin-quick-stage.is-dragging {
      cursor: grabbing;
    }

    .admin-quick-stage::before {
      content: "";
      position: absolute;
      left: 50%;
      bottom: -224px;
      width: min(116vw, 486px);
      height: min(116vw, 486px);
      transform: translateX(-50%);
      border-radius: 50%;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background:
        radial-gradient(circle, transparent 0 44%, rgba(196, 107, 130, 0.1) 44.5% 46%, transparent 46.5% 56%, rgba(255, 255, 255, 0.07) 57% 57.5%, transparent 58%),
        radial-gradient(circle at 50% 50%, rgba(122, 103, 168, 0.13), transparent 62%);
      box-shadow: 0 -28px 72px rgba(64, 52, 88, 0.16);
      pointer-events: none;
    }

    .admin-quick-stage::after {
      content: none;
    }

    .admin-quick-track {
      position: absolute;
      inset: 0;
      isolation: isolate;
    }

    .admin-swipe-hint {
      position: absolute;
      left: 50%;
      top: 2px;
      z-index: 180;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 10px;
      transform: translateX(-50%);
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 999px;
      color: rgba(245, 239, 241, 0.72);
      background: rgba(33, 27, 31, 0.72);
      box-shadow: inset 0 0 0 1px rgba(196, 107, 130, 0.07), 0 10px 24px rgba(36, 26, 31, 0.18);
      backdrop-filter: blur(12px);
      pointer-events: none;
      font-size: clamp(10px, 2.8vw, 12px);
      font-weight: 900;
      line-height: 1;
      white-space: nowrap;
    }

    .admin-swipe-hint svg {
      width: 16px;
      height: 16px;
      color: #c46b82;
      stroke-width: 2.2;
      filter: drop-shadow(0 0 8px rgba(196, 107, 130, 0.22));
    }

    .admin-quick-button {
      position: absolute;
      left: 50%;
      bottom: 34px;
      z-index: var(--fan-z);
      width: clamp(124px, 34vw, 150px);
      min-height: 132px;
      display: grid;
      justify-items: center;
      align-content: start;
      gap: 7px;
      min-width: 0;
      padding: 0;
      overflow: visible;
      border: 0;
      border-radius: 0;
      color: rgba(255, 255, 255, 0.92);
      background: transparent;
      box-shadow: none;
      text-align: center;
      cursor: pointer;
      transform:
        translateX(calc(-50% + var(--fan-x)))
        translateY(var(--fan-y))
        rotate(var(--fan-rotate))
        scale(var(--fan-scale));
      transform-origin: 50% 255%;
      opacity: var(--fan-opacity);
      pointer-events: var(--fan-pointer);
      will-change: transform, opacity;
      transition:
        transform 320ms cubic-bezier(0.2, 0.85, 0.18, 1),
        opacity 180ms ease,
        box-shadow 180ms ease;
    }

    .admin-quick-stage.is-dragging .admin-quick-button {
      transition: none;
    }

    .admin-quick-button.is-active {
      filter: drop-shadow(0 18px 24px rgba(36, 26, 31, 0.3));
    }

    .admin-quick-button.is-hidden {
      opacity: 0;
      pointer-events: none;
    }

    .admin-quick-button::before {
      content: none;
    }

    .admin-quick-button::after {
      content: none;
    }

    .admin-quick-button:active {
      transform:
        translateX(calc(-50% + var(--fan-x)))
        translateY(calc(var(--fan-y) - 5px))
        rotate(var(--fan-rotate))
        scale(calc(var(--fan-scale) * 0.98));
    }

    .admin-quick-button i {
      position: relative;
      z-index: 1;
      width: 70px;
      height: 70px;
      display: grid;
      place-items: center;
      margin-top: 0;
      border: 1px solid var(--quick-border);
      border-radius: 26px;
      color: var(--quick-color);
      background:
        radial-gradient(circle at 32% 22%, rgba(255, 255, 255, 0.14), transparent 28%),
        linear-gradient(145deg, rgba(47, 36, 43, 0.94), rgba(28, 23, 27, 0.97) 70%);
      box-shadow: 0 12px 26px rgba(36, 26, 31, 0.24), inset 0 1px 0 rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(12px);
    }

    .admin-quick-button i::after {
      content: "";
      position: absolute;
      left: 18px;
      right: 18px;
      top: 10px;
      height: 4px;
      border-radius: 999px;
      background: var(--quick-color);
      box-shadow: 0 0 10px var(--quick-glow);
      opacity: 0.82;
    }

    .admin-quick-button.is-active i {
      width: 80px;
      height: 80px;
      border-radius: 29px;
      color: #ffffff;
      background:
        radial-gradient(circle at 32% 22%, rgba(255, 255, 255, 0.28), transparent 28%),
        linear-gradient(145deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0) 46%),
        linear-gradient(145deg, var(--quick-color), var(--quick-deep));
      box-shadow: 0 16px 30px var(--quick-glow), inset 0 1px 0 rgba(255, 255, 255, 0.22);
    }

    .admin-quick-button.is-active i::after {
      background: rgba(255, 255, 255, 0.72);
      box-shadow: 0 0 16px rgba(255, 255, 255, 0.24);
    }

    .admin-quick-button i svg {
      width: 29px;
      height: 29px;
      stroke-width: 2.7;
    }

    .admin-quick-button.is-active i svg {
      width: 32px;
      height: 32px;
    }

    .admin-quick-text {
      position: relative;
      z-index: 1;
      display: grid;
      gap: 2px;
      min-width: 0;
    }

    .admin-quick-button span {
      min-width: 0;
      overflow: visible;
      color: #ffffff;
      font-size: clamp(15px, 4.2vw, 18px);
      font-weight: 950;
      line-height: 1.2;
      text-overflow: ellipsis;
      white-space: nowrap;
      text-shadow: 0 8px 18px rgba(36, 26, 31, 0.24);
    }

    .admin-quick-button small {
      min-height: 15px;
      color: rgba(255, 255, 255, 0.56);
      font-size: clamp(10px, 2.8vw, 12px);
      font-weight: 800;
      line-height: 1.25;
      white-space: nowrap;
    }

    .admin-quick-button b {
      position: absolute;
      top: -7px;
      right: calc(50% - 47px);
      z-index: 1;
      min-width: 24px;
      height: 24px;
      display: grid;
      place-items: center;
      padding: 0 6px;
      border-radius: 999px;
      color: #ffffff;
      border: 1px solid var(--quick-border);
      background: rgba(31, 25, 29, 0.92);
      box-shadow: 0 8px 18px rgba(36, 26, 31, 0.22);
      font-size: 11px;
      font-weight: 950;
      line-height: 1;
    }

    .admin-quick-button.is-batch {
      --quick-color: #b96578;
      --quick-deep: #6f3848;
      --quick-glow: rgba(185, 101, 120, 0.2);
      --quick-border: rgba(211, 142, 158, 0.22);
    }

    .admin-quick-button.is-messages {
      --quick-color: #c46b82;
      --quick-deep: #7b3f51;
      --quick-glow: rgba(196, 107, 130, 0.22);
      --quick-border: rgba(218, 153, 169, 0.22);
    }

    .admin-quick-button.is-orders {
      --quick-color: #9a86c8;
      --quick-deep: #5a4c75;
      --quick-glow: rgba(154, 134, 200, 0.22);
      --quick-border: rgba(184, 166, 220, 0.2);
    }

    .admin-quick-button.is-equipment {
      --quick-color: #a95f73;
      --quick-deep: #613341;
      --quick-glow: rgba(169, 95, 115, 0.21);
      --quick-border: rgba(200, 132, 150, 0.2);
    }

    .admin-quick-button.is-sync {
      --quick-color: #6f8fc8;
      --quick-deep: #354769;
      --quick-glow: rgba(111, 143, 200, 0.22);
      --quick-border: rgba(158, 148, 198, 0.2);
    }

    .admin-quick-button.is-logs {
      --quick-color: #9a6a78;
      --quick-deep: #554149;
      --quick-glow: rgba(154, 106, 120, 0.18);
      --quick-border: rgba(190, 148, 160, 0.18);
    }

    .admin-quick-button.is-export {
      --quick-color: #8d5b6b;
      --quick-deep: #4e303c;
      --quick-glow: rgba(141, 91, 107, 0.18);
      --quick-border: rgba(178, 132, 146, 0.18);
    }

    @media (max-width: 390px) {
      .admin-quick-nav {
        margin-inline: -10px;
      }

      .admin-quick-stage {
        height: 226px;
      }

      .admin-quick-button {
        width: 118px;
        min-height: 126px;
      }

      .admin-quick-button i {
        width: 66px;
        height: 66px;
      }
    }

    .admin-kpi-card {
      min-height: 104px;
      display: grid;
      gap: 10px;
      padding: 13px;
      border: 1px solid rgba(159, 18, 57, 0.12);
      border-radius: 22px;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(255, 246, 248, 0.92));
      box-shadow: 0 14px 32px rgba(111, 11, 39, 0.1);
    }

    .admin-kpi-card.is-compact {
      min-height: 70px;
      grid-template-columns: 30px minmax(0, 1fr);
      align-items: center;
      gap: 8px;
      padding: 10px;
      border-radius: 18px;
      box-shadow: 0 10px 22px rgba(111, 11, 39, 0.08);
    }

    .admin-kpi-card.is-compact .admin-kpi-icon {
      width: 30px;
      height: 30px;
      border-radius: 12px;
    }

    .admin-kpi-card.is-compact strong {
      font-size: clamp(20px, 6vw, 25px);
    }

    .admin-kpi-icon {
      width: 34px;
      height: 34px;
      display: grid;
      place-items: center;
      border-radius: 14px;
      color: var(--brand);
      background: var(--brand-soft);
    }

    .admin-kpi-icon svg {
      width: 18px;
      height: 18px;
      stroke-width: 2.5;
    }

    .admin-kpi-card small {
      color: var(--muted);
      font-size: 12px;
      font-weight: 800;
    }

    .admin-kpi-card strong {
      display: block;
      margin-top: 3px;
      color: var(--ink);
      font-size: clamp(24px, 7vw, 32px);
      line-height: 1;
      font-family: "DIN Alternate", "SF Pro Display", Arial, sans-serif;
    }

    .admin-kpi-card strong span {
      margin-left: 2px;
      color: var(--muted);
      font-size: 12px;
      font-family: inherit;
    }

    .admin-section-card {
      display: grid;
      gap: 16px;
      margin-top: 18px;
      padding: 18px 0 0;
      border: 0;
      border-top: 1px solid rgba(245, 239, 241, 0.12);
      border-radius: 0;
      background: transparent;
      box-shadow: none;
    }

    .admin-section-card:first-of-type {
      margin-top: 4px;
      padding-top: 8px;
      border-top: 0;
    }

    .admin-module-scroll {
      color: rgba(255, 255, 255, 0.9);
      background:
        radial-gradient(circle at 50% 0%, rgba(196, 107, 130, 0.08), transparent 34%),
        linear-gradient(180deg, rgba(24, 21, 25, 0), rgba(24, 21, 25, 0.4));
    }

    .admin-section-title {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
      gap: 10px;
    }

    .admin-section-title h2 {
      margin: 0;
      color: rgba(255, 255, 255, 0.96);
      font-size: clamp(20px, 6vw, 25px);
      line-height: 1.2;
    }

    .admin-section-title p {
      margin: 5px 0 0;
      color: rgba(245, 239, 241, 0.68);
      font-size: clamp(12px, 3.5vw, 13px);
      line-height: 1.45;
    }

    .admin-status-pill {
      min-height: 34px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0 12px;
      border-radius: 999px;
      color: #dca8b6;
      font-size: 12px;
      font-weight: 900;
      white-space: nowrap;
      background: rgba(196, 107, 130, 0.12);
      box-shadow: inset 0 0 0 1px rgba(196, 107, 130, 0.16);
    }

    .order-card {
      display: grid;
      grid-template-columns: 78px 1fr;
      gap: 12px;
      padding: 14px 0;
      border-radius: 0;
      border-top: 1px solid rgba(245, 239, 241, 0.1);
      background: transparent;
    }

    .admin-actions {
      grid-column: 1 / -1;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
    }

    .admin-actions .primary-button,
    .admin-actions .secondary-button {
      min-height: 44px;
      border-radius: 14px;
      font-size: clamp(10px, 3vw, 12px);
    }

    .admin-equipment-form {
      display: grid;
      gap: 12px;
      padding: 2px 0 0;
      border: 0;
      border-radius: 0;
      background: transparent;
    }

    .admin-equipment-form-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .admin-equipment-form .field {
      margin: 0;
    }

    .admin-equipment-form .primary-button {
      width: 100%;
    }

    .admin-machine-sync-card,
    .admin-equipment-row {
      display: grid;
      gap: 12px;
      padding: 16px 0;
      border: 0;
      border-top: 1px solid rgba(245, 239, 241, 0.1);
      border-radius: 0;
      background: transparent;
    }

    .admin-machine-sync-card:first-child,
    .admin-equipment-row:first-child {
      border-top: 0;
    }

    .admin-machine-sync-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 10px;
    }

    .admin-machine-sync-head h3 {
      margin: 0;
      color: rgba(255, 255, 255, 0.94);
      font-size: clamp(16px, 4vw, 20px);
    }

    .admin-machine-sync-head p {
      margin: 4px 0 0;
      color: rgba(245, 239, 241, 0.66);
      font-size: 12px;
      line-height: 1.45;
    }

    .admin-machine-sync-head span,
    .admin-equipment-chip {
      min-height: 28px;
      display: inline-flex;
      align-items: center;
      padding: 0 10px;
      border-radius: 999px;
      color: #dca8b6;
      background: rgba(196, 107, 130, 0.12);
      box-shadow: inset 0 0 0 1px rgba(196, 107, 130, 0.14);
      font-size: 11px;
      font-weight: 900;
      white-space: nowrap;
    }

    .admin-machine-sync-card textarea {
      width: 100%;
      min-height: 118px;
      resize: vertical;
      padding: 12px;
      color: rgba(255, 255, 255, 0.92);
      border: 1px solid rgba(245, 239, 241, 0.14);
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.06);
      font: inherit;
      font-size: 13px;
      line-height: 1.5;
    }

    .admin-machine-sync-card textarea::placeholder {
      color: rgba(245, 239, 241, 0.46);
    }

    .admin-module-scroll .field > span {
      color: rgba(245, 239, 241, 0.78);
    }

    .admin-module-scroll .field input,
    .admin-module-scroll .field select,
    .admin-module-scroll .field textarea,
    .admin-reply-field textarea {
      color: rgba(255, 255, 255, 0.9);
      border-color: rgba(245, 239, 241, 0.14);
      background: rgba(255, 255, 255, 0.06);
    }

    .admin-module-scroll .field input::placeholder,
    .admin-module-scroll .field textarea::placeholder,
    .admin-reply-field textarea::placeholder {
      color: rgba(245, 239, 241, 0.44);
    }

    .admin-module-scroll .message-item,
    .admin-module-scroll .contact-thread,
    .admin-module-scroll .admin-contact-card,
    .admin-module-scroll .borrow-card,
    .admin-module-scroll .profile-settings {
      border: 0;
      border-top: 1px solid rgba(245, 239, 241, 0.1);
      border-radius: 0;
      background: transparent;
      box-shadow: none;
    }

    .admin-module-scroll .message-item:first-child,
    .admin-module-scroll .borrow-card:first-child,
    .admin-module-scroll .profile-settings:first-child {
      border-top: 0;
    }

    .admin-module-scroll .message-item strong,
    .admin-module-scroll .admin-contact-head strong,
    .admin-module-scroll .order-card strong,
    .admin-module-scroll .borrow-card h2 {
      color: rgba(255, 255, 255, 0.94);
    }

    .admin-module-scroll .message-item p,
    .admin-module-scroll .admin-contact-card p,
    .admin-module-scroll .message-item small,
    .admin-module-scroll .order-card p,
    .admin-module-scroll .borrow-card p,
    .admin-module-scroll .empty {
      color: rgba(245, 239, 241, 0.62);
    }

    .admin-module-scroll .admin-contact-reply {
      border: 1px solid rgba(245, 239, 241, 0.12);
      background: rgba(255, 255, 255, 0.05);
    }

    .admin-module-scroll .admin-contact-reply b {
      color: rgba(255, 255, 255, 0.9);
    }

    .admin-tool-card,
    .admin-filter-panel,
    .admin-log-card {
      display: grid;
      gap: 10px;
      padding: 15px 0;
      border: 0;
      border-top: 1px solid rgba(245, 239, 241, 0.1);
      border-radius: 0;
      background: transparent;
    }

    .admin-tool-head,
    .admin-log-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 10px;
    }

    .admin-tool-head h3,
    .admin-log-head strong {
      margin: 0;
      color: rgba(255, 255, 255, 0.94);
      font-size: clamp(15px, 3.7vw, 18px);
      font-weight: 950;
      line-height: 1.25;
    }

    .admin-tool-head p,
    .admin-log-card p {
      margin: 3px 0 0;
      color: rgba(245, 239, 241, 0.64);
      font-size: 12px;
      line-height: 1.45;
    }

    .admin-export-actions {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
    }

    .admin-export-actions .secondary-button {
      min-height: 44px;
      border-radius: 14px;
      font-size: clamp(10px, 3vw, 12px);
    }

    .admin-filter-panel {
      grid-template-columns: minmax(0, 1fr) minmax(118px, 0.4fr);
      align-items: end;
    }

    .admin-filter-panel .field {
      margin: 0;
    }

    .admin-log-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .admin-log-meta span {
      min-height: 26px;
      display: inline-flex;
      align-items: center;
      padding: 0 9px;
      border-radius: 999px;
      color: #dca8b6;
      background: rgba(196, 107, 130, 0.12);
      box-shadow: inset 0 0 0 1px rgba(196, 107, 130, 0.14);
      font-size: 11px;
      font-weight: 900;
      white-space: nowrap;
    }

    .admin-equipment-row {
      grid-template-columns: 72px minmax(0, 1fr);
      align-items: center;
    }

    .admin-equipment-row .list-media {
      width: 72px;
      height: 60px;
    }

    .admin-equipment-main {
      min-width: 0;
    }

    .admin-equipment-main strong {
      color: rgba(255, 255, 255, 0.94);
    }

    .admin-equipment-main strong,
    .admin-equipment-main small {
      display: block;
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .admin-equipment-main small {
      margin-top: 4px;
      color: rgba(245, 239, 241, 0.58);
      font-size: 12px;
      line-height: 1.35;
    }

    .admin-equipment-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 8px;
    }

    .admin-equipment-edit {
      grid-column: 1 / -1;
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 8px;
      align-items: end;
    }

    .admin-mini-field {
      display: grid;
      gap: 5px;
      color: rgba(245, 239, 241, 0.62);
      font-size: 11px;
      font-weight: 850;
    }

    .admin-mini-field input,
    .admin-mini-field select {
      width: 100%;
      height: 40px;
      padding: 0 9px;
      color: rgba(255, 255, 255, 0.9);
      border: 1px solid rgba(245, 239, 241, 0.14);
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.06);
      font: inherit;
      font-size: 13px;
      font-weight: 850;
    }

    .admin-equipment-edit .secondary-button {
      min-height: 40px;
      border-radius: 12px;
      font-size: 12px;
    }

    @media (max-width: 390px) {
      .admin-equipment-form-grid {
        grid-template-columns: 1fr;
      }

      .admin-filter-panel,
      .admin-export-actions {
        grid-template-columns: 1fr;
      }

      .admin-machine-sync-head {
        display: grid;
      }

      .admin-equipment-row {
        grid-template-columns: 60px minmax(0, 1fr);
      }

      .admin-equipment-row .list-media {
        width: 60px;
        height: 52px;
      }

      .admin-equipment-edit {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .admin-equipment-edit .secondary-button {
        grid-column: 1 / -1;
      }
    }

    .profile-card {
      display: grid;
      gap: 11px;
      padding: 18px;
    }

    .profile-head {
      display: grid;
      grid-template-columns: 64px 1fr;
      gap: 14px;
      align-items: center;
      margin-bottom: 8px;
    }

    .profile-card button {
      min-height: 54px;
      display: grid;
      grid-template-columns: 26px 1fr 22px;
      align-items: center;
      gap: 10px;
      padding: 0 14px;
      text-align: left;
      color: var(--ink);
      border: 1px solid var(--line);
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.76);
    }

    .profile-screen {
      background:
        radial-gradient(circle at 82% 12%, rgba(159, 18, 57, 0.035), transparent 24%),
        linear-gradient(180deg, #ffffff 0%, #f7f2f4 46%, #fffefe 100%);
    }

    .profile-topbar {
      min-height: 62px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
      padding: 0 26px 12px;
    }

    .profile-topbar h1 {
      margin: 0;
      font-size: 30px;
      line-height: 1;
      font-weight: 900;
      letter-spacing: 0;
    }

    .profile-gear {
      width: 46px;
      height: 46px;
      display: grid;
      place-items: center;
      color: var(--ink);
      background: transparent;
    }

    .profile-gear svg {
      width: 30px;
      height: 30px;
    }

    .profile-scroll {
      padding: 0 22px calc(var(--tab-h) + 34px + env(safe-area-inset-bottom));
    }

    .profile-identity {
      position: relative;
      display: grid;
      grid-template-columns: 86px minmax(0, 1fr) 32px;
      align-items: center;
      gap: 18px;
      padding: 12px 2px 18px;
    }

    .profile-main-avatar {
      width: 86px;
      height: 86px;
      box-shadow: 0 10px 26px rgba(92, 12, 34, 0.09);
    }

    .profile-name-line {
      display: flex;
      align-items: center;
      gap: 9px;
      min-width: 0;
    }

    .profile-name-edit-button {
      max-width: 100%;
      padding: 0;
      border: 0;
      color: inherit;
      text-align: left;
      background: transparent;
      cursor: pointer;
    }

    .profile-name-line h2 {
      margin: 0;
      min-width: 0;
      overflow: hidden;
      font-size: clamp(24px, 7.6vw, 30px);
      line-height: 1.1;
      font-weight: 900;
      letter-spacing: 0;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .profile-name-line .profile-edit {
      color: var(--brand);
      border-bottom: 2px solid currentColor;
    }

    .profile-name-line .profile-edit svg {
      width: 20px;
      height: 20px;
    }

    .profile-meta {
      margin: 8px 0 0;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.5;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .profile-identity-more {
      width: 40px;
      height: 40px;
      display: grid;
      place-items: center;
      justify-self: end;
      margin-right: -8px;
      border: 0;
      color: var(--muted);
      background: transparent;
      cursor: pointer;
    }

    .profile-identity-more svg {
      width: 24px;
      height: 24px;
    }

    .profile-info-scroll {
      padding-bottom: 24px;
    }

    .profile-info-hero {
      display: grid;
      grid-template-columns: 72px minmax(0, 1fr);
      align-items: center;
      gap: 16px;
      margin: 8px 0 14px;
      padding: 18px;
      border: 1px solid rgba(159, 18, 57, 0.08);
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.96);
      box-shadow: var(--shadow-soft);
    }

    .profile-info-avatar {
      width: 72px;
      height: 72px;
    }

    .profile-info-hero p {
      margin: 0 0 4px;
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
    }

    .profile-info-hero h2 {
      margin: 0;
      overflow: hidden;
      color: var(--ink);
      font-size: 26px;
      line-height: 1.1;
      font-weight: 900;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .profile-info-edit {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      margin-top: 10px;
      color: var(--brand);
      font-size: 13px;
      font-weight: 800;
      background: transparent;
    }

    .profile-info-edit svg {
      width: 16px;
      height: 16px;
    }

    .profile-info-card {
      margin: 0;
      padding: 8px 16px;
    }

    .profile-info-row {
      min-height: 58px;
      display: grid;
      grid-template-columns: 28px minmax(72px, .7fr) minmax(0, 1.3fr);
      align-items: center;
      gap: 10px;
      border-bottom: 1px solid rgba(234, 221, 225, 0.85);
    }

    .profile-info-row:last-child {
      border-bottom: 0;
    }

    .profile-info-row svg {
      width: 22px;
      height: 22px;
      color: var(--brand);
    }

    .profile-info-row strong {
      color: var(--ink);
      font-size: 14px;
      font-weight: 850;
      white-space: nowrap;
    }

    .profile-info-row span {
      min-width: 0;
      overflow: hidden;
      color: var(--muted);
      font-size: 13px;
      font-weight: 700;
      text-align: right;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .identity-form {
      margin: 0;
      padding: 16px;
    }

    .identity-form .field:first-child {
      margin-top: 0;
    }

    .identity-hint {
      margin: 14px 0 0;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.45;
    }

    .identity-status {
      min-height: 18px;
      margin: 12px 0 0;
      color: var(--ok);
      font-size: 12px;
      font-weight: 800;
      line-height: 1.4;
    }

    .identity-status.is-error {
      color: var(--bad);
    }

    .identity-form .primary-button {
      margin-top: 16px;
    }

    .credit-summary-card {
      display: grid;
      grid-template-columns: 74px minmax(0, 1fr);
      align-items: center;
      gap: 12px;
      margin: 6px 0 12px;
      padding: 14px 15px;
      border: 1px solid rgba(159, 18, 57, 0.08);
      border-radius: 22px;
      background: rgba(255, 255, 255, 0.96);
      box-shadow: var(--shadow-soft);
    }

    .credit-score-ring {
      --score: 90;
      width: 72px;
      height: 72px;
      display: grid;
      place-items: center;
      border-radius: 50%;
      background: conic-gradient(var(--brand) calc(var(--score) * 1%), rgba(159, 18, 57, 0.12) 0);
    }

    .credit-score-ring div {
      width: 58px;
      height: 58px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2px;
      border-radius: 50%;
      background: #ffffff;
      text-align: center;
    }

    .credit-score-ring strong {
      display: block;
      color: var(--ink);
      font-size: 21px;
      line-height: .9;
      font-weight: 900;
      letter-spacing: 0;
    }

    .credit-score-ring span {
      display: block;
      color: var(--muted);
      font-size: 10px;
      line-height: 1;
      font-weight: 800;
      letter-spacing: 0;
      white-space: nowrap;
    }

    .credit-summary-card p,
    .credit-summary-card h2 {
      margin: 0;
    }

    .credit-summary-card p {
      color: var(--muted);
      font-size: 11px;
      font-weight: 800;
    }

    .credit-summary-card h2 {
      margin: 3px 0 5px;
      color: var(--brand);
      font-size: 25px;
      line-height: 1.1;
      font-weight: 900;
    }

    .credit-summary-card small {
      color: var(--muted);
      font-size: 11px;
      line-height: 1.35;
      font-weight: 700;
    }

    .credit-formula {
      grid-column: 1 / -1;
      margin-top: 2px;
      padding: 9px 10px;
      border-radius: 14px;
      color: var(--brand);
      background: rgba(159, 18, 57, 0.06);
      font-size: 11px;
      line-height: 1.35;
      font-weight: 850;
    }

    .credit-rule-card {
      margin-bottom: 12px;
      padding: 12px 14px;
    }

    .credit-rule-card h3 {
      margin: 4px 0 10px;
      color: var(--ink);
      font-size: 17px;
      line-height: 1.2;
    }

    .credit-rule-row {
      min-height: 50px;
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
      gap: 10px;
      border-bottom: 1px solid rgba(234, 221, 225, 0.85);
    }

    .credit-rule-row:last-child {
      border-bottom: 0;
    }

    .credit-rule-row strong {
      display: block;
      color: var(--ink);
      font-size: 14px;
      line-height: 1.25;
    }

    .credit-rule-row span {
      display: block;
      margin-top: 2px;
      color: var(--muted);
      font-size: 11px;
      line-height: 1.35;
    }

    .credit-rule-row b {
      color: var(--brand);
      font-size: 15px;
      white-space: nowrap;
    }

    .profile-file {
      position: relative;
      isolation: isolate;
      aspect-ratio: 1400 / 1024;
      width: 100%;
      margin: 12px 0 20px;
      overflow: visible;
    }

    .profile-file::before {
      content: "";
      position: absolute;
      z-index: 0;
      inset: 11% -3% -2%;
      border-radius: 28px;
      background: linear-gradient(180deg, rgba(246, 239, 243, 0.96), rgba(238, 228, 235, 0.9));
      box-shadow:
        0 18px 28px rgba(92, 12, 34, 0.13),
        inset 0 0 0 1px rgba(159, 18, 57, 0.07);
    }

    .profile-file::after {
      content: "";
      position: absolute;
      z-index: 0;
      left: 12%;
      right: 12%;
      bottom: -1%;
      height: 13%;
      border-radius: 999px;
      background: rgba(92, 12, 34, 0.12);
      box-shadow: 0 10px 20px rgba(92, 12, 34, 0.12);
    }

    .profile-folder-img {
      position: absolute;
      z-index: 1;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: contain;
      object-position: center;
      pointer-events: none;
      user-select: none;
      filter: none;
    }

    .profile-file-card {
      position: absolute;
      z-index: 2;
      top: 16.2%;
      right: 7.2%;
      bottom: 7.2%;
      left: 7.2%;
      display: grid;
      grid-template-rows: auto minmax(0, 1fr);
      align-content: start;
      padding: 0;
      border: 0;
      border-radius: 0;
      background: transparent;
      box-shadow: none;
    }

    .profile-file-card::after {
      content: none;
    }

    .profile-file-title {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: center;
      gap: 6px;
      margin-bottom: clamp(14px, 4vw, 18px);
      padding-left: 2px;
    }

    .profile-file-title h2 {
      margin: 0;
      font-size: clamp(15px, 4.1vw, 20px);
      line-height: 1;
      font-weight: 900;
    }

    .profile-round-link {
      width: clamp(18px, 5.4vw, 23px);
      height: clamp(18px, 5.4vw, 23px);
      display: grid;
      place-items: center;
      color: #ffffff;
      border-radius: 50%;
      background: var(--brand);
    }

    .profile-round-link svg {
      width: 14px;
      height: 14px;
    }

    .profile-file-panel {
      position: relative;
      z-index: 1;
      min-height: 0;
      display: grid;
      grid-template-rows: minmax(0, 1fr) auto;
      border: 0;
      border-radius: 0;
      background: transparent;
      overflow: hidden;
    }

    .profile-file-metrics {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      min-height: 0;
      align-items: stretch;
    }

    .profile-file-metric {
      position: relative;
      min-height: 0;
      display: grid;
      align-content: center;
      padding: clamp(6px, 2.2vw, 14px) clamp(4px, 2vw, 10px);
      border-right: 1px solid rgba(159, 18, 57, 0.18);
    }

    .profile-file-metric:last-child {
      border-right: 0;
    }

    .profile-file-metric span {
      display: flex;
      align-items: center;
      gap: clamp(3px, 1.2vw, 6px);
      color: var(--ink);
      font-size: clamp(8px, 2.6vw, 12px);
      font-weight: 700;
      white-space: nowrap;
    }

    .profile-file-metric span svg {
      width: clamp(13px, 4vw, 18px);
      height: clamp(13px, 4vw, 18px);
      color: var(--brand);
    }

    .profile-file-metric strong {
      display: block;
      margin-top: clamp(8px, 2.8vw, 14px);
      font-size: clamp(17px, 5.2vw, 26px);
      line-height: 1;
      font-weight: 900;
      white-space: nowrap;
    }

    .profile-file-metric strong em {
      color: var(--brand);
      font-style: normal;
    }

    .profile-file-actions {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      align-items: center;
      margin: 0 2px;
      border: 0;
      background: transparent;
      overflow: visible;
    }

    .profile-file-actions button {
      min-height: clamp(28px, 9.4vw, 40px);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 3px;
      color: var(--ink);
      background: transparent;
      border-right: 0;
      font-size: clamp(8px, 2.7vw, 11px);
      font-weight: 800;
      white-space: nowrap;
    }

    .profile-file-actions button:last-child {
      border-right: 0;
    }

    .profile-file-actions .profile-return-button {
      min-height: 29px;
      margin: 4px 3px;
      color: #ffffff;
      border-radius: 999px;
      background: var(--brand);
      border-right: 0;
    }

    .profile-file-actions svg {
      width: clamp(13px, 4vw, 16px);
      height: clamp(13px, 4vw, 16px);
      color: var(--brand);
    }

    .profile-file-actions .profile-return-button svg {
      width: 15px;
      height: 15px;
      color: currentColor;
    }

    .profile-stats-card {
      position: relative;
      z-index: 3;
      display: grid;
      grid-template-columns: minmax(74px, 0.75fr) 1px minmax(0, 1.55fr);
      align-items: center;
      gap: 12px;
      margin-bottom: 16px;
      padding: 18px;
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.98);
      box-shadow: var(--shadow-soft);
    }

    .profile-divider {
      width: 1px;
      height: 86px;
      background: var(--line);
    }

    .profile-stat-label {
      margin: 0;
      font-size: clamp(14px, 4vw, 16px);
      font-weight: 800;
      white-space: nowrap;
    }

    .profile-stat-value {
      margin: 14px 0 0;
      font-size: clamp(28px, 8.5vw, 34px);
      line-height: 1;
      font-weight: 900;
      white-space: nowrap;
    }

    .profile-stat-value small {
      font-size: clamp(12px, 3.8vw, 15px);
      font-weight: 700;
    }

    .profile-stat-note {
      margin: 10px 0 0;
      color: var(--muted);
      font-size: clamp(11px, 3.3vw, 13px);
    }

    .profile-stat-note b {
      color: var(--brand);
    }

    .profile-rate {
      display: grid;
      grid-template-columns: minmax(82px, 0.85fr) minmax(72px, 1fr);
      align-items: end;
      gap: 6px;
    }

    .profile-rate-chart {
      width: 100%;
      height: 64px;
    }

    .profile-shortcuts {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
      margin-bottom: 18px;
    }

    .profile-shortcut {
      min-height: 92px;
      display: grid;
      align-content: center;
      gap: 7px;
      padding: clamp(7px, 2.2vw, 10px);
      text-align: left;
      color: var(--ink);
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.92);
      box-shadow: var(--shadow-soft);
    }

    .profile-shortcut i {
      width: 34px;
      height: 34px;
      display: grid;
      place-items: center;
      color: var(--brand);
      border-radius: 12px;
      background: var(--brand-soft);
      font-style: normal;
    }

    .profile-shortcut i svg {
      width: 20px;
      height: 20px;
    }

    .profile-shortcut strong {
      overflow: hidden;
      font-size: clamp(9.5px, 2.95vw, 12.5px);
      line-height: 1.15;
      text-overflow: ellipsis;
    }

    .profile-shortcut span {
      color: var(--muted);
      overflow: hidden;
      font-size: clamp(8.5px, 2.7vw, 10px);
      line-height: 1.25;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
    }

    .profile-settings {
      margin-bottom: 10px;
      padding: 10px 18px;
      border-radius: 26px;
      background: rgba(255, 255, 255, 0.94);
      box-shadow: var(--shadow-soft);
    }

    .profile-setting-row {
      width: 100%;
      min-height: 61px;
      display: grid;
      grid-template-columns: 30px minmax(0, 1fr) auto 20px;
      align-items: center;
      gap: 11px;
      padding: 0;
      color: var(--ink);
      background: transparent;
      border-bottom: 1px solid rgba(234, 221, 225, 0.85);
      text-align: left;
    }

    .profile-setting-row:last-child {
      border-bottom: 0;
    }

    .profile-setting-row svg {
      width: 24px;
      height: 24px;
    }

    .profile-setting-row strong {
      min-width: 0;
      overflow: hidden;
      font-size: clamp(13px, 3.7vw, 15px);
      text-overflow: ellipsis;
    }

    .profile-setting-row span {
      color: var(--muted);
      max-width: 42vw;
      overflow: hidden;
      font-size: clamp(10px, 3vw, 12px);
      white-space: nowrap;
      text-overflow: ellipsis;
    }

    .profile-setting-row .chev {
      color: var(--muted);
      width: 18px;
      height: 18px;
    }

    .profile-setting-row.logout-row {
      color: var(--brand);
    }

    .profile-setting-row.logout-row span {
      color: var(--brand);
    }

    .empty {
      padding: 18px;
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      background: rgba(255, 255, 255, 0.72);
    }

    .tabbar {
      position: absolute;
      z-index: 60;
      left: 32px;
      right: 32px;
      bottom: calc(8px + env(safe-area-inset-bottom));
      height: var(--tab-h);
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      align-items: center;
      padding: 5px;
      border: 1px solid rgba(234, 221, 225, 0.86);
      border-radius: 25px;
      background: rgba(255, 255, 255, 0.9);
      box-shadow: 0 12px 26px rgba(36, 24, 28, 0.12);
      backdrop-filter: blur(16px);
    }

    .tab-button {
      min-height: 52px;
      display: grid;
      place-items: center;
      gap: 2px;
      color: var(--muted);
      border-radius: 19px;
      background: transparent;
      transition: transform 180ms ease, color 180ms ease, background 180ms ease;
    }

    .tab-button.active {
      color: var(--brand);
      background: var(--brand-soft);
      font-weight: 850;
    }

    .tab-button span {
      font-size: clamp(10px, 2.9vw, 11px);
    }

    .tab-button svg {
      width: 21px;
      height: 21px;
    }

    .brand-lockup {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 18px;
      font-size: 24px;
      font-weight: 800;
    }

    /* [IMAGE-10] 首页顶栏 App 图标 | [IMAGE-11] 右侧说明区 Logo */
    .logo-mark {
      width: 26px;
      height: 26px;
      border-radius: 50%;
      background: var(--brand);
      object-fit: cover;
      flex-shrink: 0;
    }

    .brand .app-icon {
      width: 28px;
      height: 28px;
      border-radius: 8px;
    }

    .note-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .note-grid button {
      min-height: 52px;
      border: 1px solid var(--line);
      border-radius: 16px;
      color: var(--ink);
      background: var(--card);
    }

    /* 电脑大屏说明面板结构 */
    .prototype-notes {
      display: none;
    }

    .login-center {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
    }

    .login-hero {
      display: grid;
      place-items: center;
      gap: 14px;
      margin-bottom: 36px;
    }

    .login-icon {
      width: 80px;
      height: 80px;
      border-radius: 22px;
      box-shadow: 0 14px 32px rgba(159, 18, 57, 0.18);
    }

    .login-hero h1 {
      margin: 0;
      font-size: 32px;
      font-weight: 800;
    }

    .login-hero p {
      margin: 0;
      color: var(--muted);
      font-size: 15px;
    }

    .login-btn {
      max-width: 280px;
    }

    .role-grid {
      display: grid;
      gap: 16px;
      margin-top: 24px;
    }

    .role-card {
      min-height: 148px;
      display: grid;
      place-items: center;
      gap: 6px;
      padding: 26px 20px;
      text-align: center;
      color: var(--ink);
      border: 2px solid var(--line);
      border-radius: var(--radius-lg);
      background: var(--card);
      box-shadow: var(--shadow-soft);
      transition: transform 180ms ease, border-color 180ms ease;
    }

    .role-card:active {
      transform: scale(0.97);
      border-color: var(--brand);
    }

    .role-icon {
      width: 48px;
      height: 48px;
      display: grid;
      place-items: center;
      border-radius: 50%;
      color: var(--brand);
      background: var(--brand-soft);
    }

    .role-icon svg {
      width: 26px;
      height: 26px;
    }

    .role-card h2 {
      margin: 0;
      font-size: clamp(17px, 5vw, 20px);
    }

    .role-card p {
      margin: 0;
      color: var(--muted);
      font-size: clamp(11.5px, 3.4vw, 13px);
      line-height: 1.5;
    }

    .login-form {
      margin-top: 24px;
    }

    .login-avatar {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      margin-bottom: 24px;
    }

    .role-badge {
      width: 64px;
      height: 64px;
      display: grid;
      place-items: center;
      border-radius: 50%;
      color: var(--brand);
      background: var(--brand-soft);
    }

    .role-badge svg {
      width: 32px;
      height: 32px;
    }

    .login-avatar span {
      font-size: 15px;
      font-weight: 800;
      color: var(--muted);
    }

    .login-hint {
      margin: 8px 0 0;
      text-align: center;
      color: var(--subtle);
      font-size: 12px;
    }

    .login-form-status {
      min-height: 20px;
      margin: 10px 0 0;
      text-align: center;
      color: var(--brand);
      font-size: 13px;
      font-weight: 800;
      line-height: 1.45;
      overflow-wrap: anywhere;
    }

    .login-form-status:empty {
      display: none;
    }

    .loading-spinner {
      width: 22px;
      height: 22px;
      display: inline-block;
      border-radius: 50%;
      border: 3px solid rgba(159, 18, 57, 0.16);
      border-top-color: var(--brand);
      animation: loading-spin 760ms linear infinite;
      vertical-align: middle;
    }

    .login-form-status.is-loading {
      display: grid;
      place-items: center;
      min-height: 34px;
    }

    .primary-button .loading-spinner {
      border-color: rgba(255, 255, 255, 0.28);
      border-top-color: #ffffff;
    }

    @keyframes loading-spin {
      to {
        transform: rotate(360deg);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .loading-spinner {
        animation: none;
      }
    }

    .login-switch {
      margin-top: 14px;
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 6px;
      color: var(--muted);
      font-size: 13px;
      font-weight: 700;
    }

    .login-switch .text-button {
      min-height: 34px;
      padding: 0 4px;
      font-size: 13px;
    }

    .locked-equip {
      min-height: 50px;
      display: flex;
      align-items: center;
      padding: 12px;
      border: 1px solid var(--line);
      border-radius: 15px;
      color: var(--ink);
      background: var(--brand-soft);
      font-weight: 800;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .login-form .primary-button {
      margin-top: 20px;
    }

    .confirm-overlay {
      position: absolute;
      inset: 0;
      z-index: 200;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(0, 0, 0, 0.45);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
    }

    .confirm-dialog {
      width: 280px;
      padding: 24px 20px 18px;
      border-radius: 22px;
      text-align: center;
      background: #ffffff;
      box-shadow: 0 24px 52px rgba(0, 0, 0, 0.22);
    }

    .confirm-dialog p {
      margin: 0 0 20px;
      font-size: 15px;
      font-weight: 700;
      color: var(--ink);
      line-height: 1.5;
    }

    .confirm-dialog h2 {
      margin: 0 0 16px;
      color: var(--ink);
      font-size: 19px;
      line-height: 1.2;
    }

    .name-dialog {
      width: min(300px, calc(100% - 44px));
      text-align: left;
    }

    .name-dialog input {
      width: 100%;
      min-height: 48px;
      margin: 0 0 16px;
      padding: 0 14px;
      border: 1px solid rgba(159, 18, 57, 0.18);
      border-radius: 15px;
      color: var(--ink);
      background: rgba(255, 247, 250, 0.72);
      font-size: 17px;
      font-weight: 800;
      outline: none;
    }

    .name-dialog input:focus {
      border-color: rgba(159, 18, 57, 0.5);
      box-shadow: 0 0 0 4px rgba(159, 18, 57, 0.1);
    }

    .confirm-dialog .confirm-actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    .confirm-dialog .btn-cancel {
      min-height: 44px;
      border: 1px solid var(--line);
      border-radius: 14px;
      color: var(--muted);
      background: rgba(255, 255, 255, 0.8);
      font-weight: 800;
    }

    .confirm-dialog .btn-danger {
      min-height: 44px;
      border: 0;
      border-radius: 14px;
      color: #ffffff;
      background: var(--bad);
      font-weight: 800;
    }

    /* ==================== NFC 扫描弹窗样式 ==================== */
    .nfc-scan-overlay {
      position: absolute;
      inset: 0;
      z-index: 200;
      display: grid;
      align-items: center;
      justify-content: center;
      padding: 28px;
      background: rgba(5, 5, 6, 0.92);
      backdrop-filter: blur(16px);
      animation: nfcFadeIn 0.24s ease;
    }

    @keyframes nfcFadeIn {
      0% { opacity: 0; }
      100% { opacity: 1; }
    }

    .nfc-scan-dialog {
      width: min(100%, 300px);
      padding: 32px 24px 22px;
      border-radius: 28px;
      text-align: center;
      color: #ffffff;
      background: rgba(24, 22, 32, 0.96);
      border: 1px solid rgba(255, 255, 255, 0.1);
      box-shadow: 0 24px 60px rgba(0, 0, 0, 0.5);
      animation: nfcDialogPop 0.32s ease;
    }

    @keyframes nfcDialogPop {
      0% { transform: scale(0.9); opacity: 0; }
      100% { transform: scale(1); opacity: 1; }
    }

    .nfc-scan-dialog h2 {
      margin: 0 0 8px;
      font-size: 20px;
      color: #ffffff;
    }

    .nfc-scan-dialog .nfc-hint {
      margin: 0 0 16px;
      font-size: 13px;
      color: rgba(255, 255, 255, 0.6);
      line-height: 1.5;
    }

    .nfc-scan-dialog .nfc-hint strong {
      display: block;
      margin-top: 4px;
      color: rgba(255, 255, 255, 0.85);
      font-size: 14px;
    }

    .nfc-scan-icon {
      width: 88px;
      height: 88px;
      margin: 0 auto 18px;
      display: grid;
      place-items: center;
      border-radius: 50%;
      color: var(--brand);
      background: rgba(159, 18, 57, 0.14);
      border: 2px solid rgba(159, 18, 57, 0.3);
      animation: nfcRingPulse 1.5s ease-in-out infinite;
    }

    .nfc-scan-icon svg {
      width: 42px;
      height: 42px;
    }

    @keyframes nfcRingPulse {
      0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(159, 18, 57, 0.4); }
      50% { transform: scale(1.06); box-shadow: 0 0 0 16px rgba(159, 18, 57, 0); }
    }

    .nfc-scan-dialog .nfc-scan-error-icon {
      color: var(--bad);
      background: rgba(161, 15, 43, 0.14);
      border-color: rgba(161, 15, 43, 0.3);
      animation: none;
    }

    .nfc-scan-dialog .nfc-scan-success-icon {
      color: var(--ok);
      background: rgba(22, 116, 68, 0.14);
      border-color: rgba(22, 116, 68, 0.3);
      animation: none;
    }

    .nfc-scan-dialog .nfc-actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 18px;
    }

    .nfc-scan-dialog .nfc-btn-cancel {
      min-height: 44px;
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 14px;
      color: rgba(255, 255, 255, 0.8);
      background: transparent;
      font-weight: 700;
      font-size: 14px;
      cursor: pointer;
    }

    .nfc-scan-dialog .nfc-btn-cancel:active {
      background: rgba(255, 255, 255, 0.06);
    }

    .nfc-scan-dialog .nfc-btn-retry {
      min-height: 44px;
      border: 0;
      border-radius: 14px;
      color: #ffffff;
      background: var(--brand);
      font-weight: 800;
      font-size: 14px;
      cursor: pointer;
    }

    .nfc-scan-dialog .nfc-btn-retry:active {
      background: var(--brand-deep);
    }

    .nfc-scan-dialog .nfc-btn-retry:disabled {
      opacity: 0.45;
      cursor: not-allowed;
    }

    /* NFC 扫描中设备图示 */
    .nfc-device-visual {
      position: relative;
      width: 120px;
      height: 120px;
      margin: 0 auto 22px;
      display: grid;
      place-items: center;
    }

    .nfc-device-visual .nfc-wave {
      position: absolute;
      inset: 0;
      border: 2px solid rgba(159, 18, 57, 0.3);
      border-radius: 50%;
      animation: nfcWave 1.8s ease-out infinite;
    }

    .nfc-device-visual .nfc-wave:nth-child(2) {
      animation-delay: 0.6s;
    }

    .nfc-device-visual .nfc-wave:nth-child(3) {
      animation-delay: 1.2s;
    }

    @keyframes nfcWave {
      0% { transform: scale(0.3); opacity: 0.9; }
      100% { transform: scale(1.1); opacity: 0; }
    }

    .nfc-device-core {
      width: 64px;
      height: 64px;
      display: grid;
      place-items: center;
      border-radius: 50%;
      color: #ffffff;
      background: var(--brand);
      box-shadow: 0 12px 28px rgba(159, 18, 57, 0.5);
      z-index: 2;
    }

    .nfc-device-core svg {
      width: 34px;
      height: 34px;
    }

    /* ==================== NFC 机器模式（公屏验证机）样式 ==================== */
    .nfc-machine-screen {
      position: absolute;
      inset: 0;
      z-index: 100;
      display: flex;
      flex-direction: column;
      color: #ffffff;
      background: #0a0a0c;
      font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "PingFang SC", "Microsoft YaHei", Arial, sans-serif;
    }

    .nfc-machine-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 18px 24px 10px;
      flex-shrink: 0;
    }

    .nfc-machine-header h1 {
      margin: 0;
      font-size: 22px;
      font-weight: 900;
      color: #ffffff;
      letter-spacing: 0.02em;
    }

    .nfc-machine-header .nfc-machine-badge {
      min-height: 32px;
      display: inline-flex;
      align-items: center;
      padding: 0 14px;
      border-radius: 999px;
      color: #ffb3c6;
      background: rgba(159, 18, 57, 0.25);
      font-size: 13px;
      font-weight: 900;
      border: 1px solid rgba(159, 18, 57, 0.35);
    }

    .nfc-machine-body {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 28px 32px 40px;
      text-align: center;
    }

    .nfc-machine-step {
      width: 100%;
      max-width: 360px;
    }

    .nfc-machine-step h2 {
      margin: 0 0 6px;
      font-size: 26px;
      font-weight: 900;
      color: #ffffff;
    }

    .nfc-machine-step .nfc-machine-desc {
      margin: 0 0 28px;
      font-size: 15px;
      color: rgba(255, 255, 255, 0.55);
      line-height: 1.5;
    }

    .nfc-machine-code-input {
      width: 100%;
      height: 72px;
      padding: 0 24px;
      border: 2px solid rgba(255, 255, 255, 0.18);
      border-radius: 20px;
      color: #ffffff;
      background: rgba(255, 255, 255, 0.06);
      font-size: 36px;
      font-weight: 900;
      text-align: center;
      letter-spacing: 12px;
      outline: none;
      caret-color: var(--brand);
    }

    .nfc-machine-code-input:focus {
      border-color: var(--brand);
      box-shadow: 0 0 0 4px rgba(159, 18, 57, 0.2);
    }

    .nfc-machine-code-input::placeholder {
      color: rgba(255, 255, 255, 0.2);
      letter-spacing: 4px;
      font-size: 22px;
    }

    .nfc-machine-btn {
      width: 100%;
      min-height: 60px;
      margin-top: 20px;
      border: 0;
      border-radius: 18px;
      color: #ffffff;
      background: linear-gradient(145deg, #c91946, #8c102e);
      font-size: 20px;
      font-weight: 900;
      cursor: pointer;
      box-shadow: 0 16px 28px rgba(159, 18, 57, 0.3);
      transition: transform 0.15s, opacity 0.15s;
    }

    .nfc-machine-btn:active {
      transform: scale(0.97);
    }

    .nfc-machine-btn:disabled {
      opacity: 0.45;
      cursor: not-allowed;
    }

    .nfc-machine-btn.is-secondary {
      color: rgba(255, 255, 255, 0.8);
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.15);
      box-shadow: none;
    }

    .nfc-machine-info-card {
      width: 100%;
      padding: 20px 18px;
      margin-bottom: 24px;
      border-radius: 20px;
      text-align: center;
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .nfc-machine-info-card .nfc-machine-equip-name {
      margin: 0;
      font-size: 22px;
      font-weight: 900;
      color: #ffffff;
    }

    .nfc-machine-info-card .nfc-machine-equip-id {
      margin: 6px 0 0;
      font-size: 13px;
      color: rgba(255, 255, 255, 0.5);
    }

    .nfc-machine-info-card .nfc-machine-student {
      margin: 12px 0 0;
      font-size: 14px;
      color: rgba(255, 255, 255, 0.65);
    }

    /* 机器模式 NFC 扫描动画（大尺寸公屏版） */
    .nfc-machine-scan-visual {
      position: relative;
      width: 180px;
      height: 180px;
      margin: 0 auto 30px;
      display: grid;
      place-items: center;
    }

    .nfc-machine-scan-visual .nfc-machine-wave {
      position: absolute;
      inset: 0;
      border: 3px solid rgba(159, 18, 57, 0.35);
      border-radius: 50%;
      animation: nfcMachineWave 2s ease-out infinite;
    }

    .nfc-machine-scan-visual .nfc-machine-wave:nth-child(2) {
      animation-delay: 0.65s;
    }

    .nfc-machine-scan-visual .nfc-machine-wave:nth-child(3) {
      animation-delay: 1.3s;
    }

    @keyframes nfcMachineWave {
      0% { transform: scale(0.25); opacity: 0.9; }
      100% { transform: scale(1.1); opacity: 0; }
    }

    .nfc-machine-scan-core {
      width: 100px;
      height: 100px;
      display: grid;
      place-items: center;
      border-radius: 50%;
      color: #ffffff;
      background: var(--brand);
      box-shadow: 0 18px 40px rgba(159, 18, 57, 0.5);
      z-index: 2;
      animation: nfcMachineCorePulse 1.6s ease-in-out infinite;
    }

    @keyframes nfcMachineCorePulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.04); }
    }

    .nfc-machine-scan-core svg {
      width: 52px;
      height: 52px;
    }

    .nfc-machine-result-icon {
      width: 100px;
      height: 100px;
      margin: 0 auto 20px;
      display: grid;
      place-items: center;
      border-radius: 50%;
    }

    .nfc-machine-result-icon.is-success {
      color: var(--ok);
      background: rgba(22, 116, 68, 0.15);
      border: 3px solid rgba(22, 116, 68, 0.3);
    }

    .nfc-machine-result-icon.is-error {
      color: var(--bad);
      background: rgba(161, 15, 43, 0.15);
      border: 3px solid rgba(161, 15, 43, 0.3);
    }

    .nfc-machine-result-icon svg {
      width: 50px;
      height: 50px;
    }

    .nfc-machine-back-link {
      margin-top: 24px;
      color: rgba(255, 255, 255, 0.4);
      background: transparent;
      border: 0;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      text-decoration: underline;
      text-underline-offset: 4px;
    }

    @media (min-width: 1024px) {
      .stage {
        min-height: 100vh;
        grid-template-columns: 430px minmax(320px, 500px);
        gap: 60px;
        align-items: center;
        padding: 16px;
      }

      .phone-shell {
        transform: scale(0.82);
        transform-origin: top center;
      }

      .phone-frame {
        width: 430px;
        height: 914px;
        padding: 14px;
        border-radius: 64px;
        background: linear-gradient(145deg, #161315, #050505 46%, #393436 58%, #080808);
        box-shadow:
          inset 0 0 0 2px rgba(255, 255, 255, 0.13),
          inset 0 0 0 7px #000000,
          0 32px 90px rgba(44, 18, 24, 0.28);
      }

      .phone-screen {
        border-radius: 52px;
      }

      .prototype-notes {
        display: block;
      }

      .prototype-notes h1 {
        margin: 0;
        font-size: 44px;
        line-height: 1.12;
      }

      .prototype-notes p {
        color: var(--muted);
        font-size: 17px;
        line-height: 1.7;
      }
    }

    @media (max-width: 360px) {
      .equipment-grid,
      .kpi-grid,
      .metric-row,
      .button-row,
      .loan-action-row,
      .admin-actions {
        grid-template-columns: 1fr;
      }

      .active-loan,
      .borrow-head,
      .machine-item,
      .order-card {
        grid-template-columns: 1fr;
      }

      .info-list strong {
        white-space: normal;
      }
    }

    @media (max-width: 480px) and (max-height: 760px) {
      .profile-topbar {
        min-height: 54px;
        padding: 0 24px 6px;
      }

      .profile-scroll {
        padding: 0 18px calc(var(--tab-h) + 30px + env(safe-area-inset-bottom));
      }

      .profile-identity {
        grid-template-columns: 76px minmax(0, 1fr) 22px;
        gap: 14px;
        padding: 6px 0 10px;
      }

      .profile-main-avatar {
        width: 76px;
        height: 76px;
      }

      .profile-meta {
        margin-top: 4px;
        font-size: 12px;
      }

      .profile-file {
        width: min(92%, 350px);
        margin: 2px auto 12px;
      }

      .profile-file::before {
        content: "";
        inset: 12% -2.5% -1%;
        border-radius: 24px;
        background: linear-gradient(180deg, rgba(246, 239, 243, 0.96), rgba(238, 228, 235, 0.9));
        box-shadow:
          0 14px 22px rgba(92, 12, 34, 0.12),
          inset 0 0 0 1px rgba(159, 18, 57, 0.065);
      }

      .profile-file::after {
        left: 13%;
        right: 13%;
        bottom: 0;
        height: 12%;
        background: rgba(92, 12, 34, 0.11);
        box-shadow: 0 8px 16px rgba(92, 12, 34, 0.11);
      }

      .profile-folder-img {
        filter: none;
      }

      .profile-file-title {
        margin-bottom: clamp(10px, 3vw, 14px);
      }

      .profile-stats-card {
        margin-bottom: 12px;
        padding: 14px 16px;
        border-radius: 22px;
      }

      .profile-divider {
        height: 74px;
      }

      .profile-stat-value {
        margin-top: 10px;
        font-size: clamp(26px, 8vw, 32px);
      }
    }

    @media (min-width: 481px) and (max-width: 1023px) {
      .topbar,
      .home-top,
      .search-row,
      .scroll > * {
        width: min(520px, calc(100% - 44px));
        margin-left: auto;
        margin-right: auto;
      }

      .profile-topbar,
      .profile-scroll > section {
        width: min(430px, calc(100% - 44px));
        margin-left: auto;
        margin-right: auto;
      }

      .topbar,
      .home-top,
      .profile-topbar {
        padding-left: 0;
        padding-right: 0;
      }

      .search-row,
      .scroll,
      .profile-scroll {
        padding-left: 0;
        padding-right: 0;
      }

      .tabbar {
        left: 50%;
        right: auto;
        width: min(396px, calc(100% - 56px));
        transform: translateX(-50%);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      *,
      *::before,
      *::after {
        scroll-behavior: auto !important;
        transition-duration: 0.01ms !important;
        animation-duration: 0.01ms !important;
      }
    }

    /* 针对表情符号做占位处理 */
    .equipment-placeholder-emoji {
      font-size: 32px;
      display: inline-block;
      vertical-align: middle;
      line-height: 1;
    }

    /* ==================== 2. ⚡ 新首页样式 — 背景图片 Hero ==================== */
    .new-hero-container {
      background:
        linear-gradient(rgba(0, 0, 0, 0.10), rgba(0, 0, 0, 0.10)),
        url("assets/hero.png?v=12") center/cover no-repeat;
      padding: 22px 18px;
      border-radius: 28px;
      border: 1px solid rgba(255, 255, 255, 0.15);
      box-shadow: var(--shadow);
      position: relative;
      overflow: hidden;
      margin-bottom: 16px;
      min-height: 290px;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
    }

    .new-hero-left {
      position: relative;
      z-index: 2;
      display: flex;
      flex-direction: column;
    }

    .new-hero-title {
      font-size: clamp(23px, 6.8vw, 26px);
      font-weight: 900;
      color: #1a1a1a;
      margin: 0;
      line-height: 1.25;
      letter-spacing: 0;
    }

    .new-hero-subtitle {
      font-size: clamp(11.5px, 3.5vw, 13px);
      color: #4a4a4a;
      margin-top: 6px;
      margin-bottom: 16px;
      font-weight: 500;
    }

    /* 垂直堆叠的三张统计卡片 */
    .new-stats-stack {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .new-stat-card {
      display: flex;
      align-items: center;
      width: fit-content;
      min-width: min(160px, 100%);
      padding: 10px 18px 10px 14px;
      background: #ffffff;
      border: 1.5px solid rgba(234, 221, 225, 0.4);
      border-radius: 16px;
      box-shadow: 0 4px 12px rgba(92, 12, 34, 0.02);
      transition: transform 0.18s;
    }

    .new-stat-card:active {
      transform: scale(0.98);
    }

    .new-stat-icon-wrapper {
      width: 38px;
      height: 38px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      margin-right: 12px;
    }

    .new-stat-icon-wrapper svg {
      width: 18px;
      height: 18px;
    }

    .red-theme,
    .blue-theme,
    .purple-theme {
      background-color: var(--brand-soft);
      color: var(--brand);
    }

    .new-stat-text {
      display: flex;
      flex-direction: column;
      min-width: 0;
    }

    .new-stat-label {
      font-size: clamp(9.5px, 2.8vw, 11px);
      color: #8c8c8c;
      margin-bottom: 2px;
      font-weight: bold;
    }

    .new-stat-val {
      font-size: clamp(13px, 3.7vw, 15px);
      font-weight: 800;
      color: #262626;
    }

    .new-stat-val small {
      font-size: clamp(9.5px, 2.8vw, 11px);
      font-weight: normal;
      color: #8c8c8c;
    }

    /* 首页专属轻量级反馈卡片样式 */
    .home-feedback-card {
      background: linear-gradient(135deg, var(--brand-soft) 0%, #ffffff 100%);
      border: 1px dashed var(--brand);
      border-radius: var(--radius-lg);
      padding: 14px 18px;
      box-shadow: var(--shadow-soft);
      transition: all 0.2s;
    }

    .home-feedback-card:active {
      transform: scale(0.98);
      border-color: var(--brand-deep);
    }

    .feedback-card-content {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
    }

    .feedback-card-text {
      flex: 1;
      min-width: 0;
    }

    .feedback-card-text h3 {
      margin: 0;
      overflow: hidden;
      font-size: clamp(12px, 3.6vw, 14px);
      font-weight: 800;
      color: var(--brand-deep);
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .feedback-card-text p {
      margin: 4px 0 0;
      font-size: clamp(9.5px, 3vw, 11px);
      color: var(--muted);
      line-height: 1.4;
    }

    .feedback-arrow {
      color: var(--brand);
      display: flex;
      align-items: center;
      justify-content: center;
    }

  </style>
</head>
<body>

  <!-- ==================== 2. 双栏容器布局 ==================== -->
  <div class="stage">
    
    <!-- 左侧：高保真手机壳仿真器 -->
    <div class="phone-shell">
      <div class="phone-frame">
        <div class="phone-screen">
          
          <!-- 挂载渲染的原生 DOM 容器 -->
          <div class="app" id="app"></div>

        </div>
      </div>
    </div>

    <!-- 右侧：电脑端的交互说明区 -->
    <div class="prototype-notes">
      <div class="brand-lockup">
        <!-- [IMAGE-11] 右侧说明区 Logo：替换为 <img src="你的logo.png" alt="SportLoop" style="width:26px;height:26px"> -->
        <div class="logo-mark" style="width: 26px; height: 26px; border-radius: 50%; background: var(--brand);"></div>
        <span>SportLoop Pro</span>
      </div>
      <h1>体育设备共享管家</h1>
      <p>
        此环境已将你编写的原生 JavaScript 交互内核与高级 CSS 面板无缝缝合。
        完美支持无滚动条滑动机制、多状态标签（ok, warn, bad）、拍照识别流、线下智能柜扫码预约同步等全量逻辑。
      </p>
      <div class="note-grid" style="margin-top: 24px;">
        <button id="btnAdminAccess" style="font-weight: 800;">⚙️ 管理员工作台</button>
        <button id="btnClearCache" style="font-weight: 800; color: var(--bad)">🧼 清空数据缓存</button>
      </div>
    </div>

  </div>

  <!-- ==================== 3. 原生 APP.JS DOM 渲染代码 ==================== -->
  <script>
    // 💡 强刷版本键名，绕过老旧的缓存干扰，促使全新首页布局立刻下发
    const STORAGE_KEY = "sportloop-ios-app-v7";
    const AUTH_STORAGE_KEY = "sportloop-supabase-auth-v1";
    const SUPABASE_URL = "https://udxcarumabyqfbnrpqxa.supabase.co";
    const SUPABASE_PUBLIC_KEY = "sb_publishable_HCLrmU8VEm6XPFHz-mf6zg_ztSp2gEQ";

    // 替换 assets 下同名图片后，把此数字 +1，可避免浏览器继续显示旧图缓存
    const ASSET_VERSION = "12";
    const CLASS_PERIOD_MINUTES = 90;
    const BORROW_PERIOD_OPTIONS = [1, 2, 3];
    const PHOTO_MAX_SIDE = 1280;
    const PHOTO_JPEG_QUALITY = 0.78;
    const DETECTION_PASS_CONFIDENCE = 0.7;
    const PHOTO_MAX_DATA_URL_LENGTH = 1800000;

    const reportIssueTypes = {
      "乒乓球拍": ["胶皮脱落", "拍柄松动", "表面磨损", "底板开裂"],
      "羽毛球拍": ["拍柄松动", "拍框变形", "拍线断裂", "握柄磨损"],
      "篮球": ["气压不足", "表面磨损", "表皮脱落", "球体变形"],
      "足球": ["气压不足", "表面磨损", "表皮脱落", "缝线开裂"],
    };

    function issueOptionsFor(equipmentId) {
      const item = byId(equipmentId);
      const types = item ? (reportIssueTypes[item.category] || reportIssueTypes["篮球"]) : reportIssueTypes["篮球"];
      return types.map((t) => `<option>${t}</option>`).join("") + `<option>其他</option>`;
    }

    const APP_ICON_SRC = "assets/app-icon.png";
    const HERO_EQUIPMENT_SRC = "assets/hero.png";
    const PROFILE_FOLDER_SRC = "assets/profile-folder-from-upload.png";

    /*
    ═══════════════════════════════════════════════════════════════════════════
    [IMAGE 图片替换索引] — 搜索 "IMAGE-" 可跳转到每一处
    ═══════════════════════════════════════════════════════════════════════════
    器材图（推荐相对路径 assets/xxx.png，与 index.html 同目录）:
      IMAGE-01  paddle-red    乒乓球拍（直拍）
      IMAGE-02  paddle-black  乒乓球拍（横拍）
      IMAGE-03  racket        羽毛球拍
      IMAGE-04  shuttle       羽毛球
      IMAGE-05  pingpong      乒乓球
      IMAGE-06  basketball    篮球

    器材图展示尺寸（CSS，可改 object-fit / 高度）:
      IMAGE-CSS-item-img    首页热门器材网格 .item-img
      IMAGE-CSS-list-img    列表缩略图 .list-img
      IMAGE-CSS-detail-img  详情/确认/结果大图 .detail-img
      IMAGE-CSS-loan-thumb  借用卡片缩略图 .loan-thumb
      IMAGE-CSS-camera-img  检测/同步取景 .camera-img
      IMAGE-CSS-order-img   管理员工单 .order-img

    路径处理:
      toImageSrc()   反斜杠→正斜杠；Windows 盘符→file:///；中文分段 URL 编码
      assetUrl()     静态图加 ?v=ASSET_VERSION，换同名图后改 ASSET_VERSION 防缓存
      escapeAttr()   写入 HTML 属性时转义

    核心渲染（<img src> 在此生成）:
      IMAGE-FN  equipmentImage() 函数

    首页 / 品牌图:
      IMAGE-HERO  assets/hero-equipment.png  首页右侧主图 .hero-equipment-img
      IMAGE-10   assets/app-icon.png         首页顶栏 App 图标
      IMAGE-11   右侧说明区 logo .logo-mark（仍为色块，可自行改图）
      IMAGE-12  顶栏/个人中心头像 .avatar

    用户上传（运行时选择，非静态路径）:
      IMAGE-13  归还前检测 #photoInput
      IMAGE-14  报损反馈 #reportPhoto

    兜底:
      IMAGE-ERR equipmentImage 加载失败时显示 ⚽
      IMAGE-PH  equipmentImage 无 URL 时 emoji 占位（item.image 填 emoji 如 🏓）
    ═══════════════════════════════════════════════════════════════════════════
    */

    const icons = {
      menu: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
      back: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
      search: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/><path d="M16.5 16.5 21 21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
      home: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 10.5 12 3l9 7.5V21h-6v-6H9v6H3V10.5z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>`,
      bag: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 8h12l-1 13H7L6 8z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M9 8a3 3 0 0 1 6 0" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
      bell: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M18 9a6 6 0 0 0-12 0c0 7-3 7-3 9h18c0-2-3-2-3-9z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M10 21h4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
      user: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="2"/><path d="M4 21c1.2-4 4-6 8-6s6.8 2 8 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
      scan: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M8 3H5a2 2 0 0 0-2 2v3M16 3h3a2 2 0 0 1 2 2v3M8 21H5a2 2 0 0 1-2-2v-3M16 21h3a2 2 0 0 0 2-2v-3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path d="M7 12h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
      camera: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 8h4l1.5-2h5L16 8h4v11H4V8z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><circle cx="12" cy="13.5" r="3.2" stroke="currentColor" stroke-width="2"/></svg>`,
      check: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/><path d="m8 12 2.7 2.7L16.5 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
      alert: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m12 3 10 18H2L12 3z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M12 9v5M12 17h.01" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/></svg>`,
      shield: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3 19 6v5c0 4.4-2.8 8.2-7 10-4.2-1.8-7-5.6-7-10V6l7-3z" stroke="currentColor" stroke-width="2"/><path d="m8.5 12 2.2 2.2 4.8-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
      wrench: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94L14.7 6.3Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
      chevron: `<svg class="chev" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="m9 5 7 7-7 7" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
      qr: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 4h6v6H4V4zM14 4h6v6h-6V4zM4 14h6v6H4v-6zM14 14h2v2h-2v-2zM18 14h2v6h-4v-2h2v-4zM12 18h2v2h-2v-2z" stroke="currentColor" stroke-linejoin="round" stroke-width="2"/></svg>`,
      gear: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 8.2a3.8 3.8 0 1 0 0 7.6 3.8 3.8 0 0 0 0-7.6Z" stroke="currentColor" stroke-width="2"/><path d="M19.4 13.5c.1-.5.1-1 .1-1.5s0-1-.1-1.5l2-1.5-2-3.5-2.4 1a8 8 0 0 0-2.6-1.5L14 2.5h-4L9.6 5a8 8 0 0 0-2.6 1.5l-2.4-1-2 3.5 2 1.5c-.1.5-.1 1-.1 1.5s0 1 .1 1.5l-2 1.5 2 3.5 2.4-1a8 8 0 0 0 2.6 1.5l.4 2.5h4l.4-2.5a8 8 0 0 0 2.6-1.5l2.4 1 2-3.5-2-1.5Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>`,
      edit: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 20h4l11-11-4-4L4 16v4Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="m14 6 4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
      clock: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/><path d="M12 7v5l3 2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
      file: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 4h14v16H5V4Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M8 8h8M8 12h8M8 16h5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
      refresh: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 7v5h-5M4 17v-5h5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M19 12a7 7 0 0 0-12-5M5 12a7 7 0 0 0 12 5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
      message: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 5h16v12H8l-4 4V5Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M8 10h8M8 14h5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
      idcard: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="2"/><circle cx="9" cy="11" r="2" stroke="currentColor" stroke-width="2"/><path d="M6.5 16c.7-1.4 1.5-2 2.5-2s1.8.6 2.5 2M14 10h4M14 14h4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
      help: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/><path d="M9.8 9a2.4 2.4 0 0 1 4.4 1.3c0 1.8-2.2 2-2.2 3.7M12 17h.01" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/></svg>`,
      headset: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 13a8 8 0 0 1 16 0v4a2 2 0 0 1-2 2h-2v-7h4M4 12h4v7H6a2 2 0 0 1-2-2v-5Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M14 21h2a4 4 0 0 0 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>`,
      logout: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M10 5H5v14h5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 8l4 4-4 4M18 12H9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
      grid: `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" ry="2" stroke="currentColor" stroke-width="2"/><line x1="9" y1="3" x2="9" y2="21" stroke="currentColor" stroke-width="2"/><line x1="15" y1="3" x2="15" y2="21" stroke="currentColor" stroke-width="2"/><line x1="3" y1="9" x2="21" y2="9" stroke="currentColor" stroke-width="2"/><line x1="3" y1="15" x2="21" y2="15" stroke="currentColor" stroke-width="2"/></svg>`,
    };

    const seed = {
      profile: {
