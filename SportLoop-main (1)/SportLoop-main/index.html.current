            <small>${venue.open ? "开放中" : "已关闭"}</small>
          </div>
          <button class="${venue.open ? "secondary-button" : "primary-button"}" data-admin-venue-toggle="${escapeAttr(venue.id)}" style="grid-column:1/-1;margin-top:6px;">${venue.open ? icon("shield") + " 关闭场地" : icon("check") + " 开放场地"}</button>
        </article>
      `;
    }

    function adminEquipmentFilterPanel() {
      const statuses = ["全部", "可借", "补充中", "维修中", "异常待确认"];
      return `
        <div class="admin-filter-panel">
          <label class="field">
            <span>搜索器材</span>
            <input id="adminEquipmentSearch" value="${escapeAttr(state.adminEquipmentQuery)}" placeholder="名称、编号、场馆或芯片号" />
          </label>
          <label class="field">
            <span>状态</span>
            <select id="adminEquipmentStatusFilter">
              ${statuses.map((status) => `<option value="${escapeAttr(status)}" ${state.adminEquipmentStatus === status ? "selected" : ""}>${escapeHtml(status)}</option>`).join("")}
            </select>
          </label>
        </div>
      `;
    }

    function filteredAdminEquipmentList() {
      const query = normalizeIdentityText(state.adminEquipmentQuery).toLowerCase();
      const status = state.adminEquipmentStatus || "全部";
      return store.equipment.filter((item) => {
        const haystack = [
          item.name,
          item.assetId,
          item.category,
          item.venue,
          item.status,
          ...(Array.isArray(item.nfcTags) ? item.nfcTags : []),
        ].join(" ").toLowerCase();
        const matchQuery = !query || haystack.includes(query);
        const matchStatus = status === "全部" || item.status === status;
        return matchQuery && matchStatus;
      });
    }

    function adminMachineSyncLogCard(log) {
      return `
        <article class="admin-log-card adminMachineSyncLog">
          <div class="admin-log-head">
            <div>
              <strong>${escapeHtml(log.summary || "机器入库同步")}</strong>
              <p>${escapeHtml(log.createdAt || "")}</p>
            </div>
            ${tag(log.failedCount ? "异常" : "已同步")}
          </div>
          <div class="admin-log-meta">
            <span>器材 ${log.itemCount}</span>
            <span>新增芯片 ${log.chipCount}</span>
            <span>重复 ${log.duplicateCount}</span>
            <span>失败 ${log.failedCount}</span>
          </div>
        </article>
      `;
    }

    function adminOperationLogCard(log) {
      return `
        <article class="admin-log-card adminOperationLog">
          <div class="admin-log-head">
            <div>
              <strong>${escapeHtml(log.action || "管理员操作")}</strong>
              <p>${escapeHtml(log.summary || "")}</p>
            </div>
            <span class="admin-equipment-chip">${escapeHtml(log.createdAt || "")}</span>
          </div>
          <div class="admin-log-meta">
            <span>${escapeHtml(log.targetType || "系统")}</span>
            ${log.targetId ? `<span>${escapeHtml(log.targetId)}</span>` : ""}
          </div>
        </article>
      `;
    }

    function adminFanFallbackWidth() {
      return Math.min(420, Math.max(300, window.innerWidth - 54));
    }

    function adminFanActiveIndex(total) {
      const max = Math.max(0, Number(total) - 1);
      return Math.max(0, Math.min(max, Number(state.adminFanIndex) || 0));
    }

    function adminFanSwipeDistance(stage) {
      const width = stage?.clientWidth || adminFanFallbackWidth();
      return Math.max(82, Math.min(116, width * 0.27));
    }

    function adminFanCardView(index, activeIndex, dragProgress = 0, stageWidth = adminFanFallbackWidth()) {
      const rawOffset = index - activeIndex + dragProgress;
      const offset = Math.max(-3, Math.min(3, rawOffset));
      const abs = Math.abs(rawOffset);
      const angle = offset * 14.5 * Math.PI / 180;
      const radius = Math.max(255, Math.min(310, stageWidth * 0.72));
      const x = Math.sin(angle) * radius;
      const y = (1 - Math.cos(angle)) * radius * 0.68 - 34;
      const rotate = offset * 9.5;
      const scale = Math.max(0.76, 1 - Math.min(abs, 3) * 0.065);
      const opacity = abs > 1.95 ? 0 : Math.max(0, 1 - Math.max(0, abs - 1.24) * 0.68);
      return {
        fanX: `${x.toFixed(1)}px`,
        fanY: `${y.toFixed(1)}px`,
        fanRotate: `${rotate.toFixed(2)}deg`,
        fanZ: String(Math.max(1, Math.round(100 - abs * 16))),
        fanScale: scale.toFixed(3),
        fanOpacity: opacity.toFixed(3),
        fanPointer: abs > 1.9 ? "none" : "auto",
        isActive: abs < 0.52,
        isHidden: abs > 1.95,
      };
    }

    function adminFanStyle(view) {
      return `--fan-x:${view.fanX}; --fan-y:${view.fanY}; --fan-rotate:${view.fanRotate}; --fan-z:${view.fanZ}; --fan-scale:${view.fanScale}; --fan-opacity:${view.fanOpacity}; --fan-pointer:${view.fanPointer};`;
    }

    function adminQuickNav(items) {
      const meta = {
        batch: ["check", "is-batch"],
        messages: ["message", "is-messages"],
        orders: ["wrench", "is-orders"],
        equipment: ["bag", "is-equipment"],
        syncLogs: ["refresh", "is-sync"],
        logs: ["file", "is-logs"],
        venues: ["grid", "is-venues"],
        export: ["file", "is-export"],
      };
      const activeIndex = adminFanActiveIndex(items.length);
      return `
        <nav class="admin-quick-nav" aria-label="管理员端快捷目录">
          <div class="admin-quick-stage" data-admin-fan-stage>
            <div class="admin-swipe-hint">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M8 7 3 12l5 5M16 7l5 5-5 5M4 12h16" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>左右滑动</span>
            </div>
            <div class="admin-quick-track">
              ${items.map(([key, label, count], index) => {
                const [iconName, className] = meta[key] || ["check", ""];
                const targetRoute = adminModuleRoutes[key] || "admin";
                const view = adminFanCardView(index, activeIndex);
                return `
                <button class="admin-quick-button ${className} ${view.isActive ? "is-active" : ""} ${view.isHidden ? "is-hidden" : ""}" type="button" data-admin-route="${escapeAttr(targetRoute)}" data-admin-fan-index="${index}" style="${adminFanStyle(view)}">
                  <i>${icon(iconName)}</i>
                  <span class="admin-quick-text">
                    <span>${escapeHtml(label)}</span>
                    <small data-admin-fan-hint>${view.isActive ? "点击进入" : ""}</small>
                  </span>
                  <b>${count}</b>
                </button>
              `;
              }).join("")}
            </div>
          </div>
        </nav>
      `;
    }

    function adminSection(key, title, desc, status, content) {
      return `
        <section class="admin-section-card" data-admin-section="${escapeAttr(key)}">
          <div class="admin-section-title">
