    function adminVenueManager() {
      const venues = Array.isArray(store.venues) ? store.venues : [];
      return `
        <form class="admin-machine-sync-card" id="adminVenueForm">
          <div class="admin-machine-sync-head">
            <div>
              <h3>添加场馆</h3>
              <p>输入场馆名称后点击添加。</p>
            </div>
          </div>
          <div style="display:grid;gap:12px;">
            <label class="field" style="margin:0;">
              <span>场馆名称</span>
              <input id="adminVenueInput" placeholder="例如：游泳馆" style="color:#fff;background:#1a1a2e;border:1px solid rgba(255,255,255,0.3);border-radius:12px;padding:12px;font-size:16px;width:100%;min-height:48px;box-sizing:border-box;" />
