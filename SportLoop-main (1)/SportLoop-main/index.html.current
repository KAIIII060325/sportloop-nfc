            ${tags.length ? tags.map((tag, i) => `
              <span style="display:inline-flex;align-items:center;gap:6px;margin:2px 4px;padding:4px 10px;border-radius:8px;background:rgba(255,255,255,0.06);font-size:11px;color:rgba(255,255,255,0.8);">
                ${escapeHtml(String(tag))}
                <button data-admin-delete-tag="${escapeAttr(item.id)}" data-tag-value="${escapeAttr(String(tag))}" style="color:#f87171;background:none;border:0;cursor:pointer;font-size:14px;line-height:1;padding:0;">&times;</button>
              </span>
            `).join("") : `<span style="color:rgba(255,255,255,0.3);font-size:11px;">暂无 NFC 标签</span>`}
          </div>
        </article>
