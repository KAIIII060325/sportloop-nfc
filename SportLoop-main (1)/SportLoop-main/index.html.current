    const appEl = document.querySelector("#app");

    function clone(value) {
      return JSON.parse(JSON.stringify(value));
    }

    function loadAuthSession() {
      try {
        const raw = localStorage.getItem(AUTH_STORAGE_KEY);
        if (!raw) return null;
        const session = JSON.parse(raw);
        if (!session?.accessToken || !session?.userId) return null;
        if (Number(session.expiresAt || 0) * 1000 <= Date.now()) {
          localStorage.removeItem(AUTH_STORAGE_KEY);
          return null;
        }
        return session;
      } catch {
        localStorage.removeItem(AUTH_STORAGE_KEY);
        return null;
      }
    }

    function saveAuthSession(session) {
      authSession = session;
      localStorage.setItem(AUTH_STORAGE_KEY, JSON.stringify(session));
      applyAuthSessionToState();
    }

    function applyAuthSessionToState() {
      if (!authSession?.accessToken) return;
      state.loggedIn = true;
      state.currentUserId = authSession.userId;
      state.currentEmail = authSession.email || "";
      state.loginRole = authSession.loginRole || authSession.role || state.loginRole || "student";
    }

    function clearAuthSession() {
      authSession = null;
      localStorage.removeItem(AUTH_STORAGE_KEY);
      state.loggedIn = false;
      state.currentUserId = "";
      state.currentEmail = "";
      state.isAdmin = false;
      state.loading = false;
    }

    function handleLogout() {
      if (currentUserRole() === "machine") {
        showPasswordConfirm("退出机器模式需要验证管理员密码", async (password) => {
          try {
            await supabaseAuthRequest("token?grant_type=password", {
              email: authSession?.email || "",
              password,
            });
            resetNfcMachineState();
            clearAuthSession();
            state.route = "login";
            state.notice = "已退出机器模式";
            render();
          } catch {
            state.notice = "密码错误，退出取消";
            render();
          }
        });
        return;
      }
      showConfirm("确定要退出当前账号吗？", () => {
        resetNfcMachineState();
        clearAuthSession();
        state.route = "login";
        state.notice = "已退出登录";
        render();
      }, "退出登录");
    }

    function showPasswordConfirm(message, onConfirm) {
      const overlay = document.createElement("div");
      overlay.className = "confirm-overlay";
      overlay.innerHTML = `
        <form class="confirm-dialog name-dialog">
          <p>${message}</p>
          <input type="password" name="password" placeholder="请输入管理员密码" style="width:100%;min-height:48px;padding:0 14px;border:1px solid rgba(159,18,57,0.18);border-radius:15px;font-size:16px;margin:0 0 16px;" />
          <div class="confirm-actions">
            <button class="btn-cancel" type="button">取消</button>
            <button class="btn-danger" type="submit">确认退出</button>
          </div>
        </form>
      `;
      const input = overlay.querySelector("input");
      overlay.querySelector(".btn-cancel").addEventListener("click", () => overlay.remove());
      overlay.querySelector("form").addEventListener("submit", (event) => {
        event.preventDefault();
        const password = input.value.trim();
        if (!password) { input.focus(); return; }
        overlay.remove();
        if (onConfirm) onConfirm(password);
      });
      overlay.addEventListener("click", (e) => {
        if (e.target === overlay) overlay.remove();
      });
      document.querySelector("#app").appendChild(overlay);
      setTimeout(() => input.focus(), 150);
    }

    function supabaseHeaders(extra = {}) {
      const headers = {
        apikey: SUPABASE_PUBLIC_KEY,
        "Content-Type": "application/json",
        ...extra,
      };
      if (authSession?.accessToken) headers.Authorization = `Bearer ${authSession.accessToken}`;
      return headers;
    }

    async function supabaseAuthRequest(path, body) {
      const response = await fetch(`${SUPABASE_URL}/auth/v1/${path}`, {
        method: "POST",
        headers: supabaseHeaders(),
        body: JSON.stringify(body),
      });
      const data = await response.json().catch(() => ({}));
      if (!response.ok) throw new Error(data.msg || data.message || data.error_description || data.error || "认证失败");
      return data;
    }

    async function supabaseRequest(path, options = {}) {
      if (!authSession?.accessToken) throw new Error("请先登录");
      const response = await fetch(`${SUPABASE_URL}/rest/v1/${path}`, {
        method: options.method || "GET",
        headers: supabaseHeaders(options.headers || {}),
        body: options.body ? JSON.stringify(options.body) : undefined,
      });
      if (response.status === 204) return null;
      const text = await response.text();
      const data = text ? JSON.parse(text) : null;
      if (!response.ok) throw new Error(data?.message || data?.hint || "数据库请求失败");
      return data;
    }

    async function supabaseFunctionRequest(name, body) {
      if (!authSession?.accessToken) throw new Error("请先登录");
      const response = await fetch(`${SUPABASE_URL}/functions/v1/${name}`, {
        method: "POST",
        headers: supabaseHeaders(),
        body: JSON.stringify(body),
      });
      const data = await response.json().catch(() => ({}));
      if (!response.ok) throw new Error(friendlyFunctionError(data?.error || data?.message || "云函数请求失败"));
      return data;
    }

    function friendlyFunctionError(message) {
      const text = String(message || "");
      const lower = text.toLowerCase();
      const isMiniMaxBalance =
        lower.includes("insufficient_balance") ||
        lower.includes("insufficient balance") ||
        lower.includes("quota has been exceeded") ||
        lower.includes("quota exceeded") ||
        (lower.includes("minimax") && lower.includes("402"));
      if (isMiniMaxBalance) return "MiniMax 余额不足或密钥配置异常，请检查 Supabase 里的 API Key、接口区域和可用额度。";
      if (lower.includes("invalid api key") || lower.includes("unauthorized")) return "MiniMax API Key 无效，请检查 Supabase 里的密钥配置。";
      return text || "云函数请求失败";
    }

    function normalizeLoginEmail(account) {
      const raw = String(account || "").trim().normalize("NFKC").toLowerCase();
      if (!raw) throw new Error("账号不能为空");
      if (raw.includes("@")) return raw;
      const safe = raw.replace(/[^a-z0-9._-]/g, "");
      if (!safe) throw new Error("账号请用数字、英文或邮箱");
      return `${safe}@sportloop.local`;
    }

    function loginStatusHtml() {
      if (state.loading) return `<p class="login-form-status is-loading"><span class="loading-spinner" aria-hidden="true"></span></p>`;
      return state.notice ? `<p class="login-form-status">${escapeHtml(state.notice)}</p>` : `<p class="login-form-status"></p>`;
    }

    function reportRemoteSyncError(error) {
      console.error("远程数据同步失败", error);
    }

    function makeUuid() {
      return crypto.randomUUID();
    }

    function parseDetectionResult(value) {
      if (!value) {
        return { status: "", damageLevel: "", confidence: 0, riskLabel: "低", issueCount: 0, summary: "暂无检测结果。", issues: [], targetMatched: false, comparable: false, needsAdminReview: false };
      }
      if (value === "正常") {
        return { status: "正常", damageLevel: "normal", confidence: 0.97, riskLabel: "低", issueCount: 0, summary: "未发现明显破损，请到场馆机器完成归还扫码。", issues: [], targetMatched: true, comparable: true, needsAdminReview: false };
      }
      if (value === "异常") {
        return { status: "异常", damageLevel: "obvious", confidence: 0.86, riskLabel: "中", issueCount: 2, summary: "疑似新增损耗，已生成异常记录。", issues: ["疑似胶皮翘边", "疑似拍柄松动"], targetMatched: false, comparable: false, needsAdminReview: true };
      }
      try {
        const data = JSON.parse(value);
        const status = data.status === "异常" ? "异常" : "正常";
        const targetMatched = data.target_matched === true;
        const comparable = data.comparable === true;
        const confidence = Math.max(0, Math.min(1, Number(data.confidence) || 0));
        const passed = status === "正常" && confidence >= DETECTION_PASS_CONFIDENCE && targetMatched && comparable;
        return {
          status: passed ? "正常" : "异常",
          damageLevel: data.damage_level || (status === "异常" ? "obvious" : "normal"),
          confidence,
          riskLabel: passed ? (data.risk_label || "低") : (data.risk_label === "高" ? "高" : "中"),
          issueCount: passed ? 0 : Math.max(1, Number(data.issue_count) || 0),
          summary: passed ? (data.summary || "未发现明显新增损耗。") : invalidDetectionSummary(data),
          issues: Array.isArray(data.issues) ? data.issues.filter(Boolean) : [],
          targetMatched,
          comparable,
          needsAdminReview: !passed || Boolean(data.needs_admin_review),
        };
      } catch {
        return { status: String(value), damageLevel: "", confidence: 0, riskLabel: "低", issueCount: 0, summary: String(value), issues: [], targetMatched: false, comparable: false, needsAdminReview: true };
      }
    }

    function invalidDetectionSummary(data) {
      if (data.target_matched !== true) return "照片中未清楚显示目标器材，无法完成归还质检对比。";
      if (data.comparable !== true) return "两张照片无法有效对比目标器材，请重新上传清晰照片或反馈给管理员。";
      if ((Number(data.confidence) || 0) < DETECTION_PASS_CONFIDENCE) return "检测可信度过低，请重新上传清晰照片或反馈给管理员。";
      return data.summary || "检测未通过，请重新上传照片或反馈给管理员。";
    }

    function serializeDetectionResult(result) {
      return JSON.stringify({
        status: result.status === "异常" ? "异常" : "正常",
        damage_level: result.damage_level || "normal",
        confidence: Math.max(0, Math.min(1, Number(result.confidence) || 0)),
        risk_label: result.risk_label || (result.status === "异常" ? "中" : "低"),
        issue_count: Math.max(0, Number(result.issue_count) || 0),
        summary: String(result.summary || "").trim(),
        issues: Array.isArray(result.issues) ? result.issues.map(String).filter(Boolean).slice(0, 5) : [],
        needs_admin_review: Boolean(result.needs_admin_review),
        target_matched: result.target_matched === true,
        comparable: result.comparable === true,
      });
    }

    function detectionCanPass(result) {
      return !!result
        && result.status === "正常"
        && result.confidence >= DETECTION_PASS_CONFIDENCE
        && result.targetMatched === true
        && result.comparable === true;
    }

    function detectionIsAbnormal(loan) {
      return !detectionCanPass(parseDetectionResult(loan?.detectResult));
    }

    function detectionLabel(loan) {
      return parseDetectionResult(loan?.detectResult).status || "未检测";
    }

    function loanCanMachineReturn(loan) {
      return !!loan
        && !loanNeedsBeforePhoto(loan)
        && loan.status === "待归还"
        && loan.returnMachineAllowed === true
        && !detectionIsAbnormal(loan);
    }

    function confidenceText(value) {
      const num = Number(value);
      if (!Number.isFinite(num) || num <= 0) return "--";
      return `${Math.round(num * 100)}%`;
    }

    function dbTimeText(value) {
      const ms = Date.parse(value || "");
      return Number.isFinite(ms) ? formatDateTime(ms) : "";
    }

    function dbDueText(value) {
      const ms = Date.parse(value || "");
      return Number.isFinite(ms) ? formatDueTime(ms) : "";
    }

    function toIso(ms) {
      return new Date(Number(ms)).toISOString();
    }

    function durationLabelFromMinutes(periods, minutes) {
      const hours = Number(minutes || 0) / 60;
      return `${Number(periods || 0)} 节课 · ${Number.isInteger(hours) ? hours : hours.toFixed(1)} 小时`;
    }

    function dbEquipmentToLocal(row) {
      return {
        id: row.id,
        assetId: row.asset_id,
        name: row.name,
        category: row.category,
        image: row.image,
        total: row.total,
        available: row.available,
        status: row.status,
        health: row.health,
        venue: row.venue,
        desc: row.description,
        nfcTags: Array.isArray(row.nfc_tags) ? row.nfc_tags : [],
        machineSyncedAt: row.machine_synced_at || "",
      };
    }

    function equipmentToDbPayload(item) {
      return {
        id: item.id,
        asset_id: item.assetId,
        name: item.name,
        category: item.category,
        image: item.image || "",
        total: item.total,
        available: item.available,
        status: item.status,
        health: item.health,
        venue: item.venue,
        description: item.desc,
        nfc_tags: Array.isArray(item.nfcTags) ? item.nfcTags : [],
        machine_synced_at: item.machineSyncedAt || null,
      };
    }

    function dbProfileToLocal(row) {
